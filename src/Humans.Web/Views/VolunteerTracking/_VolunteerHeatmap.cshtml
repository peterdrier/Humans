@model Humans.Web.Models.HeatmapPartialModel
@using Humans.Application.DTOs
@using Humans.Web.Authorization
@using Microsoft.AspNetCore.Authorization
@using NodaTime
@inject IAuthorizationService AuthService

@{
    var canWrite = (await AuthService.AuthorizeAsync(User, PolicyNames.VolunteerTrackingWrite)).Succeeded;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";

    if (Model.Rows.Count == 0)
    {
        <div class="alert alert-info">
            <i class="fa-solid fa-circle-info me-2"></i>@Localizer["VolTrack_Main_Empty"]
        </div>
        return;
    }

    var dayOffsets = Enumerable.Range(Model.BuildStartOffset, -Model.BuildStartOffset).ToList();

    static string CellClass(VolunteerCellState s) => s switch
    {
        VolunteerCellState.Confirmed => "bg-success",
        VolunteerCellState.Pending => "bg-success-subtle",
        VolunteerCellState.Gap => "bg-danger",
        VolunteerCellState.CampSetup => "bg-primary",
        VolunteerCellState.DayOff => "vt-dayoff",
        VolunteerCellState.Outside => "bg-secondary-subtle",
        VolunteerCellState.Expected => "bg-secondary-subtle",
        _ => "bg-light",
    };

    string CellAria(VolunteerCellState s) => s switch
    {
        VolunteerCellState.Confirmed => Localizer["VolTrack_State_Confirmed"].Value,
        VolunteerCellState.Pending => Localizer["VolTrack_State_Pending"].Value,
        VolunteerCellState.Gap => Localizer["VolTrack_State_Gap"].Value,
        VolunteerCellState.CampSetup => Localizer["VolTrack_State_CampSetup"].Value,
        VolunteerCellState.DayOff => Localizer["VolTrack_State_DayOff"].Value,
        VolunteerCellState.Outside => Localizer["VolTrack_State_Outside"].Value,
        VolunteerCellState.Expected => Localizer["VolTrack_State_Expected"].Value,
        _ => "",
    };
}

@* Heatmap CSS lives in the partial so the table renders correctly anywhere the
   partial is hosted (Volunteer Tracking dashboard AND profile build strip via
   VolunteerBuildStripViewComponent). Duplicating <style> tags across multiple
   partial renders on one page is harmless. *@
<style>
    /* Day-off cell: striped grey, signals "we know about this, intentionally
       not-here" without competing with the green/red/blue signals. */
    .vt-dayoff {
        background: #f8f9fa;
        background-image: repeating-linear-gradient(
            45deg,
            rgba(0, 0, 0, 0.18) 0,
            rgba(0, 0, 0, 0.18) 2px,
            transparent 2px,
            transparent 6px);
    }
    .vt-heatmap-table {
        table-layout: fixed;
        width: max-content;
        min-width: 100%;
    }
    .vt-heatmap-table th.vt-sticky-head,
    .vt-heatmap-table td.vt-sticky-cell {
        position: sticky;
        left: 0;
        z-index: 1;
        background: var(--bs-body-bg);
        min-width: 220px;
        width: 220px;
    }
    .vt-heatmap-table th.vt-sticky-head { z-index: 2; background: var(--bs-tertiary-bg); }
    .vt-heatmap-table td.vt-cell {
        min-width: 32px;
        width: 32px;
        height: 32px;
        padding: 0;
        text-align: center;
        cursor: pointer;
        border: 1px solid rgba(0, 0, 0, 0.05);
    }
    .vt-heatmap-table td.vt-cell button {
        width: 100%;
        height: 100%;
        border: 0;
        background: transparent;
        padding: 0;
    }
    @@media (max-width: 768px) {
        .vt-heatmap-table th.vt-sticky-head,
        .vt-heatmap-table td.vt-sticky-cell {
            min-width: 140px;
            width: 140px;
        }
        .vt-heatmap-table td.vt-cell {
            min-width: 28px;
            width: 28px;
            height: 28px;
        }
    }
</style>

<div class="card mb-3">
    <div class="card-header d-flex align-items-center">
        @if (Model.ShowAvailabilityControls)
        {
            <strong><i class="fa-solid fa-table-cells me-2"></i>@Localizer["Profile_BuildStrip_Title"]</strong>
        }
        else
        {
            <strong><i class="fa-solid fa-table-cells me-2"></i>@Localizer["VolTrack_Main_Title"]</strong>
            <span class="text-muted small ms-2">@string.Format(Localizer["VolTrack_Main_Subtitle"].Value, Model.Rows.Count)</span>
        }
        @* Scroll arrows: hidden until JS detects horizontal overflow. *@
        <div class="btn-group btn-group-sm ms-auto" role="group" aria-label="Heatmap horizontal scroll" data-vt-scroll-group hidden>
            <button type="button" class="btn btn-outline-secondary" data-vt-scroll="left" aria-label="@Localizer["VolTrack_Scroll_Left"]"><i class="fa-solid fa-chevron-left"></i></button>
            <button type="button" class="btn btn-outline-secondary" data-vt-scroll="right" aria-label="@Localizer["VolTrack_Scroll_Right"]"><i class="fa-solid fa-chevron-right"></i></button>
        </div>
    </div>
    <div class="table-responsive vt-heatmap-scroll">
        <table class="table table-sm table-bordered align-middle mb-0 vt-heatmap-table">
            <thead class="table-light">
                <tr>
                    <th class="vt-sticky-head">@Localizer["VolTrack_Col_Volunteer"]</th>
                    @foreach (var d in dayOffsets)
                    {
                        var date = Model.GateOpeningDate.PlusDays(d);
                        <th class="text-center" style="font-size: 0.7rem;">
                            <div>@date.Day</div>
                            <div class="text-muted">@date.ToMonthAbbrev()</div>
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Rows)
                {
                    // BurnerName-resolved name for tooltips/aria — resolved
                    // by the controller in a single batch (see
                    // VolunteerTrackingController.Index); the partial never
                    // makes per-row service calls. The <vc:human> below
                    // renders the avatar+name itself; this string is only
                    // for the row search/tooltip data attribute.
                    var displayName = Model.DisplayNameByUserId.GetValueOrDefault(row.UserId, "");
                    if (string.IsNullOrEmpty(displayName))
                    {
                        displayName = Localizer["VolTrack_UnknownUser"].Value;
                    }

                    // Build the day-off tooltip ("Wed 24 Jun — doctor; Fri 26 Jun") for the row badge.
                    var dayOffTooltip = string.Join("; ", row.DayOffs
                        .Select(d => Model.GateOpeningDate.PlusDays(d.DayOffset).ToDate()
                            + (string.IsNullOrWhiteSpace(d.Reason) ? "" : " — " + d.Reason)));
                    // Lookup map: cell DayOffset → reason (for popover render).
                    var reasonByDay = row.DayOffs.ToDictionary(d => d.DayOffset, d => d.Reason);
                    <tr data-vt-search-name="@displayName.ToLowerInvariant()">
                        <td class="vt-sticky-cell">
                            <vc:human user-id="@row.UserId" layout="AvatarName" size="32" />
                            <div class="small">
                                @if (row.GapCount > 0)
                                {
                                    <span class="badge bg-danger me-1">@string.Format(Localizer["VolTrack_GapBadge"].Value, row.GapCount)</span>
                                }
                                @if (row.DayOffs.Count > 0)
                                {
                                    <span class="badge bg-secondary-subtle border text-dark me-1" title="@dayOffTooltip">
                                        <i class="fa-solid fa-calendar-xmark me-1"></i>@string.Format(Localizer["VolTrack_DayOffBadge"].Value, row.DayOffs.Count)
                                    </span>
                                }
                                @if (row.BarrioSetupStartDate.HasValue)
                                {
                                    <span class="badge bg-primary" title="@Localizer["VolTrack_CampSetupTooltip"]">
                                        <i class="fa-solid fa-campground me-1"></i>@row.BarrioSetupStartDate.Value.ToDate()
                                    </span>
                                }
                            </div>
                        </td>
                        @foreach (var cell in row.Cells)
                        {
                            var date = Model.GateOpeningDate.PlusDays(cell.DayOffset);
                            var cellId = $"vt-pop-{row.UserId:N}-{cell.DayOffset}";
                            <td class="vt-cell @CellClass(cell.State)" aria-label="@CellAria(cell.State)">
                                <button type="button"
                                        data-vt-popover
                                        data-bs-toggle="popover"
                                        data-bs-trigger="manual"
                                        aria-describedby="@cellId"
                                        title="@displayName · @date.ToDate()"
                                        aria-label="@CellAria(cell.State)">
                                    <span class="visually-hidden">@CellAria(cell.State)</span>
                                </button>
                                <div class="vt-popover-content d-none">
                                    <div class="fw-semibold mb-1">@date.ToDate()</div>
                                    @if (cell.RotaNames.Count > 0)
                                    {
                                        <div class="mb-2">
                                            <div class="text-muted small text-uppercase">@Localizer["VolTrack_Popover_Rotas"]</div>
                                            <ul class="mb-1 ps-3 small">
                                                @foreach (var rotaName in cell.RotaNames)
                                                {
                                                    <li>@rotaName</li>
                                                }
                                            </ul>
                                        </div>
                                    }
                                    <div class="small text-muted mb-2">
                                        <span class="badge @CellClass(cell.State)">@CellAria(cell.State)</span>
                                    </div>
                                    <a href="/Shifts/Dashboard?startDate=@date.ToInvariantDate()&endDate=@date.ToInvariantDate()#urgencyAccordion"
                                       target="_blank" rel="noopener"
                                       class="btn btn-sm btn-outline-success w-100 mb-2">
                                        <i class="fa-solid fa-up-right-from-square me-1"></i>@Localizer["VolTrack_Popover_OpenDashboard"]
                                    </a>
                                    @if (canWrite)
                                    {
                                        <hr class="my-2" />
                                        @* State-driven: Mark / Move / Clear camp set-up. *@
                                        @if (cell.State != VolunteerCellState.CampSetup)
                                        {
                                            <form method="post" asp-controller="VolunteerTracking" asp-action="SetCampSetup" class="mb-2">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="UserId" value="@row.UserId" />
                                                <input type="hidden" name="Date" value="@date.ToInvariantDate()" />
                                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                <button type="submit" class="btn btn-sm btn-primary w-100">
                                                    <i class="fa-solid fa-campground me-1"></i>@Localizer["VolTrack_Popover_MarkCampSetup"]
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            var setupOffset = row.BarrioSetupStartDate is { } setupDate
                                                ? Period.Between(Model.GateOpeningDate, setupDate, PeriodUnits.Days).Days
                                                : (int?)null;
                                            if (setupOffset.HasValue && cell.DayOffset != setupOffset.Value)
                                            {
                                                <form method="post" asp-controller="VolunteerTracking" asp-action="SetCampSetup" class="mb-2">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="UserId" value="@row.UserId" />
                                                    <input type="hidden" name="Date" value="@date.ToInvariantDate()" />
                                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                    <button type="submit" class="btn btn-sm btn-outline-primary w-100">
                                                        <i class="fa-solid fa-arrows-left-right me-1"></i>@Localizer["VolTrack_Popover_MoveCampSetup"]
                                                    </button>
                                                </form>
                                            }
                                            <form method="post" asp-controller="VolunteerTracking" asp-action="ClearCampSetup" class="mb-2">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@row.UserId" />
                                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                <button type="submit" class="btn btn-sm btn-outline-warning w-100">
                                                    <i class="fa-solid fa-rotate-left me-1"></i>@Localizer["VolTrack_Popover_ClearCampSetup"]
                                                </button>
                                            </form>
                                        }

                                        @* Day-off section: state-driven render. CampSetup cells render nothing. *@
                                        @if (cell.State == VolunteerCellState.DayOff)
                                        {
                                            var existingReason = reasonByDay.TryGetValue(cell.DayOffset, out var r) ? r : null;
                                            <div class="small text-muted mb-2">
                                                @if (!string.IsNullOrWhiteSpace(existingReason))
                                                {
                                                    <em>@existingReason</em>
                                                }
                                                else
                                                {
                                                    <em class="opacity-75">— @Localizer["VolTrack_State_DayOff"]</em>
                                                }
                                            </div>
                                            <form method="post" asp-controller="VolunteerTracking" asp-action="ClearDayOff">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="UserId" value="@row.UserId" />
                                                <input type="hidden" name="DayOffset" value="@cell.DayOffset" />
                                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                <button type="submit" class="btn btn-sm btn-outline-warning w-100">
                                                    <i class="fa-solid fa-rotate-left me-1"></i>@Localizer["VolTrack_Popover_CancelDayOff"]
                                                </button>
                                            </form>
                                        }
                                        else if (cell.State == VolunteerCellState.Confirmed || cell.State == VolunteerCellState.Pending)
                                        {
                                            <div class="small text-muted">
                                                <i class="fa-solid fa-circle-info me-1"></i>@Localizer["VolTrack_Popover_DayOffBlockedBySignups"]
                                            </div>
                                        }
                                        else if (cell.State == VolunteerCellState.Gap)
                                        {
                                            <form method="post" asp-controller="VolunteerTracking" asp-action="SetDayOff">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="UserId" value="@row.UserId" />
                                                <input type="hidden" name="DayOffset" value="@cell.DayOffset" />
                                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                <input type="text" name="Reason" maxlength="200"
                                                       class="form-control form-control-sm mb-2"
                                                       placeholder="@Localizer["VolTrack_Popover_ReasonLabel"]" />
                                                <button type="submit" class="btn btn-sm btn-outline-secondary w-100">
                                                    <i class="fa-solid fa-calendar-xmark me-1"></i>@Localizer["VolTrack_Popover_MarkDayOff"]
                                                </button>
                                            </form>
                                        }
                                        @if (Model.ShowAvailabilityControls
                                             && cell.State != VolunteerCellState.CampSetup
                                             && cell.State != VolunteerCellState.Confirmed
                                             && cell.State != VolunteerCellState.Pending)
                                        {
                                            <hr class="my-2" />
                                            <div class="small text-muted mb-1">@Localizer["Profile_BuildStrip_Title"]</div>
                                            @if (cell.DeclaredAvailable)
                                            {
                                                <form method="post" asp-controller="VolunteerTracking" asp-action="ClearAvailabilityDay">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="userId" value="@row.UserId" />
                                                    <input type="hidden" name="dayOffset" value="@cell.DayOffset" />
                                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                                                        <i class="fa-solid fa-minus me-1"></i>@Localizer["VolTrack_Popover_UnmarkAvailable"]
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form method="post" asp-controller="VolunteerTracking" asp-action="SetAvailabilityDay">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="userId" value="@row.UserId" />
                                                    <input type="hidden" name="dayOffset" value="@cell.DayOffset" />
                                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                    <button type="submit" class="btn btn-sm btn-outline-success w-100">
                                                        <i class="fa-solid fa-plus me-1"></i>@Localizer["VolTrack_Popover_MarkAvailable"]
                                                    </button>
                                                </form>
                                            }
                                        }
                                    }
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* Scroll-arrow + Bootstrap-popover wiring. Lives in the partial so it travels
   with the view wherever it renders (Volunteer Tracking dashboard AND profile
   build strip). DOMContentLoaded gate ensures wiring runs after sibling
   partials (e.g. _VolunteerUnbookedHeatmap on the dashboard) are in the DOM.
   Per-element guards (data-vt-wired / Popover.getInstance) make it safe if the
   partial ever renders multiple times. *@
<script>
(function () {
    function initScrollArrows() {
        var STEP = 220;
        function syncGroup(scroller, group) {
            if (!scroller || !group) return;
            var hasOverflow = scroller.scrollWidth > scroller.clientWidth + 1;
            group.hidden = !hasOverflow;
            if (!hasOverflow) return;
            var atStart = scroller.scrollLeft <= 0;
            var atEnd = scroller.scrollLeft >= scroller.scrollWidth - scroller.clientWidth - 1;
            var leftBtn = group.querySelector('[data-vt-scroll="left"]');
            var rightBtn = group.querySelector('[data-vt-scroll="right"]');
            if (leftBtn) leftBtn.disabled = atStart;
            if (rightBtn) rightBtn.disabled = atEnd;
        }
        document.querySelectorAll('[data-vt-scroll-group]').forEach(function (group) {
            if (group.dataset.vtWired === '1') return;
            group.dataset.vtWired = '1';
            var card = group.closest('.card');
            var scroller = card && card.querySelector('.vt-heatmap-scroll');
            if (!scroller) return;
            group.querySelectorAll('[data-vt-scroll]').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var dir = btn.getAttribute('data-vt-scroll') === 'left' ? -1 : 1;
                    scroller.scrollBy({ left: dir * STEP, behavior: 'smooth' });
                });
            });
            scroller.addEventListener('scroll', function () { syncGroup(scroller, group); });
            window.addEventListener('resize', function () { syncGroup(scroller, group); });
            requestAnimationFrame(function () { syncGroup(scroller, group); });
        });
    }

    function initPopovers() {
        if (typeof bootstrap === 'undefined' || !bootstrap.Popover) return;
        document.querySelectorAll('[data-vt-popover]').forEach(function (el) {
            if (bootstrap.Popover.getInstance(el)) return;
            var contentEl = el.parentElement && el.parentElement.querySelector('.vt-popover-content');
            var html = contentEl ? contentEl.innerHTML : '';
            new bootstrap.Popover(el, {
                trigger: 'click',
                placement: 'auto',
                html: true,
                sanitize: false,
                content: html
            });
        });
        if (window.__vtPopoverDismissWired) return;
        window.__vtPopoverDismissWired = true;
        document.addEventListener('click', function (e) {
            document.querySelectorAll('[data-vt-popover]').forEach(function (el) {
                if (el === e.target || el.contains(e.target)) return;
                var pop = bootstrap.Popover.getInstance(el);
                if (!pop) return;
                var tipId = el.getAttribute('aria-describedby');
                if (tipId && document.getElementById(tipId) && document.getElementById(tipId).contains(e.target)) return;
                pop.hide();
            });
        });
    }

    function init() { initScrollArrows(); initPopovers(); }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>
