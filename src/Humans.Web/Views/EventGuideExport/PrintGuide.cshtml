@using Humans.Web.Controllers
@model EventGuideExportController.PrintGuideViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@Model.EventName — Print Guide</title>
    <style>
        body { font-family: 'Source Sans 3', 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; color: #333; max-width: 800px; margin: 0 auto; padding: 20px; }
        h1 { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 28px; text-align: center; margin-bottom: 5px; }
        .subtitle { text-align: center; color: #666; font-size: 12px; margin-bottom: 30px; }
        h2 { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 20px; border-bottom: 2px solid #8b6914; padding-bottom: 5px; margin-top: 30px; }
        .event { margin-bottom: 16px; padding-left: 10px; border-left: 3px solid #c9a96e; }
        .event-title { font-weight: 700; font-size: 14px; }
        .event-meta { font-size: 12px; color: #555; margin-top: 2px; }
        .event-desc { font-size: 12px; color: #444; margin-top: 4px; }
        @@media print {
            body { padding: 0; }
            .no-print { display: none; }
        }
    </style>
</head>
<body>
    <div class="no-print" style="text-align: center; margin-bottom: 20px; padding: 10px; background: #f8f9fa; border-radius: 5px;">
        <button onclick="window.print()" style="padding: 8px 24px; font-size: 14px; cursor: pointer;">Print / Save as PDF</button>
    </div>

    <h1>@Model.EventName</h1>
    @if (Model.TimeZoneId != null)
    {
        <div class="subtitle">All times in @Model.TimeZoneId</div>
    }

    @if (Model.DayGroups.Count == 0)
    {
        <p>No approved events to display.</p>
    }

    @foreach (var day in Model.DayGroups)
    {
        <h2>@day.DayLabel</h2>
        @foreach (var entry in day.Entries)
        {
            var hours = entry.DurationMinutes / 60;
            var mins = entry.DurationMinutes % 60;
            var durationStr = hours > 0
                ? (mins > 0 ? $"{hours}h {mins}min" : $"{hours}h")
                : $"{mins}min";

            <div class="event">
                <div class="event-title">@entry.Title</div>
                <div class="event-meta">
                    @entry.StartAt.ToString("HH:mm") — @durationStr
                    &middot; @entry.CampOrVenueName
                    @if (!string.IsNullOrEmpty(entry.LocationNote))
                    {
                        <text> &middot; @entry.LocationNote</text>
                    }
                    &middot; <em>@entry.CategoryName</em>
                </div>
                <div class="event-desc">@entry.Description</div>
            </div>
        }
    }
</body>
</html>
