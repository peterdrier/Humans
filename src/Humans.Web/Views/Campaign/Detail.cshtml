@model Humans.Web.Models.CampaignDetailViewModel
@using Humans.Domain.Constants
@{
    ViewData["Title"] = Model.Campaign.Title;
    var totalCodes = Model.Stats.TotalCodes;
    var availableCodes = Model.Stats.AvailableCodes;
    var sentCount = Model.Stats.SentCount;
    var failedCount = Model.Stats.FailedCount;
    var codesRedeemed = Model.Stats.CodesRedeemed;
    var totalGrants = Model.Stats.TotalGrants;
    var redemptionPct = totalGrants > 0 ? (int)Math.Round(100.0 * codesRedeemed / totalGrants) : 0;
    var statusClass = Model.Campaign.Status switch
    {
        CampaignStatus.Draft => "bg-secondary",
        CampaignStatus.Active => "bg-success",
        CampaignStatus.Completed => "bg-info",
        _ => "bg-secondary"
    };
    var isAdmin = Humans.Web.Authorization.ViewPolicies.Evaluate(Humans.Web.Authorization.ViewPolicies.Admin, User);
    var canGenerateCodes = Humans.Web.Authorization.ViewPolicies.Evaluate(Humans.Web.Authorization.ViewPolicies.CanManageTickets, User);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>@Model.Campaign.Title <span class="badge @statusClass fs-6">@Model.Campaign.Status</span></h1>
        @if (!string.IsNullOrWhiteSpace(Model.Campaign.Description))
        {
            <p class="text-muted mb-0">@Model.Campaign.Description</p>
        }
    </div>
    <div class="d-flex gap-2">
        @if (isAdmin)
        {
            <a asp-action="Edit" asp-route-id="@Model.Campaign.Id" class="btn btn-outline-primary btn-sm">
                <i class="fa-solid fa-pen me-1"></i>Edit <i class="fa-solid fa-lock auth-lock-icon"></i>
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">Back to Campaigns</a>
        }
        else
        {
            <a asp-controller="Ticket" asp-action="Codes" class="btn btn-outline-secondary">Back to Code Tracking</a>
        }
    </div>
</div>

<vc:temp-data-alerts />

@* Action buttons *@
<div class="d-flex flex-wrap gap-2 mb-4">
    @if (isAdmin && Model.Campaign.Status == CampaignStatus.Active)
    {
        <a asp-action="SendWave" asp-route-id="@Model.Campaign.Id" class="btn btn-primary">
            <i class="fa-solid fa-paper-plane me-1"></i>Send Wave
        </a>
    }

    @if (isAdmin && (Model.Campaign.Status == CampaignStatus.Draft || Model.Campaign.Status == CampaignStatus.Active))
    {
        <form asp-action="ImportCodes" asp-route-id="@Model.Campaign.Id" method="post" enctype="multipart/form-data" class="d-inline-flex align-items-center gap-2">
            @Html.AntiForgeryToken()
            <input type="file" name="file" accept=".csv,.txt" class="form-control form-control-sm" style="max-width: 250px;" required />
            <button type="submit" class="btn btn-outline-primary btn-sm">
                <i class="fa-solid fa-file-import me-1"></i>Import Codes
            </button>
        </form>
    }

    @if (canGenerateCodes && Model.Campaign.Status == CampaignStatus.Draft)
    {
        <form asp-action="GenerateCodes" asp-route-id="@Model.Campaign.Id" method="post" class="d-inline-flex align-items-center gap-2">
            @Html.AntiForgeryToken()
            <input type="number" name="count" min="1" placeholder="Count" class="form-control form-control-sm" style="max-width: 90px;" required />
            <select name="discountType" class="form-select form-select-sm" style="max-width: 140px;" required>
                <option value="Percentage">Percentage</option>
                <option value="Fixed">Fixed</option>
            </select>
            <input type="number" name="discountValue" min="0" step="0.01" placeholder="Value" class="form-control form-control-sm" style="max-width: 100px;" required />
            <button type="submit" class="btn btn-outline-success btn-sm">
                <i class="fa-solid fa-wand-magic-sparkles me-1"></i>Generate Codes <i class="fa-solid fa-lock auth-lock-icon"></i>
            </button>
        </form>

        @if (isAdmin)
        {
            <form asp-action="Activate" asp-route-id="@Model.Campaign.Id" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-success btn-sm">
                    <i class="fa-solid fa-check me-1"></i>Activate
                </button>
            </form>
        }
    }

    @if (isAdmin && Model.Campaign.Status == CampaignStatus.Active)
    {
        <form asp-action="Complete" asp-route-id="@Model.Campaign.Id" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-info btn-sm">
                <i class="fa-solid fa-flag-checkered me-1"></i>Complete
            </button>
        </form>
    }

    @if (isAdmin && failedCount > 0)
    {
        <form asp-action="RetryAllFailed" asp-route-id="@Model.Campaign.Id" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-warning btn-sm">
                <i class="fa-solid fa-rotate-right me-1"></i>Retry All Failed
            </button>
        </form>
    }
</div>

@* Stats cards *@
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h3 class="mb-0">@totalCodes</h3>
                <small class="text-muted">Codes Imported</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h3 class="mb-0">@availableCodes</h3>
                <small class="text-muted">Available</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h3 class="mb-0 text-success">@sentCount</h3>
                <small class="text-muted">Sent</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h3 class="mb-0 @(failedCount > 0 ? "text-danger" : "")">@failedCount</h3>
                <small class="text-muted">Failed</small>
            </div>
        </div>
    </div>
</div>

@* Redemption stats *@
@if (totalGrants > 0)
{
    <div class="alert alert-info mb-4">
        <i class="fa-solid fa-ticket me-1"></i>
        <strong>@codesRedeemed</strong> of <strong>@totalGrants</strong> codes redeemed (@redemptionPct%)
    </div>
}

@* Grants table *@
<div class="card">
    <div class="card-header">Grants</div>
    <div class="card-body p-0">
        @if (Model.Campaign.Grants.Count == 0)
        {
            <p class="text-muted text-center py-4 mb-0">No grants yet. Use Send Wave to distribute codes.</p>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Human</th>
                        <th>Email</th>
                        <th>Code</th>
                        <th>Assigned</th>
                        <th>Redeemed</th>
                        <th>Email Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var grant in Model.Campaign.Grants.OrderByDescending(g => g.AssignedAt))
                    {
                        var emailStatusClass = grant.LatestEmailStatus switch
                        {
                            EmailOutboxStatus.Queued => "bg-warning",
                            EmailOutboxStatus.Sent => "bg-success",
                            EmailOutboxStatus.Failed => "bg-danger",
                            _ => "bg-secondary"
                        };
                        <tr>
                            <td>@grant.User.DisplayName</td>
                            <td class="text-muted small">@grant.User.Email</td>
                            <td><code>@grant.Code.Code</code></td>
                            <td>@grant.AssignedAt.ToDisplayDateTime()</td>
                            <td>
                                @if (grant.RedeemedAt.HasValue)
                                {
                                    <span class="text-success">@grant.RedeemedAt.Value.ToDisplayDate()</span>
                                }
                                else
                                {
                                    <span class="text-muted">&mdash;</span>
                                }
                            </td>
                            <td>
                                @if (grant.LatestEmailStatus.HasValue)
                                {
                                    <span class="badge @emailStatusClass">@grant.LatestEmailStatus</span>
                                    @if (grant.LatestEmailAt.HasValue)
                                    {
                                        <small class="text-muted ms-1">@grant.LatestEmailAt.Value.ToDisplayDateTime()</small>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-end">
                                <form asp-action="Resend" asp-route-grantId="@grant.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-secondary btn-sm">
                                        <i class="fa-solid fa-rotate-right me-1"></i>Resend
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
