@model IReadOnlyList<Humans.Application.DTOs.CampaignListSummary>
@{
    ViewData["Title"] = "Campaigns";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index">Admin Tools</a></li>
        <li class="breadcrumb-item active" aria-current="page">Campaigns</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Campaigns</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fa-solid fa-plus me-1"></i>New Campaign
    </a>
</div>


<div class="card">
    <div class="card-body p-0">
        @if (Model.Count == 0)
        {
            <p class="text-muted text-center py-4 mb-0">No campaigns yet.</p>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Status</th>
                        <th>Codes</th>
                        <th>Sent</th>
                        <th>Failed</th>
                        <th>Created</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var campaign in Model)
                    {
                        var statusClass = campaign.Status switch
                        {
                            CampaignStatus.Draft => "bg-secondary",
                            CampaignStatus.Active => "bg-success",
                            CampaignStatus.Completed => "bg-info",
                            _ => "bg-secondary"
                        };
                        <tr>
                            <td>
                                <a asp-action="Detail" asp-route-id="@campaign.Id">@campaign.Title</a>
                            </td>
                            <td><span class="badge @statusClass">@campaign.Status</span></td>
                            <td>@campaign.AssignedCodes / @campaign.TotalCodes</td>
                            <td>@campaign.SentCount</td>
                            <td>
                                @if (campaign.FailedCount > 0)
                                {
                                    <span class="text-danger">@campaign.FailedCount</span>
                                }
                                else
                                {
                                    @campaign.FailedCount
                                }
                            </td>
                            <td>@campaign.CreatedAt.ToDate()</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
