@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@model IReadOnlyList<Humans.Application.DTOs.CampaignListSummary>
@{
    ViewData["Title"] = "Campaigns";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index">Admin Tools</a></li>
        <li class="breadcrumb-item active" aria-current="page">Campaigns</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Campaigns</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fa-solid fa-plus me-1"></i>New Campaign
    </a>
</div>


<div class="card">
    <div class="card-body p-0">
        @if (Model.Count == 0)
        {
            <p class="text-muted text-center py-4 mb-0">No campaigns yet.</p>
        }
        else
        {
            Func<Humans.Application.DTOs.CampaignListSummary, IHtmlContent> titleCell =
                @<text><a asp-action="Detail" asp-route-id="@item.Id">@item.Title</a></text>;
            Func<Humans.Application.DTOs.CampaignListSummary, IHtmlContent> failedCell = @<text>
                @if (item.FailedCount > 0)
                {
                    <span class="text-danger">@item.FailedCount</span>
                }
                else
                {
                    @item.FailedCount
                }
            </text>;
            var table = TableModel.For(Model)
                .Template("Title", titleCell)
                .Column("Status", r => r.Status, c => c.EnumBadge())
                .Column("Codes", r => $"{r.AssignedCodes} / {r.TotalCodes}")
                .Column("Sent", r => r.SentCount)
                .Template("Failed", failedCell)
                .Column("Created", r => r.CreatedAt, c => c.Date())
                .Build();
            <partial name="_Table" model="table" />
        }
    </div>
</div>
