@{
    ViewData["Title"] = "Gate List";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mt-4 mb-3">
        <h1>Gate List</h1>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fa-solid fa-arrow-left"></i> Dashboard</a>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="text-center py-5">
                <i class="fa-solid fa-door-open fa-3x text-muted mb-3"></i>
                <h4>Gate list functionality coming in June</h4>
                <p class="text-muted">
                    For now, use the <a asp-action="Attendees">Attendees page</a> to view ticket holders,
                    or <a asp-action="ExportAttendees">export a CSV</a> for offline use.
                </p>
            </div>
        </div>
    </div>
</div>
