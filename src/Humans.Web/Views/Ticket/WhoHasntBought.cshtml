@model Humans.Web.Models.WhoHasntBoughtViewModel
@{
    ViewData["Title"] = "Who Hasn't Bought?";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Who Hasn't Bought?</h1>
    <partial name="_TicketNav" />

    <p class="text-muted">Active humans without a matched ticket purchase.</p>

    <!-- Search & Filters -->
    <form method="get" class="row g-2 mb-3">
        <div class="col-md-3">
            <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search name or email..." />
        </div>
        <div class="col-md-2">
            <select name="filterTeam" class="form-select">
                <option value="">All Teams</option>
                @foreach (var team in Model.AvailableTeams)
                {
                    <option value="@team" selected="@(Model.FilterTeam == team)">@team</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="filterTier" class="form-select">
                <option value="">All Tiers</option>
                <option value="Volunteer" selected="@(Model.FilterTier == "Volunteer")">Volunteer</option>
                <option value="Colaborador" selected="@(Model.FilterTier == "Colaborador")">Colaborador</option>
                <option value="Asociado" selected="@(Model.FilterTier == "Asociado")">Asociado</option>
            </select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-search"></i> Filter</button>
        </div>
        <input type="hidden" name="pageSize" value="@Model.PageSize" />
    </form>

    <p class="text-muted">@Model.TotalCount humans haven't bought tickets</p>

    <div class="table-responsive">
        <table class="table table-sm table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Teams</th>
                    <th>Tier</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var h in Model.Humans)
                {
                    <tr>
                        <td>
                            <a asp-controller="Human" asp-action="HumanDetail" asp-route-id="@h.UserId">@h.Name</a>
                        </td>
                        <td><small>@h.Email</small></td>
                        <td><small>@h.Teams</small></td>
                        <td><span class="badge bg-secondary">@h.Tier</span></td>
                    </tr>
                }
                @if (Model.Humans.Count == 0)
                {
                    <tr><td colspan="4" class="text-muted text-center">Everyone has bought tickets!</td></tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav>
            <ul class="pagination">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="WhoHasntBought" asp-route-page="@(Model.Page - 1)" asp-route-search="@Model.Search" asp-route-filterTeam="@Model.FilterTeam" asp-route-filterTier="@Model.FilterTier" asp-route-pageSize="@Model.PageSize">Previous</a>
                </li>
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="WhoHasntBought" asp-route-page="@i" asp-route-search="@Model.Search" asp-route-filterTeam="@Model.FilterTeam" asp-route-filterTier="@Model.FilterTier" asp-route-pageSize="@Model.PageSize">@i</a>
                    </li>
                }
                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="WhoHasntBought" asp-route-page="@(Model.Page + 1)" asp-route-search="@Model.Search" asp-route-filterTeam="@Model.FilterTeam" asp-route-filterTier="@Model.FilterTier" asp-route-pageSize="@Model.PageSize">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>
