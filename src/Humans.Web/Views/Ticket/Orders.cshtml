@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@model Humans.Web.Models.TicketOrdersViewModel
@{
    ViewData["Title"] = "Ticket Orders";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Ticket Orders</h1>
    <partial name="_TicketNav" />

    <p class="text-muted">@Model.TotalCount orders found</p>

    @{
        Func<TicketOrderRow, IHtmlContent> orderIdCell =
            @<text><small><code>@item.VendorOrderId</code></small></text>;
        Func<TicketOrderRow, IHtmlContent> dateCell =
            @<text>@item.PurchasedAt.ToWeekdayDayMonth()</text>;
        Func<TicketOrderRow, IHtmlContent> attendeesCell =
            @<text><a asp-action="Attendees" asp-route-filterOrderId="@item.VendorOrderId">@item.AttendeeCount</a></text>;
        Func<TicketOrderRow, IHtmlContent> emailCell =
            @<text><small>@item.BuyerEmail</small></text>;
        Func<TicketOrderRow, IHtmlContent> discountCell = @<text>
            @if (item.DiscountAmount.HasValue)
            {
                <span title="@(item.DiscountCode ?? "")">-@item.DiscountAmount.Value.ToString("N2", System.Globalization.CultureInfo.CurrentCulture)</span>
            }
            else
            {
                <span class="text-muted">&mdash;</span>
            }
        </text>;
        Func<TicketOrderRow, IHtmlContent> donationCell = @<text>
            @if (item.DonationAmount > 0)
            {
                <span>@item.DonationAmount.ToString("N2", System.Globalization.CultureInfo.CurrentCulture)</span>
            }
            else
            {
                <span class="text-muted">&mdash;</span>
            }
        </text>;
        Func<TicketOrderRow, IHtmlContent> vatCell = @<text>
            @if (item.VatAmount > 0)
            {
                <span>@item.VatAmount.ToString("N2", System.Globalization.CultureInfo.CurrentCulture)</span>
            }
            else
            {
                <span class="text-muted">&mdash;</span>
            }
        </text>;
        Func<TicketOrderRow, IHtmlContent> methodCell = @<text>
            @if (item.PaymentMethod != null)
            {
                <small>@(item.PaymentMethodDetail != null ? $"{item.PaymentMethod}/{item.PaymentMethodDetail}" : item.PaymentMethod)</small>
            }
            else
            {
                <span class="text-muted">&mdash;</span>
            }
        </text>;
        Func<TicketOrderRow, IHtmlContent> stripeFeeCell = @<text>
            @if (item.StripeFee.HasValue)
            {
                @item.StripeFee.Value.ToString("N2", System.Globalization.CultureInfo.CurrentCulture)
            }
            else
            {
                <span class="text-muted">&mdash;</span>
            }
        </text>;
        Func<TicketOrderRow, IHtmlContent> ttFeeCell = @<text>
            @if (item.ApplicationFee.HasValue)
            {
                @item.ApplicationFee.Value.ToString("N2", System.Globalization.CultureInfo.CurrentCulture)
            }
            else
            {
                <span class="text-muted">&mdash;</span>
            }
        </text>;
        Func<TicketOrderRow, IHtmlContent> matchedCell = @<text>
            @if (item.MatchedUserId.HasValue)
            {
                <vc:human user-id="@item.MatchedUserId.Value" link="Admin" />
            }
            else
            {
                <span class="badge bg-secondary"><i class="fa-solid fa-xmark"></i></span>
            }
        </text>;
        Func<object?, IHtmlContent> extraFilters = @<text>
            <div class="col-md-2">
                <select name="filterMatched" class="form-select js-auto-submit" aria-label="Filter by matched">
                    <option value="">All</option>
                    <option value="true" selected="@(Model.FilterMatched == true ? "selected" : null)">Matched</option>
                    <option value="false" selected="@(Model.FilterMatched == false ? "selected" : null)">Unmatched</option>
                </select>
            </div>
            <div class="col-md-2">
                <select name="pageSize" class="form-select js-auto-submit" aria-label="Page size">
                    <option value="25" selected="@(Model.PageSize == 25 ? "selected" : null)">25 per page</option>
                    <option value="50" selected="@(Model.PageSize == 50 ? "selected" : null)">50 per page</option>
                    <option value="100" selected="@(Model.PageSize == 100 ? "selected" : null)">100 per page</option>
                </select>
            </div>
        </text>;
        var table = TableModel.For(Model.Orders.ToList())
            .Template("Order ID", orderIdCell)
            .Template("Date", dateCell, c => c.Sort("date", descendingFirst: true))
            .Column("Purchaser", o => o.BuyerName, c => c.Sort("name"))
            .Template("Email", emailCell)
            .Template("Tickets", attendeesCell, c => c.Sort("tickets", descendingFirst: true))
            .Column("Amount (€)", o => o.TotalAmount, c => c.Currency().Sort("amount", descendingFirst: true).End())
            .Template("Discount", discountCell)
            .Template("Donation", donationCell)
            .Template("VAT", vatCell)
            .Template("Method", methodCell)
            .Template("Stripe Fee", stripeFeeCell)
            .Template("TT Fee", ttFeeCell)
            .Column("Status", o => o.PaymentStatus, c => c.EnumBadge()
                .SelectFilter(["Paid", "Pending", "Refunded", "Cancelled"], "filterPaymentStatus", Model.FilterPaymentStatus))
            .Template("Matched", matchedCell)
            .SearchBox("search", Model.Search, "Search name, email, or code...")
            .ServerMode(Model.SortBy, Model.SortDesc, new PagerViewModel(Model.TotalPages, Model.Page, "Orders"))
            .HiddenField("filterTicketType", Model.FilterTicketType)
            .ExtraFilters(extraFilters)
            .Empty("No orders found")
            .Build();
    }
    <partial name="_Table" model="table" />
</div>
