@model Humans.Web.Models.TicketOrdersViewModel
@{
    ViewData["Title"] = "Ticket Orders";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Ticket Orders</h1>
    <partial name="_TicketNav" />

    <!-- Search & Filters -->
    <form method="get" class="row g-2 mb-3">
        <div class="col-md-3">
            <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search name, email, or code..." />
        </div>
        <div class="col-md-2">
            <select name="filterPaymentStatus" class="form-select">
                <option value="">All Statuses</option>
                <option value="Paid" selected="@(Model.FilterPaymentStatus == "Paid")">Paid</option>
                <option value="Pending" selected="@(Model.FilterPaymentStatus == "Pending")">Pending</option>
                <option value="Refunded" selected="@(Model.FilterPaymentStatus == "Refunded")">Refunded</option>
            </select>
        </div>
        <div class="col-md-2">
            <select name="filterMatched" class="form-select">
                <option value="">All</option>
                <option value="true" selected="@(Model.FilterMatched == true)">Matched</option>
                <option value="false" selected="@(Model.FilterMatched == false)">Unmatched</option>
            </select>
        </div>
        <div class="col-md-2">
            <select name="pageSize" class="form-select">
                <option value="25" selected="@(Model.PageSize == 25)">25 per page</option>
                <option value="50" selected="@(Model.PageSize == 50)">50 per page</option>
                <option value="100" selected="@(Model.PageSize == 100)">100 per page</option>
            </select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-search"></i> Filter</button>
        </div>
        <input type="hidden" name="sortBy" value="@Model.SortBy" />
        <input type="hidden" name="sortDesc" value="@Model.SortDesc" />
    </form>

    <p class="text-muted">@Model.TotalCount orders found</p>

    <div class="table-responsive">
        <table class="table table-sm table-hover">
            <thead>
                <tr>
                    <th>Order ID</th>
                    <th><a asp-action="Orders" asp-route-sortBy="date" asp-route-sortDesc="@(Model.SortBy == "date" ? (!Model.SortDesc).ToString() : "true")" asp-route-search="@Model.Search" asp-route-pageSize="@Model.PageSize">Date</a></th>
                    <th><a asp-action="Orders" asp-route-sortBy="name" asp-route-sortDesc="@(Model.SortBy == "name" ? (!Model.SortDesc).ToString() : "false")" asp-route-search="@Model.Search" asp-route-pageSize="@Model.PageSize">Purchaser</a></th>
                    <th>Email</th>
                    <th><a asp-action="Orders" asp-route-sortBy="tickets" asp-route-sortDesc="@(Model.SortBy == "tickets" ? (!Model.SortDesc).ToString() : "true")" asp-route-search="@Model.Search" asp-route-pageSize="@Model.PageSize">Tickets</a></th>
                    <th><a asp-action="Orders" asp-route-sortBy="amount" asp-route-sortDesc="@(Model.SortBy == "amount" ? (!Model.SortDesc).ToString() : "true")" asp-route-search="@Model.Search" asp-route-pageSize="@Model.PageSize">Amount</a></th>
                    <th>Code</th>
                    <th>Status</th>
                    <th>Matched</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model.Orders)
                {
                    <tr>
                        <td><small><code>@order.VendorOrderId</code></small></td>
                        <td>@order.PurchasedAt.ToDisplayDate()</td>
                        <td>@order.BuyerName</td>
                        <td><small>@order.BuyerEmail</small></td>
                        <td><a asp-action="Attendees" asp-route-filterOrderId="@order.VendorOrderId">@order.AttendeeCount</a></td>
                        <td>@order.Currency @order.TotalAmount.ToString("N2")</td>
                        <td>@(order.DiscountCode ?? "\u2014")</td>
                        <td>
                            @{
                                var statusClass = order.PaymentStatus switch
                                {
                                    Humans.Domain.Enums.TicketPaymentStatus.Paid => "bg-success",
                                    Humans.Domain.Enums.TicketPaymentStatus.Pending => "bg-warning text-dark",
                                    Humans.Domain.Enums.TicketPaymentStatus.Refunded => "bg-danger",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @statusClass">@order.PaymentStatus</span>
                        </td>
                        <td>
                            @if (order.MatchedUserId.HasValue)
                            {
                                <a asp-controller="Human" asp-action="HumanDetail" asp-route-id="@order.MatchedUserId">
                                    <span class="badge bg-success"><i class="fa-solid fa-check"></i></span> @order.MatchedUserName
                                </a>
                            }
                            else
                            {
                                <span class="badge bg-secondary"><i class="fa-solid fa-xmark"></i></span>
                            }
                        </td>
                    </tr>
                }
                @if (Model.Orders.Count == 0)
                {
                    <tr><td colspan="9" class="text-muted text-center">No orders found</td></tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav>
            <ul class="pagination">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Orders" asp-route-page="@(Model.Page - 1)" asp-route-search="@Model.Search" asp-route-sortBy="@Model.SortBy" asp-route-sortDesc="@Model.SortDesc" asp-route-pageSize="@Model.PageSize" asp-route-filterPaymentStatus="@Model.FilterPaymentStatus" asp-route-filterMatched="@Model.FilterMatched">Previous</a>
                </li>
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="Orders" asp-route-page="@i" asp-route-search="@Model.Search" asp-route-sortBy="@Model.SortBy" asp-route-sortDesc="@Model.SortDesc" asp-route-pageSize="@Model.PageSize" asp-route-filterPaymentStatus="@Model.FilterPaymentStatus" asp-route-filterMatched="@Model.FilterMatched">@i</a>
                    </li>
                }
                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Orders" asp-route-page="@(Model.Page + 1)" asp-route-search="@Model.Search" asp-route-sortBy="@Model.SortBy" asp-route-sortDesc="@Model.SortDesc" asp-route-pageSize="@Model.PageSize" asp-route-filterPaymentStatus="@Model.FilterPaymentStatus" asp-route-filterMatched="@Model.FilterMatched">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>
