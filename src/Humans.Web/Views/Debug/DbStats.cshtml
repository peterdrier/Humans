@using Humans.Web.Models.Tables
@model DbStatsViewModel
@{
    ViewData["Title"] = "Database Query Statistics";
}

<div class="page-head">
    <div>
        <h1 class="title">Database Query Statistics</h1>
        <p class="sub">@Model.TotalQueryCount.ToString("N0") total queries since last restart</p>
    </div>
    <div class="d-flex align-items-center gap-3">
        <form asp-action="ResetDbStats" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-warning btn-sm"
                    data-confirm="Reset all query statistics?">
                <i class="fa-solid fa-rotate-right me-1"></i>Reset
            </button>
        </form>
        <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Admin
        </a>
    </div>
</div>


@if (Model.Entries.Count == 0)
{
    <div class="alert alert-info">
        <i class="fa-solid fa-info-circle me-1"></i>No query statistics recorded yet. Navigate around the app to generate data.
    </div>
}
else
{
    var dbTable = TableModel.For(Model.Entries)
        .RowCss(r => r.Operation switch
        {
            var op when string.Equals(op, "SELECT", StringComparison.Ordinal) => null,
            var op when string.Equals(op, "INSERT", StringComparison.Ordinal) => "table-success",
            var op when string.Equals(op, "UPDATE", StringComparison.Ordinal) => "table-info",
            var op when string.Equals(op, "DELETE", StringComparison.Ordinal) => "table-warning",
            _ => null
        })
        .Column("Operation", r => r.Operation)
        .Column("Table", r => r.Table)
        .Column("Count", r => r.Count, c => c.Number().End())
        .Column("Avg (ms)", r => r.AverageMs.ToString("F2", System.Globalization.CultureInfo.CurrentCulture), c => c.End())
        .Column("Max (ms)", r => r.MaxMs.ToString("F2", System.Globalization.CultureInfo.CurrentCulture), c => c.End())
        .Column("Total (ms)", r => r.TotalMs.ToString("F2", System.Globalization.CultureInfo.CurrentCulture), c => c.End())
        .Id("dbStatsTable")
        .Build();
    <partial name="_Table" model="dbTable" />
}
