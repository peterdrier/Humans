@model DbStatsViewModel
@{
    ViewData["Title"] = "Database Query Statistics";
}

<div class="page-head">
    <div>
        <h1 class="title">Database Query Statistics</h1>
        <p class="sub">@Model.TotalQueryCount.ToString("N0") total queries since last restart</p>
    </div>
    <div class="d-flex align-items-center gap-3">
        <form asp-action="ResetDbStats" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-warning btn-sm"
                    data-confirm="Reset all query statistics?">
                <i class="fa-solid fa-rotate-right me-1"></i>Reset
            </button>
        </form>
        <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Admin
        </a>
    </div>
</div>


@if (Model.Entries.Count == 0)
{
    <div class="alert alert-info">
        <i class="fa-solid fa-info-circle me-1"></i>No query statistics recorded yet. Navigate around the app to generate data.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-hover font-monospace" style="font-size: 0.85rem;" id="dbStatsTable" data-sortable-table>
            <thead>
                <tr>
                    <th data-sort-col="0" data-sort-type="text">Operation <i class="fa-solid fa-sort fa-xs"></i></th>
                    <th data-sort-col="1" data-sort-type="text">Table <i class="fa-solid fa-sort fa-xs"></i></th>
                    <th data-sort-col="2" data-sort-type="number" class="text-end">Count <i class="fa-solid fa-sort fa-xs"></i></th>
                    <th data-sort-col="3" data-sort-type="number" class="text-end">Avg (ms) <i class="fa-solid fa-sort fa-xs"></i></th>
                    <th data-sort-col="4" data-sort-type="number" class="text-end">Max (ms) <i class="fa-solid fa-sort fa-xs"></i></th>
                    <th data-sort-col="5" data-sort-type="number" class="text-end">Total (ms) <i class="fa-solid fa-sort fa-xs"></i></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in Model.Entries)
                {
                    var opClass = entry.Operation switch
                    {
                        "SELECT" => "",
                        "INSERT" => "table-success",
                        "UPDATE" => "table-info",
                        "DELETE" => "table-warning",
                        _ => ""
                    };
                    <tr class="@opClass">
                        <td>@entry.Operation</td>
                        <td>@entry.Table</td>
                        <td class="text-end">@entry.Count.ToString("N0")</td>
                        <td class="text-end">@entry.AverageMs.ToString("F2")</td>
                        <td class="text-end">@entry.MaxMs.ToString("F2")</td>
                        <td class="text-end">@entry.TotalMs.ToString("F2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
