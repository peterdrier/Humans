@using Humans.Web.Models.Tables
@model ClientStatsViewModel
@{
    ViewData["Title"] = "Client Statistics";
}

<page-header title="Client Statistics">
    <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="fa-solid fa-arrow-left me-1"></i>Admin
    </a>
</page-header>

<div class="alert alert-info">
    <i class="fa-solid fa-circle-info me-1"></i>
    All counts are in-memory and reset on every restart/redeploy — read them as
    <strong>"since this deploy"</strong>, not historical totals. OS / browser / device
    are tallied per HTML page view; resolution is reported once per browser session.
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <partial name="_ClientStatTable"
                 model="@(new ClientStatTableModel("Operating system", "fa-solid fa-desktop", Model.TotalPageViews, Model.OperatingSystems))" />
    </div>
    <div class="col-lg-6">
        <partial name="_ClientStatTable"
                 model="@(new ClientStatTableModel("Browser", "fa-solid fa-globe", Model.TotalPageViews, Model.Browsers))" />
    </div>
    <div class="col-lg-6">
        <partial name="_ClientStatTable"
                 model="@(new ClientStatTableModel("Device type", "fa-solid fa-mobile-screen", Model.TotalPageViews, Model.DeviceTypes))" />
    </div>
    <div class="col-lg-6">
        <partial name="_ClientStatTable"
                 model="@(new ClientStatTableModel("Bots / crawlers", "fa-solid fa-robot", Model.TotalBotPageViews, Model.Bots))" />
    </div>
    <div class="col-lg-6">
        <partial name="_ClientStatTable"
                 model="@(new ClientStatTableModel("Screen resolution", "fa-solid fa-ruler-combined", Model.TotalResolutionSamples, Model.Resolutions))" />
    </div>
</div>

<h2 class="h4 mt-5 mb-2">
    <i class="fa-solid fa-signal me-1"></i>HTTP status codes
</h2>
<p class="text-muted small">
    @Model.TotalResponses.ToString("N0") responses since startup, across <em>all</em> traffic
    (pages, assets, API, probes) — observed from ASP.NET Core's request metric.
    Per-request detail for the error responses is on
    <a asp-action="HttpErrors">HTTP errors</a>.
</p>

@if (Model.StatusCodes.Count == 0)
{
    <div class="alert alert-secondary">No responses recorded yet.</div>
}
else
{
    var statusTable = TableModel.For(Model.StatusCodes)
        .RowCss(r => r.StatusCode switch
        {
            >= 500 => "table-danger",
            >= 400 => "table-warning",
            >= 300 => "table-info",
            _ => null
        })
        .Column("Code", r => r.StatusCode, c => c.Number())
        .Column("Category", r => r.Category)
        .Column("Count", r => r.Count, c => c.Number().End())
        .Column("%", r => r.Percent.ToString("F1", System.Globalization.CultureInfo.CurrentCulture), c => c.End())
        .Build();
    <partial name="_Table" model="statusTable" />
}
