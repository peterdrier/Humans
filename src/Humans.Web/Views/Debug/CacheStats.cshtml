@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@model CacheStatsViewModel
@{
    ViewData["Title"] = "Cache Statistics";
}

<div class="page-head">
    <div>
        <h1 class="title">Cache Statistics</h1>
        <p class="sub">@((Model.TotalHits + Model.TotalMisses).ToString("N0")) total lookups since last restart</p>
    </div>
    <div class="d-flex align-items-center gap-3">
        <form asp-action="ResetCacheStats" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-warning btn-sm"
                    data-confirm="Reset all cache statistics?">
                <i class="fa-solid fa-rotate-right me-1"></i>Reset
            </button>
        </form>
        <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Admin
        </a>
    </div>
</div>


<div class="stats">
    <div class="stat">
        <div class="label">Hits</div>
        <div class="value text-success">@Model.TotalHits.ToString("N0")</div>
    </div>
    <div class="stat">
        <div class="label">Misses</div>
        <div class="value text-danger">@Model.TotalMisses.ToString("N0")</div>
    </div>
    <div class="stat">
        <div class="label">Overall Hit Rate</div>
        <div class="value">@Model.OverallHitRatePercent.ToString("F1")<em>%</em></div>
    </div>
    <div class="stat">
        <div class="label">Active Entries</div>
        <div class="value text-primary">@Model.TotalActiveEntries.ToString("N0")</div>
    </div>
</div>

<h2 class="h5 mt-4">IMemoryCache</h2>
@if (Model.Entries.Count == 0)
{
    <div class="alert alert-info">
        <i class="fa-solid fa-info-circle me-1"></i>No cache statistics recorded yet. Navigate around the app to generate data.
    </div>
}
else
{
    Func<CacheStatEntryViewModel, IHtmlContent> typeBadgeCell = @<text>
        @{
            var badgeClass = item.Type switch
            {
                "Static" => "bg-primary",
                "PerUser" => "bg-info",
                "PerEntity" => "bg-secondary",
                "RateLimit" => "bg-warning text-dark",
                _ => "bg-light text-dark"
            };
        }
        <span class="badge @badgeClass">@item.Type</span>
    </text>;
    var cacheTable = TableModel.For(Model.Entries)
        .RowCss(r => r.HitRatePercent switch
        {
            >= 80 => "table-success",
            >= 50 => null,
            _ => "table-warning"
        })
        .Column("Key Type", r => r.KeyType)
        .Template("Type", typeBadgeCell)
        .Column("Entries", r => r.ActiveEntries, c => c.Number().End())
        .Column("TTL", r => r.Ttl)
        .Column("Hits", r => r.Hits, c => c.Number().End())
        .Column("Misses", r => r.Misses, c => c.Number().End())
        .Column("Hit Rate %", r => r.HitRatePercent.ToString("F1", System.Globalization.CultureInfo.CurrentCulture) + "%", c => c.End())
        .Id("cacheStatsTable")
        .Build();
    <partial name="_Table" model="cacheTable" />
}

<h2 class="h5 mt-4">Caching Decorators</h2>
@if (Model.DecoratorEntries.Count == 0)
{
    <div class="alert alert-info">
        <i class="fa-solid fa-info-circle me-1"></i>No decorator caches registered.
    </div>
}
else
{
    Func<DecoratorCacheStatEntryViewModel, IHtmlContent> warmedCell = @<text>
        @if (item.IsWarmedUp)
        {
            <i class="fa-solid fa-check text-success" title="Warmed"></i>
        }
        else
        {
            <i class="fa-solid fa-xmark text-muted" title="Cold (lazy or awaiting warmup)"></i>
        }
    </text>;
    var decoratorTable = TableModel.For(Model.DecoratorEntries)
        .RowCss(r => (r.Hits + r.Misses) == 0
            ? null
            : r.HitRatePercent switch
            {
                >= 80 => "table-success",
                >= 50 => null,
                _ => "table-warning"
            })
        .Column("Name", r => r.Name)
        .Template("Warmed", warmedCell, c => c.Css("text-center").HeaderCss("text-center"))
        .Column("Entries", r => r.Entries, c => c.Number().End())
        .Column("Hits", r => r.Hits, c => c.Number().End())
        .Column("Misses", r => r.Misses, c => c.Number().End())
        .Column("Hit Rate %", r => r.Hits + r.Misses == 0 ? "—" : r.HitRatePercent.ToString("F1", System.Globalization.CultureInfo.CurrentCulture) + "%", c => c.End())
        .Column("Key Rmv", r => r.KeyRemovals, c => c.Number().End())
        .Column("Bulk Inval", r => r.BulkInvalidations, c => c.Number().End())
        .Id("decoratorCacheStatsTable")
        .Build();
    <partial name="_Table" model="decoratorTable" />
}
