@using Humans.Domain.Enums
@using Humans.Web.Models.CampAdmin
@model ShiftObligationFunctionsViewModel
@{
    ViewData["Title"] = "Shift-obligation functions";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Camp" asp-action="Index">@Localizer["Camp_Plural"]</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">@Localizer["Camp_AdminTitle"]</a></li>
        <li class="breadcrumb-item"><a asp-action="ShiftObligations">Shift obligations</a></li>
        <li class="breadcrumb-item active" aria-current="page">Functions</li>
    </ol>
</nav>

<h1 class="mb-4">Shift-obligation functions</h1>

<vc:temp-data-alerts />

<div class="card mb-4">
    <div class="card-header"><i class="fa-solid fa-list me-2"></i>Configured functions</div>
    @if (Model.Functions.Count == 0)
    {
        <div class="card-body"><p class="text-muted mb-0">No functions configured yet.</p></div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead>
                    <tr>
                        <th>Target</th>
                        <th>Type</th>
                        <th>Role slug</th>
                        <th>Applicability</th>
                        <th class="text-end">Default required</th>
                        <th class="text-end">Sort</th>
                        <th>Active</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var f in Model.Functions)
                    {
                        <tr>
                            <td>@(string.IsNullOrWhiteSpace(f.TargetName) ? f.TargetId.ToString() : f.TargetName)</td>
                            <td>@f.TargetType</td>
                            <td><code>@f.CampRoleSlug</code></td>
                            <td>@f.Applicability</td>
                            <td class="text-end">@f.DefaultRequiredShiftCount</td>
                            <td class="text-end">@f.SortOrder</td>
                            <td>
                                @if (f.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="ShiftObligationFunctions" asp-route-editId="@f.Id"
                                   fragment="function-form" class="btn btn-outline-secondary btn-sm">
                                    <i class="fa-solid fa-pen me-1"></i>Edit
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="card mb-4" id="function-form">
    <div class="card-header"><i class="fa-solid fa-plus me-2"></i>Add / edit function</div>
    <div class="card-body">
        @if (Model.Form.Id is not null)
        {
            <div class="alert alert-info py-2 small">
                <i class="fa-solid fa-pen me-1"></i>Editing: <strong>@Model.EditTargetName</strong>.
                Save to update it, or <a asp-action="ShiftObligationFunctions">start a new function</a>.
            </div>
        }
        <p class="text-muted small">
            Use the <strong>Edit</strong> button on a function above to change it, or leave the Id blank
            to create a new one. Each (target type, target) pair may be used once.
        </p>
        <form asp-action="ShiftObligationFunctions" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <div class="col-md-6">
                <label class="form-label">Function Id (optional — edit)</label>
                <input type="text" name="Id" class="form-control form-control-sm"
                       pattern="^[0-9a-fA-F]{8}-([0-9a-fA-F]{4}-){3}[0-9a-fA-F]{12}$"
                       value="@(Model.Form.Id?.ToString())"
                       placeholder="Leave blank to create" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Target type</label>
                <select name="TargetType" id="targetTypeSelect" class="form-select form-select-sm">
                    @foreach (var t in Enum.GetValues<ShiftObligationTargetType>())
                    {
                        <option value="@t" selected="@(t == Model.Form.TargetType)">@t</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Applicability</label>
                <select name="Applicability" class="form-select form-select-sm">
                    @foreach (var a in Enum.GetValues<ObligationApplicability>())
                    {
                        <option value="@a" selected="@(a == Model.Form.Applicability)">@a</option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Target</label>
                @* Name-based picker mirroring the HumanSearch autocomplete: a visible
                   text input (the name), a hidden input that posts the GUID as TargetId,
                   and a substring-filtered dropdown over a server-embedded list. The
                   Target type select above switches the data source (teams vs rotas). *@
                <div class="target-search-wrapper position-relative">
                    <input type="text"
                           id="target-search-input"
                           class="form-control form-control-sm"
                           placeholder="Search teams by name…"
                           value="@(Model.SelectedTargetName ?? "")"
                           autocomplete="off" />
                    <input type="hidden"
                           name="TargetId"
                           id="target-search-hidden"
                           value="@(Model.Form.TargetId == Guid.Empty ? "" : Model.Form.TargetId.ToString())" />
                    <ul id="target-search-dropdown"
                        class="list-group shadow-sm"
                        style="display: none; position: fixed; max-height: 260px; overflow-y: auto; z-index: 2000; background: var(--h-bg-card, #fff); border: 1px solid var(--h-border, #ccc); border-radius: 4px;">
                    </ul>
                </div>
                <div class="form-text">Pick a team or rota by name — the type selector switches the list.</div>
            </div>
            <div class="col-md-3">
                <label class="form-label">Camp role slug</label>
                <select name="CampRoleSlug" class="form-select form-select-sm">
                    <option value="">— none (remind barrio leads only) —</option>
                    @foreach (var opt in Model.CampRoleSlugOptions)
                    {
                        if (string.Equals(opt.Slug, Model.Form.CampRoleSlug, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@opt.Slug" selected>@opt.Name (@opt.Slug)</option>
                        }
                        else
                        {
                            <option value="@opt.Slug">@opt.Name (@opt.Slug)</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Default required shifts</label>
                <input type="number" name="DefaultRequiredShiftCount" min="0" value="@Model.Form.DefaultRequiredShiftCount" class="form-control form-control-sm" required />
            </div>
            <div class="col-md-3">
                <label class="form-label">Sort order</label>
                <input type="number" name="SortOrder" value="@Model.Form.SortOrder" class="form-control form-control-sm" required />
                <div class="form-text">Order of this function's column in the matrix (lowest first).</div>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <div class="form-check">
                    <input type="checkbox" name="IsActive" value="true" class="form-check-input" id="isActive" checked="@Model.Form.IsActive" />
                    <label class="form-check-label" for="isActive">Active</label>
                </div>
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="fa-solid fa-floppy-disk me-1"></i>Save function
                </button>
            </div>
        </form>
    </div>
</div>

@{
    var teamOptionsJson = System.Text.Json.JsonSerializer.Serialize(
        Model.TeamOptions.Select(o => new { id = o.Id.ToString(), name = o.Name }));
    var rotaOptionsJson = System.Text.Json.JsonSerializer.Serialize(
        Model.RotaOptions.Select(o => new { id = o.Id.ToString(), name = o.Name }));
}

@* Name-based Target picker. Mirrors Views/Shared/Components/HumanSearch/Default.cshtml
   (visible text input + hidden GUID input + body-reparented fixed dropdown), but the
   data source is embedded server-side and filtered locally — no AJAX. The Target type
   select toggles between the team and rota lists. *@
<script>
(function () {
    var teams = @Html.Raw(teamOptionsJson);
    var rotas = @Html.Raw(rotaOptionsJson);

    var typeSelect = document.getElementById('targetTypeSelect');
    var textInput = document.getElementById('target-search-input');
    var hiddenInput = document.getElementById('target-search-hidden');
    var dropdown = document.getElementById('target-search-dropdown');
    var isOpen = false;

    // Reparent the dropdown to body so no parent stacking/clip applies (same as HumanSearch).
    if (dropdown.parentNode !== document.body) {
        document.body.appendChild(dropdown);
    }

    function currentSource() {
        return typeSelect.value === 'Rota' ? rotas : teams;
    }

    function placeholderFor() {
        return typeSelect.value === 'Rota' ? 'Search rotas by name…' : 'Search teams by name…';
    }

    function positionDropdown() {
        var rect = textInput.getBoundingClientRect();
        dropdown.style.top = (rect.bottom + 2) + 'px';
        dropdown.style.left = rect.left + 'px';
        dropdown.style.width = rect.width + 'px';
    }

    function showDropdown() {
        positionDropdown();
        dropdown.style.display = 'block';
        isOpen = true;
        window.addEventListener('scroll', positionDropdown, true);
        window.addEventListener('resize', positionDropdown);
    }

    function hideDropdown() {
        dropdown.style.display = 'none';
        dropdown.innerHTML = '';
        isOpen = false;
        window.removeEventListener('scroll', positionDropdown, true);
        window.removeEventListener('resize', positionDropdown);
    }

    function renderDropdown(items) {
        dropdown.innerHTML = '';
        if (!items || items.length === 0) {
            hideDropdown();
            return;
        }
        items.forEach(function (item) {
            var li = document.createElement('li');
            li.className = 'list-group-item list-group-item-action py-2 px-3';
            li.style.cursor = 'pointer';
            li.textContent = item.name;
            li.addEventListener('mousedown', function (e) {
                e.preventDefault();
                hiddenInput.value = item.id;
                textInput.value = item.name;
                hideDropdown();
            });
            dropdown.appendChild(li);
        });
        showDropdown();
    }

    function filterAndShow() {
        var q = textInput.value.trim().toLowerCase();
        var source = currentSource();
        var matches = q.length === 0
            ? source.slice(0, 50)
            : source.filter(function (x) { return x.name.toLowerCase().indexOf(q) !== -1; });
        renderDropdown(matches);
    }

    textInput.addEventListener('input', function () {
        // Typing invalidates any prior selection until an item is picked.
        hiddenInput.value = '';
        filterAndShow();
    });

    textInput.addEventListener('focus', filterAndShow);

    textInput.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') hideDropdown();
    });

    document.addEventListener('mousedown', function (e) {
        if (!isOpen) return;
        if (textInput.contains(e.target) || dropdown.contains(e.target)) return;
        hideDropdown();
    });

    typeSelect.addEventListener('change', function () {
        // Switching the target type swaps the data source; clear the selection so
        // a team GUID can't survive into a rota target (or vice versa).
        hiddenInput.value = '';
        textInput.value = '';
        textInput.placeholder = placeholderFor();
        hideDropdown();
    });

    // Initial placeholder reflects the pre-selected type (matters on edit pre-fill).
    textInput.placeholder = placeholderFor();
})();
</script>
