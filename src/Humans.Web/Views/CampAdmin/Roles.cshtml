@using Humans.Web.Models.CampAdmin
@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@model CampRoleDefinitionListViewModel
@{
    ViewData["Title"] = "Camp roles";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Camp" asp-action="Index">@Localizer["Camp_Plural"]</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">@Localizer["Camp_AdminTitle"]</a></li>
        <li class="breadcrumb-item active" aria-current="page">Roles</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-1">Camp roles</h1>
        <p class="text-muted mb-0">Global role definitions applied to every barrio.</p>
    </div>
    <a asp-controller="CampAdmin" asp-action="CreateRole" class="btn btn-primary">
        <i class="fa-solid fa-plus me-1"></i>Add role
    </a>
</div>


<div class="card mb-4">
    <div class="card-header">
        <i class="fa-solid fa-circle-check me-2"></i>Active (@Model.Active.Count)
    </div>
    @if (Model.Active.Count == 0)
    {
        <div class="card-body">
            <p class="text-muted mb-0">No active camp roles defined yet. Use <strong>Add role</strong> to create the first one.</p>
        </div>
    }
    else
    {
        Func<CampRoleDefinitionListRowViewModel, IHtmlContent> activeNameCell = @<text>
            <a asp-controller="CampAdmin" asp-action="RolesDrillDown" asp-route-slug="@(string.IsNullOrWhiteSpace(item.Slug) ? item.Id.ToString() : item.Slug)"><strong>@item.Name</strong></a>
            @if (!string.IsNullOrWhiteSpace(item.GroupEmail))
            {
                <small class="text-muted ms-2"><code>@item.GroupEmail</code></small>
            }
            @if (!string.IsNullOrWhiteSpace(item.Description))
            {
                <br />
                <small class="text-muted">@Html.SanitizedMarkdown(item.Description)</small>
            }
        </text>;
        Func<CampRoleDefinitionListRowViewModel, IHtmlContent> activeActionsCell = @<text>
            <a asp-controller="CampAdmin" asp-action="RolesDrillDown" asp-route-slug="@(string.IsNullOrWhiteSpace(item.Slug) ? item.Id.ToString() : item.Slug)" class="btn btn-outline-secondary btn-sm">
                <i class="fa-solid fa-table-list me-1"></i>Roster
            </a>
            <a asp-controller="CampAdmin" asp-action="EditRole" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">
                <i class="fa-solid fa-pen-to-square me-1"></i>Edit
            </a>
            <form asp-controller="CampAdmin" asp-action="DeactivateRole" asp-route-id="@item.Id" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-warning btn-sm" data-confirm="Deactivate this role? Existing assignments will remain but it will no longer be assignable.">
                    <i class="fa-solid fa-eye-slash me-1"></i>Deactivate
                </button>
            </form>
        </text>;
        var activeTable = TableModel.For(Model.Active)
            .Column("Sort", r => r.SortOrder)
            .Template("Name", activeNameCell)
            .Column("Slots", r => r.SlotCount, c => c.End())
            .Column("Min required", r => r.MinimumRequired, c => c.End())
            .Template("Actions", activeActionsCell, c => c.NoSort().End())
            .Build();
        <partial name="_Table" model="activeTable" />
    }
</div>

@if (Model.Deactivated.Count > 0)
{
    Func<CampRoleDefinitionListRowViewModel, IHtmlContent> deactivatedNameCell = @<text>
        <strong>@item.Name</strong>
        @if (!string.IsNullOrWhiteSpace(item.Description))
        {
            <br />
            <small class="text-muted">@Html.SanitizedMarkdown(item.Description)</small>
        }
    </text>;
    Func<CampRoleDefinitionListRowViewModel, IHtmlContent> reactivateCell =
        @<text>
            <form asp-controller="CampAdmin" asp-action="ReactivateRole" asp-route-id="@item.Id" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-success btn-sm">
                    <i class="fa-solid fa-rotate-left me-1"></i>Reactivate
                </button>
            </form>
        </text>;
    var deactivatedTable = TableModel.For(Model.Deactivated)
        .RowCss(_ => "text-muted")
        .Column("Sort", r => r.SortOrder)
        .Template("Name", deactivatedNameCell)
        .Column("Slots", r => r.SlotCount, c => c.End())
        .Column("Min required", r => r.MinimumRequired, c => c.End())
        .Template("Actions", reactivateCell, c => c.NoSort().End())
        .Build();
    <div class="card">
        <div class="card-header">
            <i class="fa-solid fa-circle-pause me-2"></i>Deactivated (@Model.Deactivated.Count)
        </div>
        <partial name="_Table" model="deactivatedTable" />
    </div>
}
