@model Humans.Web.Models.CampAdminViewModel
@{
    ViewData["Title"] = Localizer["Camp_AdminTitle"];
}

<h1>@Localizer["Camp_AdminTitle"]</h1>

<vc:temp-data-alerts />

@* Summary cards *@
<div class="row row-cols-2 row-cols-md-5 g-3 mb-4">
    <div class="col">
        <div class="card text-center h-100">
            <div class="card-body">
                <h5 class="card-title">@Model.TotalCamps</h5>
                <p class="card-text text-muted">Total @Localizer["Camp_Plural"] (@Model.PublicYear)</p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card text-center h-100">
            <div class="card-body">
                <h5 class="card-title">@Model.ActiveCamps</h5>
                <p class="card-text text-muted">Active</p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card text-center h-100">
            <div class="card-body">
                <h5 class="card-title">@Model.PendingCamps.Count</h5>
                <p class="card-text text-muted">Pending Review</p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card text-center h-100">
            <div class="card-body">
                <h5 class="card-title">@Model.WithdrawnCamps.Count</h5>
                <p class="card-text text-muted">Withdrawn</p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card text-center h-100">
            <div class="card-body">
                <h5 class="card-title">@(Model.OpenSeasons.Count > 0 ? string.Join(", ", Model.OpenSeasons) : "None")</h5>
                <p class="card-text text-muted">Open Seasons</p>
            </div>
        </div>
    </div>
</div>

@* Pending Approvals *@
<div class="card mb-4">
    <div class="card-header">
        <i class="fa-solid fa-clock me-2"></i>Pending Approvals
    </div>
    @if (Model.PendingCamps.Count == 0)
    {
        <div class="card-body">
            <p class="text-muted mb-0">No camps pending review.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Notes</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var camp in Model.PendingCamps)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Camp" asp-action="Details" asp-route-slug="@camp.Slug">
                                    @camp.Name
                                </a>
                            </td>
                            <td>@((camp.BlurbShort ?? "").Length > 100 ? camp.BlurbShort![..100] + "..." : camp.BlurbShort)</td>
                            <td>
                                <input type="text" class="form-control form-control-sm" form="approve-@camp.SeasonId" name="notes" placeholder="Optional notes" />
                            </td>
                            <td class="text-end">
                                <form id="approve-@camp.SeasonId" asp-controller="CampAdmin" asp-action="Approve" asp-route-seasonId="@camp.SeasonId" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-success btn-sm" title="Approve">
                                        <i class="fa-solid fa-check me-1"></i>Approve
                                    </button>
                                </form>
                                <button type="button" class="btn btn-danger btn-sm" data-bs-toggle="collapse" data-bs-target="#reject-@camp.SeasonId" title="Reject">
                                    <i class="fa-solid fa-xmark me-1"></i>Reject
                                </button>
                            </td>
                        </tr>
                        <tr class="collapse" id="reject-@camp.SeasonId">
                            <td colspan="4">
                                <form asp-controller="CampAdmin" asp-action="Reject" asp-route-seasonId="@camp.SeasonId" method="post" class="d-flex gap-2 p-2">
                                    @Html.AntiForgeryToken()
                                    <input type="text" name="notes" class="form-control form-control-sm" placeholder="Rejection reason (required)" required />
                                    <button type="submit" class="btn btn-danger btn-sm text-nowrap">Confirm Reject</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@* Withdrawn Camps *@
@if (Model.WithdrawnCamps.Count > 0)
{
    <div class="card mb-4">
        <div class="card-header">
            <i class="fa-solid fa-circle-pause me-2"></i>Withdrawn (@Model.WithdrawnCamps.Count)
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var camp in Model.WithdrawnCamps)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Camp" asp-action="Details" asp-route-slug="@camp.Slug">
                                    @camp.Name
                                </a>
                            </td>
                            <td>@((camp.BlurbShort ?? "").Length > 100 ? camp.BlurbShort![..100] + "..." : camp.BlurbShort)</td>
                            <td class="text-end">
                                <form asp-controller="CampAdmin" asp-action="Reactivate" asp-route-seasonId="@camp.SeasonId" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-warning btn-sm" title="Move back to pending approval">
                                        <i class="fa-solid fa-rotate-left me-1"></i>Move to Pending
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@* Season Management *@
<div class="row">
    <div class="col-md-6">
        <div class="card mb-4">
            <div class="card-header">
                <i class="fa-solid fa-calendar me-2"></i>Season Management
            </div>
            <div class="card-body">
                <h6>Open a Season for Registration</h6>
                <form asp-controller="CampAdmin" asp-action="OpenSeason" method="post" class="d-flex gap-2 mb-3">
                    @Html.AntiForgeryToken()
                    <input type="number" name="year" class="form-control form-control-sm" style="max-width: 120px;" placeholder="Year" min="2024" max="2099" required />
                    <button type="submit" class="btn btn-outline-primary btn-sm text-nowrap">
                        <i class="fa-solid fa-door-open me-1"></i>Open
                    </button>
                </form>

                @if (Model.OpenSeasons.Count > 0)
                {
                    <h6>Close a Season</h6>
                    @foreach (var year in Model.OpenSeasons)
                    {
                        <form asp-controller="CampAdmin" asp-action="CloseSeason" asp-route-year="@year" method="post" class="d-inline me-2 mb-2">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-warning btn-sm">
                                <i class="fa-solid fa-door-closed me-1"></i>Close @year
                            </button>
                        </form>
                    }
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card mb-4">
            <div class="card-header">
                <i class="fa-solid fa-eye me-2"></i>Public Year
            </div>
            <div class="card-body">
                <p class="text-muted">Currently showing: <strong>@Model.PublicYear</strong></p>
                <form asp-controller="CampAdmin" asp-action="SetPublicYear" method="post" class="d-flex gap-2">
                    @Html.AntiForgeryToken()
                    <input type="number" name="year" class="form-control form-control-sm" style="max-width: 120px;" value="@Model.PublicYear" min="2024" max="2099" required />
                    <button type="submit" class="btn btn-outline-primary btn-sm text-nowrap">
                        <i class="fa-solid fa-arrows-rotate me-1"></i>Set
                    </button>
                </form>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <i class="fa-solid fa-lock me-2"></i>Name Lock Date
            </div>
            <div class="card-body">
                @if (Model.NameLockDates.Count > 0)
                {
                    <div class="mb-3">
                        @foreach (var (year, lockDate) in Model.NameLockDates.OrderBy(x => x.Key))
                        {
                            <p class="mb-1">
                                <strong>@year:</strong>
                                @if (lockDate.HasValue)
                                {
                                    @lockDate.Value.ToDisplayDate()
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </p>
                        }
                    </div>
                }
                <p class="text-muted">After this date, camps can no longer change their name for a season.</p>
                <form asp-controller="CampAdmin" asp-action="SetNameLockDate" method="post" class="d-flex gap-2">
                    @Html.AntiForgeryToken()
                    <input type="number" name="year" class="form-control form-control-sm" style="max-width: 120px;" placeholder="Year" min="2024" max="2099" required />
                    <input type="date" name="lockDate" class="form-control form-control-sm" style="max-width: 180px;" required />
                    <button type="submit" class="btn btn-outline-primary btn-sm text-nowrap">
                        <i class="fa-solid fa-lock me-1"></i>Set
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@* Camp Summary Table *@
@if (Model.AllCampSummaries.Count > 0)
{
    <div class="card mb-4">
        <div class="card-header">
            <i class="fa-solid fa-table me-2"></i>Camp Summary (@Model.PublicYear)
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead>
                    <tr>
                        <th>Camp Name</th>
                        <th>Accepting</th>
                        <th class="text-end">Humans</th>
                        <th>Zone</th>
                        <th>Space</th>
                        <th class="text-end">Years</th>
                        <th>Lead(s)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var camp in Model.AllCampSummaries)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Camp" asp-action="Details" asp-route-slug="@camp.Slug">@camp.Name</a>
                            </td>
                            <td>@camp.AcceptingMembers</td>
                            <td class="text-end">@camp.MemberCount</td>
                            <td>@camp.Zone</td>
                            <td>@camp.SpaceRequirement</td>
                            <td class="text-end">@camp.YearsParticipating</td>
                            <td>
                                @foreach (var lead in camp.Leads)
                                {
                                    <human-link user-id="@lead.UserId" display-name="@lead.DisplayName" />
                                    if (lead != camp.Leads.Last())
                                    {
                                        <text>, </text>
                                    }
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@* All Camps quick list -- link to public page *@
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fa-solid fa-campground me-2"></i>All @Localizer["Camp_Plural"] (@Model.PublicYear)</span>
        <div class="d-flex gap-2">
            <a asp-action="ExportCamps" class="btn btn-outline-secondary btn-sm">
                <i class="fa-solid fa-download me-1"></i>Export CSV
            </a>
            <a asp-controller="Camp" asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="fa-solid fa-arrow-up-right-from-square me-1"></i>View Public Page
            </a>
        </div>
    </div>
    <div class="card-body">
        <p class="text-muted">Use the public @Localizer["Camp_Plural"] page to browse all registered camps. CampAdmin and Admin users can edit any camp from its detail page.</p>
    </div>
</div>

<div class="card mb-4 border-danger" authorize-policy="AdminOnly">
    <div class="card-header bg-danger text-white">
        <i class="fa-solid fa-triangle-exclamation me-2"></i>Danger Zone (Admin Only)
    </div>
    <div class="card-body">
        <p class="text-muted">Permanently delete a camp and all its seasons, images, and leads.</p>
        <form asp-controller="CampAdmin" asp-action="Delete" method="post" class="d-flex gap-2"
              data-confirm="Are you sure? This action cannot be undone.">
            @Html.AntiForgeryToken()
            <input type="text" name="campId" class="form-control form-control-sm" style="max-width: 320px;" placeholder="Camp ID (GUID)" required pattern="^[0-9a-fA-F]{8}-([0-9a-fA-F]{4}-){3}[0-9a-fA-F]{12}$" />
            <button type="submit" class="btn btn-danger btn-sm text-nowrap">
                <i class="fa-solid fa-trash me-1"></i>Delete <i class="fa-solid fa-lock auth-lock-icon"></i>
            </button>
        </form>
    </div>
</div>
