@using Humans.Application.DTOs.Shifts.Workload
@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@model IReadOnlyList<WorkloadByPersonRow>

@if (Model.Count == 0)
{
    <div class="alert alert-info">No humans have shift signups or role assignments yet.</div>
    return;
}

@{
    Func<WorkloadByPersonRow, IHtmlContent> humanCell =
        @<text><vc:human user-id="@item.UserId" layout="Text" link="Admin" /></text>;
    var table = TableModel.For(Model)
        .Template("Human", humanCell)
        .Column("Confirmed signups", r => r.ConfirmedSignupCount, c => c.Number().End())
        .Column("Pending signups", r => r.PendingSignupCount, c => c.Number().End())
        .Column("Year-round", r => r.YearRoundHours, c => c.Number().End())
        .Column("Build", r => r.BuildHours, c => c.Number().End())
        .Column("Event", r => r.EventHours, c => c.Number().End())
        .Column("Strike", r => r.StrikeHours, c => c.Number().End())
        .Column("Total", r => r.TotalHours, c => c.Number().End().Css("fw-semibold"))
        .Css("table-striped workload-table")
        .Build();
}
<partial name="_Table" model="table" />
