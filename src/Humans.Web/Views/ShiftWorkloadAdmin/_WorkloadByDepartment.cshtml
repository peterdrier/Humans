@using Humans.Application.DTOs.Shifts.Workload
@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@using System.Globalization
@model IReadOnlyList<WorkloadByDepartmentRow>

@if (Model.Count == 0)
{
    <div class="alert alert-info">No departments own rotas or roles in this event.</div>
    return;
}

@{
    Func<WorkloadByDepartmentRow, IHtmlContent> departmentCell = @<text>
        @if (!string.IsNullOrEmpty(item.TeamSlug))
        {
            <a asp-controller="ShiftAdmin" asp-action="Index" asp-route-slug="@item.TeamSlug">@item.TeamName</a>
        }
        else
        {
            @item.TeamName
        }
    </text>;
    Func<WorkloadByDepartmentRow, IHtmlContent> coverageCell = @<text>
        @(item.PlannedSlots > 0
            ? (item.FilledSlots * 100m / item.PlannedSlots).ToString("0.0", CultureInfo.InvariantCulture)
            : "0.0")%
    </text>;
    var table = TableModel.For(Model)
        .Template("Department", departmentCell)
        .Column("Rotas", r => r.RotaCount, c => c.Number().End())
        .Column("Shifts", r => r.ShiftCount, c => c.Number().End())
        .Column("Planned slots", r => r.PlannedSlots, c => c.Number().End())
        .Column("Filled slots", r => r.FilledSlots, c => c.Number().End())
        .Template("Coverage", coverageCell, c => c.End())
        .Column("Planned hours", r => r.PlannedHours, c => c.Number().End())
        .Column("Filled hours", r => r.FilledHours, c => c.Number().End())
        .Css("table-striped workload-table")
        .Build();
}
<partial name="_Table" model="table" />
