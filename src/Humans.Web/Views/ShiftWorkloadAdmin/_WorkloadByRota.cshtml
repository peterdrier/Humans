@using Humans.Application.DTOs.Shifts.Workload
@model IReadOnlyList<WorkloadByRotaRow>

@{
    var inv = System.Globalization.CultureInfo.InvariantCulture;
}

@if (Model.Count == 0)
{
    <div class="alert alert-info">No rotas in this event.</div>
    return;
}

<div class="table-responsive">
    <table class="table table-sm table-striped table-hover workload-table" data-sortable-table>
        <thead>
            <tr>
                <th data-sort>Department</th>
                <th data-sort>Rota</th>
                <th data-sort class="text-end">Shifts</th>
                <th data-sort class="text-end">Planned slots</th>
                <th data-sort class="text-end">Filled slots</th>
                <th data-sort class="text-end">Coverage</th>
                <th data-sort class="text-end">Planned hours</th>
                <th data-sort class="text-end">Filled hours</th>
                <th data-sort class="text-end">Pending signups</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model)
            {
                var pct = row.PlannedSlots > 0
                    ? row.FilledSlots * 100m / row.PlannedSlots
                    : 0m;
                <tr>
                    <td data-value="@row.TeamName">@row.TeamName</td>
                    <td data-value="@row.RotaName">@row.RotaName</td>
                    <td class="text-end" data-value="@row.ShiftCount">@row.ShiftCount</td>
                    <td class="text-end" data-value="@row.PlannedSlots">@row.PlannedSlots</td>
                    <td class="text-end" data-value="@row.FilledSlots">@row.FilledSlots</td>
                    <td class="text-end" data-value="@pct.ToString("0.0", inv)">@pct.ToString("0.0")%</td>
                    <td class="text-end" data-value="@row.PlannedHours.ToString("0.##", inv)">@row.PlannedHours.ToString("0.##")</td>
                    <td class="text-end" data-value="@row.FilledHours.ToString("0.##", inv)">@row.FilledHours.ToString("0.##")</td>
                    <td class="text-end" data-value="@row.PendingSignupCount">@row.PendingSignupCount</td>
                </tr>
            }
        </tbody>
    </table>
</div>
