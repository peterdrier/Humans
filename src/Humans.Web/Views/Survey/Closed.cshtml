@model Humans.Web.Models.SurveyClosedViewModel

@{
    ViewData["Title"] = "Survey unavailable";

    var (heading, body) = string.Equals(Model.Reason, "closed", StringComparison.Ordinal)
        ? ("This survey is closed", "Thanks for your interest — this survey is no longer accepting responses.")
        : ("This link is no longer valid", "The survey link you used is invalid or has expired. If you think this is a mistake, please request a new link.");
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card mt-4">
            <div class="card-body text-center py-5">
                <i class="fa-solid fa-circle-info fa-2x text-muted mb-3"></i>
                <h1 class="h4 mb-2">@heading</h1>
                <p class="text-muted mb-0">@body</p>
            </div>
        </div>
    </div>
</div>
