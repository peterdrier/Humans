@model Humans.Web.Models.ContainerMapViewModel
@{
    ViewData["Title"] = $"Container Placement {Model.Year}";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@5.20.1/dist/maplibre-gl.css" />
    <style>
        /* Override the main layout to occupy the whole screen space */
        .main-content { display: flex; max-width: 100vw; padding: 0; }
        main { display: flex; flex: 1; padding: 0; }
        #map-page { display: flex; flex: 1; overflow: hidden; }

        #container-sidebar {
            width: 280px;
            flex-shrink: 0;
            background: #1e1e2e;
            color: #fff;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            border-right: 1px solid #333;
        }
        #container-sidebar h2 {
            font-size: 14px;
            font-weight: 600;
            margin: 0;
            padding: 12px 14px 8px;
            border-bottom: 1px solid #333;
            color: #ffffffcc;
        }
        #sidebar-unplaced, #sidebar-placed { overflow-y: auto; padding: 8px; }
        .sidebar-section-label {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #ffffff55;
            padding: 6px 6px 4px;
        }
        .container-card {
            border-radius: 6px;
            padding: 8px 10px;
            margin-bottom: 6px;
            cursor: pointer;
            border: 1px solid #e8a02055;
            background: #e8a02011;
            transition: border-color 0.15s, background 0.15s;
        }
        .container-card:hover { border-color: #e8a020; background: #e8a02022; }
        .container-card.active { border-color: #4fc3f7; background: #4fc3f722; }
        .container-card.placed { border-color: #44aa6655; background: #22332233; cursor: default; }
        .container-card-name { font-size: 13px; font-weight: 600; }
        .container-card-name.placed-name { color: #88cc88; }
        .container-card-desc { font-size: 11px; color: #ffffff66; margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .container-card-actions { margin-top: 6px; }
        #map-container { flex: 1; position: relative; }
        #map { height: 100%; width: 100%; }
        #rotation-handle {
            position: absolute;
            width: 16px;
            height: 16px;
            background: #4fc3f7;
            border: 2px solid white;
            border-radius: 50%;
            cursor: grab;
            transform: translate(-50%, -50%);
            display: none;
            z-index: 10;
            pointer-events: auto;
        }
        #rotation-handle:active { cursor: grabbing; }
        #map-toast {
            position: absolute;
            bottom: 16px;
            left: 50%;
            transform: translateX(-50%);
            background: #cc2222;
            color: white;
            padding: 8px 16px;
            border-radius: 6px;
            font-size: 13px;
            display: none;
            z-index: 20;
        }
    </style>
}

<div id="map-page">
    <div id="container-sidebar">
        <h2>@Localizer["Container_Breadcrumb"] @Model.Year</h2>
        <div id="sidebar-unplaced">
            <div class="sidebar-section-label">@Localizer["ContainerMap_Unplaced"]</div>
        </div>
        <div id="sidebar-placed">
            <div class="sidebar-section-label">@Localizer["ContainerMap_Placed"]</div>
        </div>
    </div>
    <div id="map-container">
        <div id="map"
             data-year="@Model.Year"
             data-is-map-admin="@(Model.IsMapAdmin ? "true" : "false")"
             data-user-camp-season-id="@Model.UserCampSeasonId"></div>
        <div id="rotation-handle"></div>
        <div id="map-toast"></div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/maplibre-gl@5.20.1/dist/maplibre-gl.js"></script>
    <script src="https://unpkg.com/@@turf/turf@7.1.0/turf.min.js"></script>
    <script type="module" src="~/js/container-map/main.js"></script>
}
