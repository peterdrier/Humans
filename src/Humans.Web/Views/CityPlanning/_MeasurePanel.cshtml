@model Humans.Web.Models.CityPlanningMeasurePanelViewModel
@{
    var clearMeasurementsLabel = Localizer["CityPlanning_ClearMeasurementsButton"];
}

<div class="card shadow-sm">
    <div class="card-body py-2 px-3 d-flex flex-column gap-1">
        <vc:access-matrix section="@Model.AccessMatrixSection" />
        <div class="d-flex gap-1">
            <button type="button" id="measure-btn" class="btn btn-outline-secondary btn-sm flex-grow-1" title="@Localizer["CityPlanning_MeasureButton"]" aria-pressed="false">
                <i class="fa-solid fa-ruler me-1"></i> @Localizer["CityPlanning_MeasureButton"]
            </button>
            <button id="clear-measurements-btn" type="button" class="btn btn-sm btn-outline-danger d-none" title="@clearMeasurementsLabel" aria-label="@clearMeasurementsLabel">
                <i class="fa-solid fa-trash"></i>
            </button>
        </div>
        @if (!string.IsNullOrEmpty(Model.AdminAction) && !string.IsNullOrEmpty(Model.AdminLabel))
        {
            <a asp-action="@Model.AdminAction" class="btn btn-outline-primary btn-sm">
                <i class="@(Model.AdminIconCssClass) me-1"></i> @Model.AdminLabel
            </a>
        }
    </div>
</div>
