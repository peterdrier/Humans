@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@model Humans.Web.Models.GoogleSyncAuditListViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>@Model.Title</h1>
    @if (Model.BackUrl != null)
    {
        <a href="@Model.BackUrl" class="btn btn-outline-secondary">@(Model.BackLabel ?? "Back")</a>
    }
</div>

@if (Model.Entries.Count == 0)
{
    <div class="alert alert-info">
        No sync audit entries found.
    </div>
}
else
{
    Func<GoogleSyncAuditEntryViewModel, IHtmlContent> actionCell =
        @<text><span class="badge bg-secondary">@item.Action</span></text>;
    Func<GoogleSyncAuditEntryViewModel, IHtmlContent> descriptionCell = @<text>
        @item.Description
        @if (item.ResourceName != null)
        {
            <br />
            <small class="text-muted">Resource: @item.ResourceName</small>
        }
    </text>;
    Func<GoogleSyncAuditEntryViewModel, IHtmlContent> resultCell = @<text>
        @if (item.Success == true)
        {
            <span class="badge bg-success">OK</span>
        }
        else if (item.Success == false)
        {
            <span class="badge bg-danger" title="@item.ErrorMessage">Failed</span>
            @if (!string.IsNullOrEmpty(item.ErrorMessage))
            {
                <br />
                <small class="text-danger">@item.ErrorMessage</small>
            }
        }
        else
        {
            <span class="text-muted">--</span>
        }
    </text>;
    Func<GoogleSyncAuditEntryViewModel, IHtmlContent> actorCell =
        @<text><span class="badge bg-info">System</span></text>;
    Func<GoogleSyncAuditEntryViewModel, IHtmlContent> whenCell =
        @<text><span class="text-nowrap">@item.OccurredAt.ToInvariantTimestamp()</span></text>;
    var table = TableModel.For(Model.Entries)
        .Template("Action", actionCell, c => c.NoSort())
        .Template("Description", descriptionCell)
        .Column("User", e => e.UserEmail ?? "--")
        .Column("Role", e => e.Role ?? "--")
        .Column("Source", e => e.SyncSource != null ? e.SyncSource.ToString() : "--")
        .Template("Result", resultCell, c => c.NoSort())
        .Template("Actor", actorCell, c => c.NoSort())
        .Template("When", whenCell)
        .RowCss(e => e.Success == false ? "table-danger" : null)
        .Build();
    <div class="card">
        <partial name="_Table" model="table" />
    </div>
}
