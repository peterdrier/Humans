@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@model Humans.Web.Models.AuditLogListViewModel

<page-header title="Audit Log">
    <form asp-controller="AuditLog" asp-action="CheckDriveActivity" method="post" class="d-inline" id="checkForm">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-warning" id="checkBtn">
            Check Drive Activity Now
        </button>
    </form>
</page-header>


@if (Model.AnomalyCount > 0)
{
    <div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
        <strong class="me-2">@Model.AnomalyCount anomalous permission change(s) detected.</strong>
        <a asp-action="Index" asp-route-filter="AnomalousPermissionDetected" class="alert-link">View all</a>
    </div>
}

<div class="mb-3">
    <div class="btn-group" role="group">
        <a asp-action="Index" class="btn btn-sm @(string.IsNullOrEmpty(Model.ActionFilter) ? "btn-primary" : "btn-outline-primary")">
            All
        </a>
        <a asp-action="Index" asp-route-filter="AnomalousPermissionDetected"
           class="btn btn-sm @Model.ActionFilter.ToAuditFilterButtonClass(nameof(AuditAction.AnomalousPermissionDetected), "btn-warning", "btn-outline-warning")">
            Anomalous Permissions
            @if (Model.AnomalyCount > 0)
            {
                <span class="badge bg-danger ms-1">@Model.AnomalyCount</span>
            }
        </a>
        <a asp-action="Index" asp-route-filter="GoogleResourceAccessGranted"
           class="btn btn-sm @Model.ActionFilter.ToAuditFilterButtonClass(nameof(AuditAction.GoogleResourceAccessGranted), "btn-primary", "btn-outline-primary")">
            Access Granted
        </a>
        <a asp-action="Index" asp-route-filter="GoogleResourceAccessRevoked"
           class="btn btn-sm @Model.ActionFilter.ToAuditFilterButtonClass(nameof(AuditAction.GoogleResourceAccessRevoked), "btn-primary", "btn-outline-primary")">
            Access Revoked
        </a>
        <a asp-action="Index" asp-route-filter="MemberSuspended"
           class="btn btn-sm @Model.ActionFilter.ToAuditFilterButtonClass(nameof(AuditAction.MemberSuspended), "btn-primary", "btn-outline-primary")">
            Suspensions
        </a>
        <a asp-action="Index" asp-route-filter="RoleAssigned"
           class="btn btn-sm @Model.ActionFilter.ToAuditFilterButtonClass(nameof(AuditAction.RoleAssigned), "btn-primary", "btn-outline-primary")">
            Roles
        </a>
    </div>
</div>

@if (Model.Events.Count == 0)
{
    <div class="alert alert-info">
        No audit log entries found.
    </div>
}
else
{
    Func<Humans.Application.Services.AuditLog.AuditEvent, IHtmlContent> whenCell =
        @<text><span class="text-nowrap">@item.OccurredAt.ToInvariantTimestamp()</span></text>;
    Func<Humans.Application.Services.AuditLog.AuditEvent, IHtmlContent> actorCell = @<text>
        @if (!item.ActorUserId.HasValue)
        {
            <span class="badge bg-info">System</span>
        }
        else
        {
            <vc:human user-id="@item.ActorUserId.Value" />
        }
    </text>;
    Func<Humans.Application.Services.AuditLog.AuditEvent, IHtmlContent> actionCell =
        @<text><span class="badge @item.Action.ToAuditBadgeClass()">@item.Action.ToAuditBadgeLabel()</span></text>;
    Func<Humans.Application.Services.AuditLog.AuditEvent, IHtmlContent> subjectCell = @<text>
        @if (item.SubjectUserId.HasValue)
        {
            <vc:human user-id="@item.SubjectUserId.Value" />
        }
    </text>;
    Func<Humans.Application.Services.AuditLog.AuditEvent, IHtmlContent> targetCell = @<text>
        @if (item.TargetTeamId.HasValue && !string.IsNullOrEmpty(item.TargetTeamName))
        {
            <a asp-controller="Team" asp-action="Details" asp-route-slug="@item.TargetTeamSlug" class="text-decoration-none">@item.TargetTeamName</a>
        }
    </text>;
    var pager = new PagerViewModel(Model.TotalPages, Model.PageNumber, "Index") { NavCssClass = "mt-3" };
    var table = TableModel.For(Model.Events)
        .Template("When", whenCell)
        .Template("Actor", actorCell)
        .Template("Action", actionCell)
        .Template("Subject", subjectCell)
        .Column("Description", ev => ev.Description)
        .Template("Target", targetCell)
        .RowCss(ev => ev.Action.ToAuditEntryRowClass())
        .ServerMode(null, false, pager)
        .Build();
    <div class="card">
        <partial name="_Table" model="table" />
    </div>
}

<div class="mt-3">
    <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary">Back to Dashboard</a>
</div>
