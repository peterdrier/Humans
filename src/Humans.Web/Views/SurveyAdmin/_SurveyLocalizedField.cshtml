@using Humans.Web.Extensions
@model SurveyLocalizedFieldModel

@{
    // The builder edits one culture at a time (spec §6): every culture's input is in the DOM so the
    // whole survey posts in one form, but only the active culture (the culture-tab switcher in
    // Builder.cshtml) is visible. Server renders the initial state so there is no flash before JS.
    var active = ViewData["SurveyActiveCulture"] as string ?? CultureCatalog.DefaultCultureCode;
}
<div class="mb-2 survey-localized-field">
    <label class="form-label small fw-semibold mb-1">@Model.Label</label>
    @foreach (var culture in CultureCatalog.SupportedCultureCodes)
    {
        var name = $"{Model.NamePrefix}[{culture}]";
        Model.Values.TryGetValue(culture, out var value);
        <div class="survey-culture-field input-group input-group-sm mb-1" data-culture="@culture"
             style="@(culture == active ? "" : "display:none")">
            <span class="input-group-text" style="min-width:3.5rem;">@culture.ToDisplayLanguageName()</span>
            @if (Model.Multiline)
            {
                <textarea name="@name" class="form-control" rows="2">@value</textarea>
            }
            else
            {
                <input type="text" name="@name" class="form-control" value="@value" />
            }
        </div>
    }
</div>
