@using Humans.Domain.Enums
@using Humans.Web.Extensions
@model SurveyBuilderViewModel

@{
    ViewData["Title"] = Model.IsNew ? "New survey" : "Edit survey";
    // The culture the localized-field partials render visible initially (see _SurveyLocalizedField).
    ViewData["SurveyActiveCulture"] = Model.DefaultCulture;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index">Admin</a></li>
        <li class="breadcrumb-item"><a asp-controller="SurveyAdmin" asp-action="Index">Surveys</a></li>
        <li class="breadcrumb-item active" aria-current="page">@ViewData["Title"]</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">@ViewData["Title"]</h1>
    @if (!Model.IsNew)
    {
        <div class="d-flex align-items-center gap-2">
            <span class="badge @(Model.Status == SurveyStatus.Open ? "bg-success" : Model.Status == SurveyStatus.Closed ? "bg-secondary" : "bg-warning text-dark")">@Model.Status</span>
            @if (Model.Status != SurveyStatus.Open)
            {
                <form asp-controller="SurveyAdmin" asp-action="Open" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success btn-sm">Open</button>
                </form>
            }
            @if (Model.Status == SurveyStatus.Open)
            {
                <form asp-controller="SurveyAdmin" asp-action="Close" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-secondary btn-sm" data-confirm="Close this survey to new responses?">Close</button>
                </form>
            }
        </div>
    }
</div>

<vc:temp-data-alerts />

<div asp-validation-summary="All" class="alert alert-danger" role="alert" style="@(ViewData.ModelState.IsValid ? "display:none" : "")"></div>

<form asp-controller="SurveyAdmin" asp-action="Save" method="post" id="survey-builder-form">
    @Html.AntiForgeryToken()
    @if (!Model.IsNew)
    {
        <input type="hidden" asp-for="Id" />
    }
    <input type="hidden" asp-for="Status" />

    @* One culture is edited at a time; the badge counts fields still missing vs the default language. *@
    <div class="d-flex flex-wrap align-items-center gap-1 mb-2" id="culture-tabs">
        <span class="small text-muted me-1">Editing language:</span>
        @foreach (var c in CultureCatalog.SupportedCultureCodes)
        {
            <button type="button" data-culture="@c"
                    class="btn btn-sm culture-tab @(c == Model.DefaultCulture ? "btn-primary" : "btn-outline-secondary")">
                @c.ToDisplayLanguageName()
                <span class="badge text-bg-warning missing-badge" style="display:none"></span>
            </button>
        }
    </div>

    <div class="card mb-3">
        <div class="card-header py-2"><strong>Survey</strong></div>
        <div class="card-body">
            <partial name="_SurveyLocalizedField" model="@(new SurveyLocalizedFieldModel(nameof(Model.Title), "Title", Model.Title))" />
            <partial name="_SurveyLocalizedField" model="@(new SurveyLocalizedFieldModel(nameof(Model.Intro), "Intro", Model.Intro, Multiline: true))" />
            <partial name="_SurveyLocalizedField" model="@(new SurveyLocalizedFieldModel(nameof(Model.ThankYou), "Thank-you", Model.ThankYou, Multiline: true))" />

            <div class="row g-3 mt-1">
                <div class="col-md-3">
                    <label class="form-label small">Default language</label>
                    <select asp-for="DefaultCulture" class="form-select form-select-sm">
                        @* asp-for selects the matching option — no manual selected attribute. *@
                        @foreach (var c in CultureCatalog.SupportedCultureCodes)
                        {
                            <option value="@c">@c.ToDisplayLanguageName()</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Opens at</label>
                    <input type="datetime-local" name="OpensAt" value="@Model.OpensAtInput" class="form-control form-control-sm" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Closes at</label>
                    <input type="datetime-local" name="ClosesAt" value="@Model.ClosesAtInput" class="form-control form-control-sm" />
                </div>
                <div class="col-md-3 align-self-end">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="allowAnon" asp-for="AllowAnonymous" />
                        <label class="form-check-label small" for="allowAnon">Allow anonymous responses</label>
                    </div>
                </div>
            </div>

            <div class="row g-3 mt-1">
                <div class="col-md-3">
                    <label class="form-label small">Audience</label>
                    <select asp-for="AudienceType" class="form-select form-select-sm">
                        <option value="">(choose at send time)</option>
                        @foreach (var a in Enum.GetValues<SurveyAudienceType>())
                        {
                            <option value="@a">@a</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Team (if audience = Team)</label>
                    <select asp-for="AudienceTeamId" class="form-select form-select-sm">
                        <option value="">—</option>
                        @foreach (var t in Model.Teams)
                        {
                            <option value="@t.Id">@t.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2" id="logged-in-since-field" style="@(Model.AudienceType == SurveyAudienceType.LoggedInSince ? "" : "display:none")">
                    <label class="form-label small">Logged in since</label>
                    <input type="date" name="AudienceLoggedInSince" value="@Model.AudienceLoggedInSinceInput" class="form-control form-control-sm" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small">Public link slug (optional; requires Allow anonymous)</label>
                    <input type="text" asp-for="PublicSlug" class="form-control form-control-sm" placeholder="e.g. feedback-2026" />
                </div>
            </div>
        </div>
    </div>

    <h2 class="h5">Questions</h2>
    <div id="questions-container">
        @foreach (var (q, i) in Model.Questions.Select((q, i) => (q, i)))
        {
            <partial name="_SurveyQuestionCard" model="@(new SurveyQuestionCardModel(i.ToString(), q))" />
        }
    </div>

    <template id="question-template">
        <partial name="_SurveyQuestionCard" model="@(new SurveyQuestionCardModel("__QKEY__", new SurveyQuestionBuilderViewModel()))" />
    </template>

    <div class="d-flex justify-content-between mt-3">
        <button type="button" class="btn btn-outline-secondary btn-sm" id="add-question">+ Add question</button>
        <div class="d-flex gap-2">
            <button type="submit" name="submitAction" value="save-translate" class="btn btn-outline-primary"
                    title="Saves, then machine-translates fields still missing in other languages from the default language. Existing text is never overwritten — review before opening.">
                Save + translate missing
            </button>
            <button type="submit" class="btn btn-primary">Save survey</button>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        (function () {
            const container = document.getElementById('questions-container');
            const qTemplate = document.getElementById('question-template');
            const defaultCulture = document.querySelector('select[name="DefaultCulture"]');

            function freshKey(p) { return p + Math.random().toString(36).slice(2) + Date.now().toString(36); }

            function uuid() {
                return (crypto.randomUUID && crypto.randomUUID()) ||
                    'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, ch => {
                        const r = Math.random() * 16 | 0;
                        return (ch === 'x' ? r : (r & 0x3 | 0x8)).toString(16);
                    });
            }

            // ── culture switcher ─────────────────────────────────────────────
            let activeCulture = defaultCulture.value;

            function applyCulture(scope) {
                (scope || document).querySelectorAll('.survey-culture-field').forEach(el => {
                    el.style.display = el.dataset.culture === activeCulture ? '' : 'none';
                });
            }

            function cultureInput(group, culture) {
                return group.querySelector('.survey-culture-field[data-culture="' + culture + '"] input, ' +
                                           '.survey-culture-field[data-culture="' + culture + '"] textarea');
            }

            function updateMissingBadges() {
                const src = defaultCulture.value;
                const groups = Array.from(document.querySelectorAll('.survey-localized-field'));
                document.querySelectorAll('.culture-tab').forEach(tab => {
                    const badge = tab.querySelector('.missing-badge');
                    const culture = tab.dataset.culture;
                    if (culture === src) { badge.style.display = 'none'; return; }
                    let missing = 0;
                    groups.forEach(g => {
                        const s = cultureInput(g, src);
                        const t = cultureInput(g, culture);
                        if (s && t && s.value.trim() && !t.value.trim()) missing++;
                    });
                    badge.textContent = missing;
                    badge.style.display = missing ? '' : 'none';
                });
            }

            document.querySelectorAll('.culture-tab').forEach(tab => tab.addEventListener('click', () => {
                activeCulture = tab.dataset.culture;
                document.querySelectorAll('.culture-tab').forEach(t => {
                    t.classList.toggle('btn-primary', t === tab);
                    t.classList.toggle('btn-outline-secondary', t !== tab);
                });
                applyCulture();
                updateMissingBadges();
            }));

            // ── audience cutoff visibility ───────────────────────────────────
            const audienceType = document.querySelector('select[name="AudienceType"]');
            const loggedInSinceField = document.getElementById('logged-in-since-field');

            function applyAudienceVisibility() {
                loggedInSinceField.style.display = audienceType.value === 'LoggedInSince' ? '' : 'none';
            }

            audienceType.addEventListener('change', applyAudienceVisibility);
            applyAudienceVisibility();

            // ── question cards ───────────────────────────────────────────────
            function applyTypeVisibility(card) {
                const type = card.querySelector('.question-type')?.value;
                const ratings = card.querySelector('.rating-section');
                const options = card.querySelector('.options-section');
                const isChoice = type === 'SingleChoice' || type === 'MultiChoice';
                if (options) options.style.display = isChoice ? '' : 'none';
                if (ratings) ratings.style.display = type === 'Rating' ? '' : 'none';
            }

            function ensureQuestionId(card) {
                const id = card.querySelector('.question-id');
                if (id && !id.value) id.value = uuid();
            }

            function addOption(card) {
                const tpl = card.querySelector('.option-template');
                if (!tpl) return;
                const html = tpl.innerHTML.replaceAll('__OKEY__', freshKey('o'));
                card.querySelector('.options-container').insertAdjacentHTML('beforeend', html);
                applyCulture(card.querySelector('.options-container').lastElementChild);
            }

            // ── show-if clause editor ────────────────────────────────────────
            function questionCards() { return Array.from(container.querySelectorAll('.question-card')); }

            function questionLabel(card, index) {
                // The first localized field on a card is its Prompt.
                const prompt = card.querySelector('.survey-localized-field');
                const text = prompt && cultureInput(prompt, defaultCulture.value)?.value.trim() || '(untitled)';
                return 'Q' + (index + 1) + ': ' + (text.length > 60 ? text.slice(0, 57) + '…' : text);
            }

            function populateQuestionSelect(select) {
                const current = select.value;
                const ownCard = select.closest('.question-card');
                select.innerHTML = '';
                select.add(new Option('— choose a question —', ''));
                questionCards().forEach((card, i) => {
                    if (card === ownCard) return;
                    const id = card.querySelector('.question-id')?.value;
                    if (id) select.add(new Option(questionLabel(card, i), id));
                });
                select.value = current;
                if (select.value !== current) select.value = ''; // referenced question is gone
            }

            function populateOptionValues(row) {
                const select = row.querySelector('.clause-options');
                const op = row.querySelector('.clause-operator').value;
                const needsValues = op === 'Is' || op === 'IsNot';
                select.style.display = needsValues ? '' : 'none';
                if (!needsValues) { Array.from(select.options).forEach(o => o.selected = false); return; }

                const selected = new Set(Array.from(select.selectedOptions).map(o => o.value));
                select.innerHTML = '';
                const targetId = row.querySelector('.clause-question').value;
                const target = questionCards().find(c => c.querySelector('.question-id')?.value === targetId);
                if (!target) return;
                target.querySelectorAll('.option-row').forEach(or => {
                    const value = or.querySelector('input[name$=".Value"]')?.value.trim();
                    if (!value) return;
                    const labelText = cultureInput(or, defaultCulture.value)?.value.trim();
                    const label = labelText ? labelText + ' (' + value + ')' : value;
                    select.add(new Option(label, value, false, selected.has(value)));
                });
            }

            function updateCombineVisibility(card) {
                const combine = card.querySelector('.showif-combine');
                if (combine) combine.style.display =
                    card.querySelectorAll('.clauses-container .clause-row').length > 1 ? '' : 'none';
            }

            function addClause(card) {
                const tpl = card.querySelector('.clause-template');
                const html = tpl.innerHTML.replaceAll('__CKEY__', freshKey('c'));
                const clauses = card.querySelector('.clauses-container');
                clauses.insertAdjacentHTML('beforeend', html);
                populateQuestionSelect(clauses.lastElementChild.querySelector('.clause-question'));
                populateOptionValues(clauses.lastElementChild);
                updateCombineVisibility(card);
            }

            function removeClauseRowsReferencing(questionId) {
                document.querySelectorAll('.clause-question').forEach(sel => {
                    if (sel.value === questionId) {
                        const card = sel.closest('.question-card');
                        sel.closest('.clause-row').remove();
                        updateCombineVisibility(card);
                    }
                });
            }

            function initCard(card) {
                ensureQuestionId(card);
                applyTypeVisibility(card);
                updateCombineVisibility(card);
                card.querySelectorAll('.clause-row').forEach(row => {
                    populateQuestionSelect(row.querySelector('.clause-question'));
                    populateOptionValues(row);
                });
            }

            // ── events ───────────────────────────────────────────────────────
            document.getElementById('add-question').addEventListener('click', function () {
                const html = qTemplate.innerHTML.replaceAll('__QKEY__', freshKey('q'));
                container.insertAdjacentHTML('beforeend', html);
                const card = container.lastElementChild;
                initCard(card);
                applyCulture(card);
            });

            container.addEventListener('click', function (e) {
                if (e.target.classList.contains('remove-question')) {
                    const card = e.target.closest('.question-card');
                    const id = card.querySelector('.question-id')?.value;
                    card.remove();
                    if (id) removeClauseRowsReferencing(id);
                } else if (e.target.classList.contains('add-option')) {
                    addOption(e.target.closest('.question-card'));
                } else if (e.target.classList.contains('remove-option')) {
                    e.target.closest('.option-row').remove();
                } else if (e.target.classList.contains('add-clause')) {
                    addClause(e.target.closest('.question-card'));
                } else if (e.target.classList.contains('remove-clause')) {
                    const card = e.target.closest('.question-card');
                    e.target.closest('.clause-row').remove();
                    if (card.querySelectorAll('.clauses-container .clause-row').length === 0) {
                        card.querySelector('.showif-mode').value = 'always';
                        card.querySelector('.showif-clauses').style.display = 'none';
                    }
                    updateCombineVisibility(card);
                }
            });

            container.addEventListener('change', function (e) {
                if (e.target.classList.contains('question-type')) {
                    applyTypeVisibility(e.target.closest('.question-card'));
                } else if (e.target.classList.contains('showif-mode')) {
                    const card = e.target.closest('.question-card');
                    const conditional = e.target.value === 'conditional';
                    card.querySelector('.showif-clauses').style.display = conditional ? '' : 'none';
                    if (conditional && card.querySelectorAll('.clauses-container .clause-row').length === 0) {
                        addClause(card);
                    } else if (!conditional) {
                        card.querySelectorAll('.clauses-container .clause-row').forEach(r => r.remove());
                        updateCombineVisibility(card);
                    }
                } else if (e.target.classList.contains('clause-question') || e.target.classList.contains('clause-operator')) {
                    populateOptionValues(e.target.closest('.clause-row'));
                }
            });

            // Refresh a clause's question list right before the user opens it, so prompt edits,
            // newly added questions and removals are always reflected.
            container.addEventListener('focusin', function (e) {
                if (e.target.classList.contains('clause-question')) populateQuestionSelect(e.target);
            });

            defaultCulture.addEventListener('change', updateMissingBadges);

            let badgeTimer = null;
            document.getElementById('survey-builder-form').addEventListener('input', function () {
                clearTimeout(badgeTimer);
                badgeTimer = setTimeout(updateMissingBadges, 500);
            });

            questionCards().forEach(initCard);
            applyCulture();
            updateMissingBadges();
        })();
    </script>
}
