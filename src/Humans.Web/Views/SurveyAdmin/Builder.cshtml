@using Humans.Domain.Enums
@using Humans.Web.Extensions
@model SurveyBuilderViewModel

@{
    ViewData["Title"] = Model.IsNew ? "New survey" : "Edit survey";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index">Admin</a></li>
        <li class="breadcrumb-item"><a asp-controller="SurveyAdmin" asp-action="Index">Surveys</a></li>
        <li class="breadcrumb-item active" aria-current="page">@ViewData["Title"]</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">@ViewData["Title"]</h1>
    @if (!Model.IsNew)
    {
        <div class="d-flex align-items-center gap-2">
            <span class="badge @(Model.Status == SurveyStatus.Open ? "bg-success" : Model.Status == SurveyStatus.Closed ? "bg-secondary" : "bg-warning text-dark")">@Model.Status</span>
            @if (Model.Status != SurveyStatus.Open)
            {
                <form asp-controller="SurveyAdmin" asp-action="Open" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success btn-sm">Open</button>
                </form>
            }
            @if (Model.Status == SurveyStatus.Open)
            {
                <form asp-controller="SurveyAdmin" asp-action="Close" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-secondary btn-sm" data-confirm="Close this survey to new responses?">Close</button>
                </form>
            }
        </div>
    }
</div>

<vc:temp-data-alerts />

<div asp-validation-summary="All" class="alert alert-danger" role="alert" style="@(ViewData.ModelState.IsValid ? "display:none" : "")"></div>

<form asp-controller="SurveyAdmin" asp-action="Save" method="post">
    @Html.AntiForgeryToken()
    @if (!Model.IsNew)
    {
        <input type="hidden" asp-for="Id" />
    }
    <input type="hidden" asp-for="Status" />

    <div class="card mb-3">
        <div class="card-header py-2"><strong>Survey</strong></div>
        <div class="card-body">
            <partial name="_SurveyLocalizedField" model="@(new SurveyLocalizedFieldModel(nameof(Model.Title), "Title", Model.Title))" />
            <partial name="_SurveyLocalizedField" model="@(new SurveyLocalizedFieldModel(nameof(Model.Intro), "Intro", Model.Intro, Multiline: true))" />
            <partial name="_SurveyLocalizedField" model="@(new SurveyLocalizedFieldModel(nameof(Model.ThankYou), "Thank-you", Model.ThankYou, Multiline: true))" />

            <div class="row g-3 mt-1">
                <div class="col-md-3">
                    <label class="form-label small">Default language</label>
                    <select asp-for="DefaultCulture" class="form-select form-select-sm">
                        @foreach (var c in CultureCatalog.SupportedCultureCodes)
                        {
                            <option value="@c" selected="@(Model.DefaultCulture == c ? "selected" : null)">@c.ToDisplayLanguageName()</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Opens at</label>
                    <input type="datetime-local" name="OpensAt" value="@Model.OpensAtInput" class="form-control form-control-sm" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Closes at</label>
                    <input type="datetime-local" name="ClosesAt" value="@Model.ClosesAtInput" class="form-control form-control-sm" />
                </div>
                <div class="col-md-3 align-self-end">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="allowAnon" asp-for="AllowAnonymous" />
                        <label class="form-check-label small" for="allowAnon">Allow anonymous responses</label>
                    </div>
                </div>
            </div>

            <div class="row g-3 mt-1">
                <div class="col-md-3">
                    <label class="form-label small">Audience</label>
                    <select asp-for="AudienceType" class="form-select form-select-sm">
                        <option value="">(choose at send time)</option>
                        @foreach (var a in Enum.GetValues<SurveyAudienceType>())
                        {
                            <option value="@a" selected="@(Model.AudienceType == a ? "selected" : null)">@a</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Team (if audience = Team)</label>
                    <select asp-for="AudienceTeamId" class="form-select form-select-sm">
                        <option value="">—</option>
                        @foreach (var t in Model.Teams)
                        {
                            <option value="@t.Id" selected="@(Model.AudienceTeamId == t.Id ? "selected" : null)">@t.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Public link slug (optional; requires Allow anonymous)</label>
                    <input type="text" asp-for="PublicSlug" class="form-control form-control-sm" placeholder="e.g. feedback-2026" />
                </div>
            </div>
        </div>
    </div>

    <h2 class="h5">Questions</h2>
    <div id="questions-container">
        @foreach (var (q, i) in Model.Questions.Select((q, i) => (q, i)))
        {
            <partial name="_SurveyQuestionCard" model="@(new SurveyQuestionCardModel(i.ToString(), q))" />
        }
    </div>

    <template id="question-template">
        <partial name="_SurveyQuestionCard" model="@(new SurveyQuestionCardModel("__QKEY__", new SurveyQuestionBuilderViewModel()))" />
    </template>

    <div class="d-flex justify-content-between mt-3">
        <button type="button" class="btn btn-outline-secondary btn-sm" id="add-question">+ Add question</button>
        <button type="submit" class="btn btn-primary">Save survey</button>
    </div>
</form>

@section Scripts {
    <script>
        (function () {
            const container = document.getElementById('questions-container');
            const qTemplate = document.getElementById('question-template');

            function freshKey(p) { return p + Math.random().toString(36).slice(2) + Date.now().toString(36); }

            function applyTypeVisibility(card) {
                const type = card.querySelector('.question-type')?.value;
                const ratings = card.querySelector('.rating-section');
                const options = card.querySelector('.options-section');
                const isChoice = type === 'SingleChoice' || type === 'MultiChoice';
                if (options) options.style.display = isChoice ? '' : 'none';
                if (ratings) ratings.style.display = type === 'Rating' ? '' : 'none';
            }

            function addOption(card) {
                const tpl = card.querySelector('.option-template');
                if (!tpl) return;
                const html = tpl.innerHTML.replaceAll('__OKEY__', freshKey('o'));
                card.querySelector('.options-container').insertAdjacentHTML('beforeend', html);
            }

            document.getElementById('add-question').addEventListener('click', function () {
                const html = qTemplate.innerHTML.replaceAll('__QKEY__', freshKey('q'));
                container.insertAdjacentHTML('beforeend', html);
                applyTypeVisibility(container.lastElementChild);
            });

            container.addEventListener('click', function (e) {
                if (e.target.classList.contains('remove-question')) {
                    e.target.closest('.question-card').remove();
                } else if (e.target.classList.contains('add-option')) {
                    addOption(e.target.closest('.question-card'));
                } else if (e.target.classList.contains('remove-option')) {
                    e.target.closest('.option-row').remove();
                }
            });

            container.addEventListener('change', function (e) {
                if (e.target.classList.contains('question-type')) {
                    applyTypeVisibility(e.target.closest('.question-card'));
                }
            });

            container.querySelectorAll('.question-card').forEach(applyTypeVisibility);
        })();
    </script>
}
