@using Humans.Web.Models.Gate
@model IReadOnlyList<GateLeaderboardRowViewModel>
@{
    ViewData["Title"] = "Gate leaderboard";
}

@section Styles {
    <link rel="stylesheet" href="@Url.Content("~/css/gate/gate.css")" asp-append-version="true" />
}

@* The kiosk is chromeless (no browser back), so a prominent return path is mandatory — without it
   the operator is stranded here mid-queue. *@
<a asp-action="Index" class="gate-back">&larr; Back to scanning</a>

<h1>Gate leaderboard</h1>
<p class="text-muted">
    <strong>@ViewData["TotalAdmitted"]</strong> admitted ·
    <strong>@ViewData["TotalScanned"]</strong> scans (last 7 days)
</p>

@if (Model.Count == 0)
{
    <p class="text-muted">No scans yet.</p>
}
else
{
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Scanner</th>
                <th class="text-end">Admitted</th>
                <th class="text-end">Issues caught</th>
                <th class="text-end">Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model)
            {
                <tr>
                    <td><vc:human user-id="@row.ScannedByUserId" /></td>
                    <td class="text-end">@row.Admitted</td>
                    <td class="text-end">@row.Rejected</td>
                    <td class="text-end">@row.Total</td>
                </tr>
            }
        </tbody>
    </table>
}
