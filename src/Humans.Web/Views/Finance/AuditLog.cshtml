@model IReadOnlyList<Humans.Application.Interfaces.Budget.BudgetAuditLogSnapshot>
@using Humans.Application.Interfaces.Budget
@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@{
    ViewData["Title"] = "Budget Audit Log";
    var yearId = ViewBag.YearId as Guid?;
    var years = ViewBag.Years as IReadOnlyList<Humans.Application.Interfaces.Budget.BudgetYearSummarySnapshot> ?? [];
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Budget Audit Log</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="fa-solid fa-arrow-left me-1"></i>Back to Finance
    </a>
</div>


@if (years.Count > 0)
{
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" asp-action="AuditLog" class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="form-label">Filter by Year</label>
                    <select name="yearId" class="form-select js-auto-submit">
                        <option value="">All Years</option>
                        @foreach (var y in years)
                        {
                            <option value="@y.Id" selected="@(yearId == y.Id ? "selected" : null)">@y.Name@(y.IsDeleted ? " (Archived)" : "")</option>
                        }
                    </select>
                </div>
            </form>
        </div>
    </div>
}

@if (Model.Count > 0)
{
    Func<BudgetAuditLogSnapshot, IHtmlContent> whoCell =
        @<text><vc:human user-id="@item.ActorUserId" /></text>;
    Func<BudgetAuditLogSnapshot, IHtmlContent> entityTypeCell =
        @<text><span class="badge bg-secondary">@item.EntityType</span></text>;
    Func<BudgetAuditLogSnapshot, IHtmlContent> oldValueCell = @<text>
        @if (!string.IsNullOrEmpty(item.OldValue))
        {
            <span class="text-danger">@item.OldValue</span>
        }
    </text>;
    Func<BudgetAuditLogSnapshot, IHtmlContent> newValueCell = @<text>
        @if (!string.IsNullOrEmpty(item.NewValue))
        {
            <span class="text-success">@item.NewValue</span>
        }
    </text>;
    var auditTable = TableModel.For(Model)
        .Column("Time", r => r.OccurredAt.ToDateTimeUtc().ToString("g", System.Globalization.CultureInfo.CurrentCulture), c => c.Css("text-nowrap"))
        .Template("Who", whoCell)
        .Template("Entity Type", entityTypeCell)
        .Column("Description", r => r.Description)
        .Column("Field", r => r.FieldName ?? "")
        .Template("Old Value", oldValueCell)
        .Template("New Value", newValueCell)
        .Build();
    <div class="card">
        <partial name="_Table" model="auditTable" />
    </div>
}
else
{
    <div class="card">
        <div class="card-body text-center py-4 text-muted">
            No audit log entries found.
        </div>
    </div>
}
