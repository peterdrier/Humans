@{
    ViewData["Title"] = "Finance";
    var years = ViewBag.Years as IReadOnlyList<BudgetYear> ?? [];
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Finance</h1>
    <a asp-action="Admin" class="btn btn-outline-primary">
        <i class="fa-solid fa-gear me-1"></i>Finance Admin
    </a>
</div>

<vc:temp-data-alerts />

<div class="card">
    <div class="card-body text-center py-5">
        <i class="fa-solid fa-chart-pie text-muted" style="font-size: 3rem;"></i>
        <h3 class="mt-3">No active budget year</h3>
        <p class="text-muted">Create and activate a budget year in Finance Admin to get started.</p>
        <a asp-action="Admin" class="btn btn-primary">
            <i class="fa-solid fa-plus me-1"></i>Go to Finance Admin
        </a>
    </div>
</div>

@if (years.Count > 0)
{
    <div class="card mt-4">
        <div class="card-header">Existing Budget Years</div>
        <div class="list-group list-group-flush">
            @foreach (var y in years)
            {
                <a asp-action="YearDetail" asp-route-id="@y.Id" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    @y.Name
                    <span class="badge bg-@(y.Status == BudgetYearStatus.Draft ? "warning" : "secondary")">@y.Status</span>
                </a>
            }
        </div>
    </div>
}
