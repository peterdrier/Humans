@model IReadOnlyList<Humans.Application.Services.Finance.Dtos.HoldedUnmatchedRow>
@using Humans.Application.Services.Finance.Dtos
@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@{
    ViewData["Title"] = "Holded Unmatched Documents";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Holded Unmatched Documents</h1>
    <div class="d-flex gap-2">
        <form asp-action="RunHoldedSync" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-primary">
                <i class="fa-solid fa-arrows-rotate me-1"></i>Sync Now
            </button>
        </form>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fa-solid fa-arrow-left me-1"></i>Back to Finance
        </a>
    </div>
</div>


@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="fa-solid fa-circle-check fa-2x text-success mb-3"></i>
            <p class="mb-0 text-muted">No unmatched documents — every Holded purchase is mapped to a budget category.</p>
        </div>
    </div>
}
else
{
    Func<HoldedUnmatchedRow, IHtmlContent> totalCell =
        @<text><span class="text-danger">&euro;@item.Total.ToString("N2", System.Globalization.CultureInfo.CurrentCulture)</span></text>;
    Func<HoldedUnmatchedRow, IHtmlContent> linkCell =
        @<text><a href="@item.HoldedUrl" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-arrow-up-right-from-square me-1"></i>Holded</a></text>;
    var unmatchedTable = TableModel.For(Model)
        .Column("Doc #", r => r.DocNumber)
        .Column("Contact", r => r.ContactName)
        .Template("Total", totalCell, c => c.NoSort().End())
        .Column("Reason", r => r.Reason, c => c.Css("text-muted small"))
        .Template("", linkCell, c => c.NoSort())
        .Build();
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="fa-solid fa-triangle-exclamation me-1 text-warning"></i>Unmatched Documents</span>
            <span class="badge bg-warning text-dark">@Model.Count unmatched</span>
        </div>
        <partial name="_Table" model="unmatchedTable" />
    </div>
}
