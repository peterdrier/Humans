@model System.Collections.Generic.IReadOnlyList<Humans.Domain.Entities.AgentConversation>
@{ ViewData["Title"] = "Agent — Conversations"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Agent Conversations</h2>
    <a asp-action="Settings" class="btn btn-outline-secondary btn-sm">Settings</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <div class="form-check form-check-inline">
            <input class="form-check-input" type="checkbox" name="refusalsOnly" value="true" @(Context.Request.Query["refusalsOnly"] == "true" ? "checked" : "") id="refusalsOnly" />
            <label class="form-check-label" for="refusalsOnly">Refusals only</label>
        </div>
        <div class="form-check form-check-inline">
            <input class="form-check-input" type="checkbox" name="handoffsOnly" value="true" @(Context.Request.Query["handoffsOnly"] == "true" ? "checked" : "") id="handoffsOnly" />
            <label class="form-check-label" for="handoffsOnly">Handoffs only</label>
        </div>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary btn-sm">Filter</button>
    </div>
</form>

@if (!Model.Any())
{
    <p class="text-muted">No conversations found.</p>
}
else
{
    <table class="table table-sm table-hover">
        <thead>
            <tr>
                <th>Started</th>
                <th>User</th>
                <th>Locale</th>
                <th>Messages</th>
                <th>Last Message</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var conv in Model)
            {
                <tr>
                    <td>@conv.StartedAt.ToDateTimeUtc().ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@conv.UserId</td>
                    <td>@conv.Locale</td>
                    <td>@conv.MessageCount</td>
                    <td>@conv.LastMessageAt.ToDateTimeUtc().ToString("yyyy-MM-dd HH:mm")</td>
                    <td><a asp-action="ConversationDetail" asp-route-id="@conv.Id">View</a></td>
                </tr>
            }
        </tbody>
    </table>
}
