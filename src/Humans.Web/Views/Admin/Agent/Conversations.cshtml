@using Humans.Web.Extensions
@model System.Collections.Generic.IReadOnlyList<Humans.Web.Controllers.AdminAgentConversationRow>
@{ ViewData["Title"] = "Agent — Conversations"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Agent Conversations</h2>
    <a asp-action="Settings" class="btn btn-outline-secondary btn-sm">Settings</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <div class="form-check form-check-inline">
            <input class="form-check-input" type="checkbox" name="refusalsOnly" value="true" @(Context.Request.Query["refusalsOnly"] == "true" ? "checked" : null) id="refusalsOnly" />
            <label class="form-check-label" for="refusalsOnly">Refusals only</label>
        </div>
        <div class="form-check form-check-inline">
            <input class="form-check-input" type="checkbox" name="handoffsOnly" value="true" @(Context.Request.Query["handoffsOnly"] == "true" ? "checked" : null) id="handoffsOnly" />
            <label class="form-check-label" for="handoffsOnly">Handoffs only</label>
        </div>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary btn-sm">Filter</button>
    </div>
</form>

@if (!Model.Any())
{
    <p class="text-muted">No conversations found.</p>
}
else
{
    @* width:auto + Bootstrap's table-sm — grid sizes to content rather than spanning the full column. *@
    <table class="table table-sm table-hover" style="width: auto;">
        <thead>
            <tr>
                <th>Started</th>
                <th>Human</th>
                <th>Locale</th>
                <th class="text-end">Messages</th>
                <th>Last Message</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model)
            {
                var conv = row.Conversation;
                <tr>
                    <td class="text-nowrap">@conv.StartedAt.ToAuditMinuteTimestamp()</td>
                    <td><human-link user-id="@conv.UserId" display-name="@row.DisplayName" admin="true" /></td>
                    <td>@conv.Locale</td>
                    <td class="text-end">@conv.MessageCount</td>
                    <td class="text-nowrap">@conv.LastMessageAt.ToAuditMinuteTimestamp()</td>
                    <td><a asp-action="ConversationDetail" asp-route-id="@conv.Id">View</a></td>
                </tr>
            }
        </tbody>
    </table>
}
