@using Humans.Application.Services.Cantina.Dtos
@using NodaTime
@using NodaTime.Text
@model WeeklyRosterDto

@functions {
    // Compact day display "Mon 27 May" — used for header subtitle, per-day
    // mini-table, person row "days on site" chips. Invariant culture so the
    // string is stable across user locales; the surrounding labels are still
    // resx-localized.
    private static readonly LocalDatePattern ShortDayPattern =
        LocalDatePattern.CreateWithInvariantCulture("ddd d MMM");

    private static string FormatDay(LocalDate? d) =>
        d.HasValue ? ShortDayPattern.Format(d.Value) : "";

    private static string FormatDay(LocalDate d) => ShortDayPattern.Format(d);
}

@{
    ViewData["Title"] = Localizer["Cantina_Roster_PageTitle"].Value;

    // Fixed iteration order for the dietary breakdown card.
    // Mirrors DietaryOptions.DietaryPreferences + the "Unanswered" pseudo-bucket
    // that CantinaRosterService always populates on WeeklyRosterDto.DietaryBreakdown.
    var dietaryOrder = new[] { "Omnivore", "Vegetarian", "Vegan", "Pescatarian", "Unanswered" };

    // Subtitle: "<EventName> — Week of <Mon 27 May> – <Sun 2 Jun>" — degrades
    // gracefully when there's no active event or no calendar range.
    string subtitle;
    if (Model.EventName is null)
    {
        subtitle = Localizer["Cantina_Roster_NoActiveEvent"].Value;
    }
    else if (Model.WeekStartDate is null || Model.WeekEndDate is null)
    {
        subtitle = Model.EventName;
    }
    else
    {
        subtitle = $"{Model.EventName} — {Localizer["Cantina_Roster_WeekOf"].Value} {FormatDay(Model.WeekStartDate)} – {FormatDay(Model.WeekEndDate)}";
    }

    // Rollup chips: only show entries with non-zero counts; "—" when all zero.
    string FormatRollup(IEnumerable<RollupItemDto> items)
    {
        var nonZero = items.Where(i => i.Count > 0).ToList();
        return nonZero.Count == 0
            ? "—"
            : string.Join(", ", nonZero.Select(i => $"{i.Label} ({i.Count})"));
    }

    // "Today" comes from the service in the event's timezone (see
    // WeeklyRosterDto.EventTodayDate). Using DateTime.UtcNow here would
    // show tomorrow's row highlighted late in the evening for a Madrid
    // coordinator (CET is ahead of UTC).
    var todayForHighlight = Model.EventTodayDate;
}

@section Styles {
    <style>
        @@media print {
            .week-picker, .btn-download-csv, nav, footer, .alert { display: none !important; }
            .card { border: 1px solid #ddd; page-break-inside: avoid; }
            .table { font-size: 0.9rem; }
            body { background: white; }
            details > summary { list-style: none; }
            details:not([open]) > *:not(summary) { display: block !important; }
        }
    </style>
}

<div class="container py-4">
    @* === Page header + week picker / CSV download =========================== *@
    <div class="d-flex flex-wrap justify-content-between align-items-start mb-3 gap-2">
        <div>
            <h1 class="mb-1">@Localizer["Cantina_Roster_PageTitle"]</h1>
            <div class="text-muted">@subtitle</div>
        </div>
        <div class="d-flex flex-wrap align-items-center gap-2 week-picker">
            <span class="form-label mb-0 small text-muted me-1">@Localizer["Cantina_Roster_WeekPickerLabel"]</span>
            <div class="btn-group" role="group" aria-label="@Localizer["Cantina_Roster_WeekPickerLabel"].Value">
                <a asp-action="Roster" asp-route-weekStartOffset="@(Model.WeekStartOffset - 7)"
                   class="btn btn-sm btn-outline-secondary" title="@Localizer["Cantina_Roster_PrevWeek"].Value">
                    <i class="fa-solid fa-chevron-left"></i>
                    <span class="visually-hidden">@Localizer["Cantina_Roster_PrevWeek"]</span>
                </a>
                <a asp-action="Roster"
                   class="btn btn-sm btn-outline-secondary">@Localizer["Cantina_Roster_ThisWeek"]</a>
                <a asp-action="Roster" asp-route-weekStartOffset="@(Model.WeekStartOffset + 7)"
                   class="btn btn-sm btn-outline-secondary" title="@Localizer["Cantina_Roster_NextWeek"].Value">
                    <span class="visually-hidden">@Localizer["Cantina_Roster_NextWeek"]</span>
                    <i class="fa-solid fa-chevron-right"></i>
                </a>
            </div>
            <a asp-action="Csv" asp-route-weekStartOffset="@Model.WeekStartOffset"
               class="btn btn-sm btn-primary btn-download-csv">
                <i class="fa-solid fa-download me-1"></i>@Localizer["Cantina_Roster_DownloadCsv"]
            </a>
        </div>
    </div>

    @* === Weekly aggregates: 3-card row ====================================== *@
    <div class="row g-3 mb-4">
        @* Card A — Unique humans + Unanswered *@
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="display-5 fw-bold">@Model.TotalUniqueOnSite</div>
                    <div class="text-muted small">@Localizer["Cantina_Roster_TotalOnSite"]</div>
                    <hr class="my-2" />
                    <div class="@(Model.UnansweredCount > 0 ? "text-warning fw-semibold" : "text-muted")">
                        <i class="fa-solid @(Model.UnansweredCount > 0 ? "fa-triangle-exclamation" : "fa-check") me-1"></i>
                        @Model.UnansweredCount @Localizer["Cantina_Roster_Unanswered"]
                    </div>
                </div>
            </div>
        </div>

        @* Card B — Dietary breakdown *@
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="card-title text-muted text-uppercase small">@Localizer["Cantina_Roster_DietaryBreakdown"]</h6>
                    <ul class="list-unstyled mb-0">
                        @foreach (var key in dietaryOrder)
                        {
                            var count = Model.DietaryBreakdown.TryGetValue(key, out var c) ? c : 0;
                            <li class="d-flex justify-content-between align-items-center py-1">
                                <span>@key</span>
                                <span class="badge bg-secondary rounded-pill">@count</span>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        @* Card C — Allergy + intolerance roll-up *@
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="card-title text-muted text-uppercase small">@Localizer["Cantina_Roster_AllergyRollup"]</h6>
                    <div class="mb-3">@FormatRollup(Model.AllergyRollup)</div>
                    <h6 class="card-title text-muted text-uppercase small">@Localizer["Cantina_Roster_IntoleranceRollup"]</h6>
                    <div>@FormatRollup(Model.IntoleranceRollup)</div>
                </div>
            </div>
        </div>
    </div>

    @* === "Other" free-text entries ========================================== *@
    @if (Model.AllergyOtherEntries.Count > 0 || Model.IntoleranceOtherEntries.Count > 0)
    {
        <div class="row g-3 mb-4">
            @if (Model.AllergyOtherEntries.Count > 0)
            {
                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-body">
                            <h6 class="card-title">@Localizer["Cantina_Roster_OtherAllergies"]</h6>
                            <ol class="mb-0 small">
                                @foreach (var entry in Model.AllergyOtherEntries)
                                {
                                    <li>@entry</li>
                                }
                            </ol>
                        </div>
                    </div>
                </div>
            }
            @if (Model.IntoleranceOtherEntries.Count > 0)
            {
                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-body">
                            <h6 class="card-title">@Localizer["Cantina_Roster_OtherIntolerances"]</h6>
                            <ol class="mb-0 small">
                                @foreach (var entry in Model.IntoleranceOtherEntries)
                                {
                                    <li>@entry</li>
                                }
                            </ol>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @* === Per-day mini-summary table ========================================= *@
    <div class="card mb-4">
        <div class="card-body">
            <h6 class="card-title text-muted text-uppercase small">@Localizer["Cantina_Roster_PerDayTable_Heading"]</h6>
            <div class="table-responsive">
                <table class="table table-sm mb-0 align-middle">
                    <thead>
                        <tr>
                            <th scope="col">@Localizer["Cantina_Roster_PerDayTable_Date"]</th>
                            <th scope="col" class="text-end">@Localizer["Cantina_Roster_PerDayTable_Total"]</th>
                            <th scope="col" class="text-end">@Localizer["Cantina_Roster_PerDayTable_Unanswered"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var day in Model.Days)
                        {
                            var isToday = todayForHighlight is not null
                                && day.CalendarDate.HasValue
                                && day.CalendarDate.Value == todayForHighlight.Value;
                            var label = day.CalendarDate.HasValue
                                ? FormatDay(day.CalendarDate.Value)
                                : $"Day {day.DayOffset}";
                            <tr class="@(isToday ? "table-active fw-semibold" : "")">
                                <td>@label</td>
                                <td class="text-end">@day.TotalOnSite</td>
                                <td class="text-end @(day.UnansweredOnDay > 0 ? "text-warning" : "text-muted")">@day.UnansweredOnDay</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* === Per-person section (collapsible details, default OPEN) ============= *@
    @if (Model.People.Count == 0)
    {
        <div class="card">
            <div class="card-body text-center text-muted py-5">
                <i class="fa-solid fa-users-slash fa-2x mb-2"></i>
                <div>@Localizer["Cantina_Roster_EmptyState"]</div>
            </div>
        </div>
    }
    else
    {
        <details open class="mb-3">
            <summary class="h5 mb-3" style="cursor: pointer;">
                @string.Format(Localizer["Cantina_Roster_ShowRoster"].Value, Model.People.Count)
            </summary>
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th scope="col">@Localizer["Cantina_Roster_TablePerson"]</th>
                            <th scope="col">@Localizer["Cantina_Roster_TableArrivesOn"]</th>
                            <th scope="col">@Localizer["Cantina_Roster_TableNoShift"]</th>
                            <th scope="col">@Localizer["Cantina_Roster_TableDietary"]</th>
                            <th scope="col">@Localizer["Cantina_Roster_TableAllergies"]</th>
                            <th scope="col">@Localizer["Cantina_Roster_TableAllergyOther"]</th>
                            <th scope="col">@Localizer["Cantina_Roster_TableIntolerances"]</th>
                            <th scope="col">@Localizer["Cantina_Roster_TableIntoleranceOther"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var person in Model.People)
                        {
                            <tr>
                                <td class="fw-semibold">@person.BurnerName</td>
                                <td>
                                    <span class="badge bg-secondary">@FormatDay(person.ArrivesOn)</span>
                                </td>
                                <td>
                                    @if (person.NoShift.Count == 0)
                                    {
                                        <span class="text-muted small">@Localizer["Cantina_Roster_NoShift_FullWeek"]</span>
                                    }
                                    else
                                    {
                                        foreach (var d in person.NoShift)
                                        {
                                            <span class="badge bg-light text-muted me-1">@FormatDay(d)</span>
                                        }
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(person.DietaryPreference))
                                    {
                                        <span class="badge bg-success">@person.DietaryPreference</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">@Localizer["Cantina_Roster_Unanswered_RowLabel"]</span>
                                    }
                                </td>
                                <td>
                                    @foreach (var chip in person.Allergies)
                                    {
                                        <span class="badge bg-warning text-dark me-1">@chip</span>
                                    }
                                </td>
                                <td class="small">@person.AllergyOtherText</td>
                                <td>
                                    @foreach (var chip in person.Intolerances)
                                    {
                                        <span class="badge bg-info text-dark me-1">@chip</span>
                                    }
                                </td>
                                <td class="small">@person.IntoleranceOtherText</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </details>

        @* Secondary CSV download at the bottom for convenience *@
        <div class="d-flex justify-content-end mt-3">
            <a asp-action="Csv" asp-route-weekStartOffset="@Model.WeekStartOffset"
               class="btn btn-sm btn-outline-primary btn-download-csv">
                <i class="fa-solid fa-download me-1"></i>@Localizer["Cantina_Roster_DownloadCsv"]
            </a>
        </div>
    }
</div>
