@model Humans.Web.Models.EventCategoryListViewModel
@{
    ViewData["Title"] = "Event Categories";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Event Categories</h2>
    <a asp-controller="GuideAdmin" asp-action="CreateCategory" class="btn btn-primary">
        <i class="fa-solid fa-plus me-1"></i>Add Category
    </a>
</div>

<vc:temp-data-alerts />

@if (Model.Categories.Count == 0)
{
    <div class="alert alert-info">
        No categories yet. Add one to get started.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th style="width: 60px;">Order</th>
                    <th>Name</th>
                    <th>Slug</th>
                    <th>Sensitive</th>
                    <th>Active</th>
                    <th>Events</th>
                    <th style="width: 200px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @for (var i = 0; i < Model.Categories.Count; i++)
                {
                    var cat = Model.Categories[i];
                    <tr class="@(!cat.IsActive ? "table-secondary" : "")">
                        <td>
                            <div class="btn-group btn-group-sm">
                                @if (i > 0)
                                {
                                    <form method="post" asp-controller="GuideAdmin" asp-action="MoveCategoryUp" asp-route-id="@cat.Id" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-secondary btn-sm" title="Move up">
                                            <i class="fa-solid fa-arrow-up"></i>
                                        </button>
                                    </form>
                                }
                                @if (i < Model.Categories.Count - 1)
                                {
                                    <form method="post" asp-controller="GuideAdmin" asp-action="MoveCategoryDown" asp-route-id="@cat.Id" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-secondary btn-sm" title="Move down">
                                            <i class="fa-solid fa-arrow-down"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                        <td>@cat.Name</td>
                        <td><code>@cat.Slug</code></td>
                        <td>
                            @if (cat.IsSensitive)
                            {
                                <span class="badge bg-warning text-dark">Sensitive</span>
                            }
                        </td>
                        <td>
                            @if (cat.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td>@cat.EventCount</td>
                        <td>
                            <a asp-controller="GuideAdmin" asp-action="EditCategory" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-primary me-1">
                                <i class="fa-solid fa-pen me-1"></i>Edit
                            </a>
                            <form method="post" asp-controller="GuideAdmin" asp-action="DeleteCategory" asp-route-id="@cat.Id" class="d-inline" data-confirm="Delete this category?">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="fa-solid fa-trash me-1"></i>Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary">
    <i class="fa-solid fa-arrow-left me-1"></i>Back to Admin
</a>
