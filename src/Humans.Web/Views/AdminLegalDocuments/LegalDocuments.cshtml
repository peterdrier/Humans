@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@model Humans.Web.Models.LegalDocumentListViewModel
@{
    ViewData["Title"] = "Legal Documents";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index">Admin</a></li>
        <li class="breadcrumb-item active" aria-current="page">Legal Documents</li>
    </ol>
</nav>

<h1>Legal Documents</h1>


<div class="d-flex justify-content-between align-items-center mb-3">
    <form method="get" class="d-flex align-items-center gap-2">
        <label for="teamId" class="form-label mb-0">Team:</label>
        <select name="teamId" id="teamId" class="form-select form-select-sm" style="width: auto;">
            <option value="">All teams</option>
            @foreach (var team in Model.Teams)
            {
                <option value="@team.Id" selected="@(Model.FilterTeamId == team.Id ? "selected" : null)">@team.Name</option>
            }
        </select>
    </form>
    <a asp-controller="AdminLegalDocuments" asp-action="CreateLegalDocument" asp-route-teamId="@Model.FilterTeamId" class="btn btn-primary btn-sm">Create Document</a>
</div>

<div class="card">
    <div class="card-body p-0">
        @{
            Func<LegalDocumentListItemViewModel, IHtmlContent> nameCell =
                @<text><a asp-controller="AdminLegalDocuments" asp-action="EditLegalDocument" asp-route-id="@item.Id">@item.Name</a></text>;
            Func<LegalDocumentListItemViewModel, IHtmlContent> requiredCell = @<text>
                @if (item.IsRequired)
                {
                    <span class="badge bg-warning">Required</span>
                }
                else
                {
                    <span class="badge bg-secondary">Optional</span>
                }
            </text>;
            Func<LegalDocumentListItemViewModel, IHtmlContent> activeCell = @<text>
                @if (item.IsActive)
                {
                    <span class="badge bg-success">Active</span>
                }
                else
                {
                    <span class="badge bg-secondary">Archived</span>
                }
            </text>;
            Func<LegalDocumentListItemViewModel, IHtmlContent> lastSyncedCell =
                @<text>@(item.LastSyncedAt?.ToDateTime() ?? "Never")</text>;
            Func<LegalDocumentListItemViewModel, IHtmlContent> actionsCell = @<text>
                <a asp-controller="AdminLegalDocuments" asp-action="EditLegalDocument" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Edit</a>
                @if (item.IsActive)
                {
                    <form asp-controller="AdminLegalDocuments" asp-action="ArchiveLegalDocument" asp-route-id="@item.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger btn-sm" data-confirm="Archive this document? It will no longer be required for consent.">Archive</button>
                    </form>
                }
            </text>;
            var table = TableModel.For(Model.Documents)
                .Template("Name", nameCell)
                .Column("Team", r => r.TeamName)
                .Template("Required", requiredCell, c => c.NoSort())
                .Template("Active", activeCell, c => c.NoSort())
                .Column("Grace Period", r => $"{r.GracePeriodDays} days")
                .Column("Current Version", r => r.CurrentVersion ?? "No versions")
                .Template("Last Synced", lastSyncedCell)
                .Template("Actions", actionsCell, c => c.NoSort())
                .RowCss(r => !r.IsActive ? "table-secondary" : null)
                .Empty("No legal documents found.")
                .Build();
        }
        <partial name="_Table" model="table" />
    </div>
</div>

<script>
    document.getElementById('teamId').addEventListener('change', function () {
        this.form.submit();
    });

    document.querySelectorAll('[data-confirm]').forEach(function (button) {
        button.addEventListener('click', function (e) {
            if (!confirm(this.getAttribute('data-confirm'))) {
                e.preventDefault();
            }
        });
    });
</script>
