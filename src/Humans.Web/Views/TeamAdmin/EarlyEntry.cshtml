@model Humans.Web.Models.TeamEarlyEntryPageViewModel
@{
    ViewData["Title"] = string.Format("{0} — {1}", Localizer["TeamAdmin_EarlyEntry_Title"].Value, Model.TeamName);
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Team" asp-action="Index">@Localizer["Teams_Title"]</a></li>
        <li class="breadcrumb-item"><a asp-controller="Team" asp-action="Details" asp-route-slug="@Model.Slug">@Model.TeamName</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Localizer["TeamAdmin_EarlyEntry_Title"]</li>
    </ol>
</nav>

<h1>@Localizer["TeamAdmin_EarlyEntry_Title"]</h1>
<p class="text-muted">@Localizer["MyTeams_Team"]: @Model.TeamName</p>
<p>@Localizer["TeamAdmin_EarlyEntry_Intro"]</p>

<div asp-validation-summary="All" class="text-danger"></div>

@* Existing grants — each row carries an inline edit form + a remove form. *@
<div class="card mb-4">
    <div class="card-header">@Localizer["TeamAdmin_EarlyEntry_Title"]</div>
    <div class="card-body p-0">
        @if (Model.Grants.Count == 0)
        {
            <p class="text-muted m-3 mb-0">@Localizer["TeamAdmin_EarlyEntry_NoGrants"]</p>
        }
        else
        {
            <table class="table table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th>@Localizer["TeamAdmin_EarlyEntry_Human"]</th>
                        <th>@Localizer["TeamAdmin_EarlyEntry_Date"]</th>
                        <th>@Localizer["TeamAdmin_EarlyEntry_Project"]</th>
                        <th class="text-end">@Localizer["MyTeams_Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var grant in Model.Grants)
                    {
                        <tr>
                            <td>@grant.HumanName</td>
                            <td colspan="2">
                                <form asp-action="EditEarlyEntry" asp-route-slug="@Model.Slug" method="post" class="row g-2 align-items-center">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="GrantId" value="@grant.GrantId" />
                                    <div class="col-auto">
                                        <input type="date" name="EntryDate" class="form-control form-control-sm"
                                               value="@grant.EntryDate.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture)" required />
                                    </div>
                                    <div class="col">
                                        <input type="text" name="ProjectName" class="form-control form-control-sm"
                                               value="@grant.ProjectName" maxlength="256" required
                                               aria-label="@Localizer["TeamAdmin_EarlyEntry_Project"]" />
                                    </div>
                                    <div class="col-auto">
                                        <button type="submit" class="btn btn-sm btn-outline-primary">@Localizer["TeamAdmin_EarlyEntry_Save"]</button>
                                    </div>
                                </form>
                            </td>
                            <td class="text-end">
                                <form asp-action="RemoveEarlyEntry" asp-route-slug="@Model.Slug" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="grantId" value="@grant.GrantId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            data-confirm="@Localizer["TeamAdmin_EarlyEntry_RemoveConfirm"].Value">
                                        @Localizer["TeamAdmin_EarlyEntry_Remove"]
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@* Inline picker — <vc:human-search> posts UserId into a hidden input for AddEarlyEntry. *@
<div class="card mb-4 position-relative" style="z-index: 2;">
    <div class="card-header">@Localizer["TeamAdmin_EarlyEntry_AddTitle"]</div>
    <div class="card-body">
        <form asp-action="AddEarlyEntry" asp-route-slug="@Model.Slug" method="post" class="row g-2 align-items-end">
            @Html.AntiForgeryToken()
            <div class="col-md-5">
                <label class="form-label">@Localizer["TeamAdmin_EarlyEntry_Human"]</label>
                <vc:human-search field-name="UserId"
                                 instance-key="team-ee-add"
                                 placeholder="@Localizer["TeamAdmin_EarlyEntry_SearchPlaceholder"].Value"
                                 scope="Name" />
            </div>
            <div class="col-md-3">
                <label class="form-label" for="ee-add-date">@Localizer["TeamAdmin_EarlyEntry_Date"]</label>
                <input type="date" id="ee-add-date" name="EntryDate" class="form-control" required />
            </div>
            <div class="col-md-2">
                <label class="form-label" for="ee-add-project">@Localizer["TeamAdmin_EarlyEntry_Project"]</label>
                <input type="text" id="ee-add-project" name="ProjectName" class="form-control" maxlength="256" required />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-success">@Localizer["TeamAdmin_EarlyEntry_Grant"]</button>
            </div>
        </form>
    </div>
</div>
