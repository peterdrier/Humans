@model Humans.Web.Models.TeamMembersViewModel
@{
    ViewData["Title"] = string.Format(Localizer["TeamAdminMembers_Title"].Value, Model.TeamName);
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Team" asp-action="Index">@Localizer["Teams_Title"]</a></li>
        <li class="breadcrumb-item"><a asp-controller="Team" asp-action="Details" asp-route-slug="@Model.TeamSlug">@Model.TeamName</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Localizer["TeamAdmin_ManageMembers"]</li>
    </ol>
</nav>

<h1>@Localizer["TeamAdmin_ManageMembers"]</h1>
<p class="text-muted">@Localizer["MyTeams_Team"]: @Model.TeamName @(Model.IsSystemTeam ? string.Format("({0})", Localizer["TeamAdmin_SystemTeam"].Value) : "")</p>

<vc:temp-data-alerts />

@if (Model.IsSystemTeam)
{
    <div class="alert alert-info">
        @Localizer["TeamAdmin_SystemTeamRolesInfo"]
    </div>
}

@if (Model.PendingRequests.Any())
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>@Localizer["TeamDetail_PendingRequests"]</span>
            <span class="badge bg-warning">@Model.PendingRequests.Count</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>@Localizer["AdminApp_Applicant"]</th>
                        <th>@Localizer["TeamAdmin_Message"]</th>
                        <th>@Localizer["MyTeams_Requested"]</th>
                        <th>@Localizer["MyTeams_Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in Model.PendingRequests)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <vc:user-avatar profile-picture-url="@request.UserProfilePictureUrl"
                                                    display-name="@request.UserDisplayName"
                                                    size="32"
                                                    css-class="me-2" />
                                    <div>
                                        <strong>@request.UserDisplayName</strong><br>
                                        <small class="text-muted">@request.UserEmail</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(request.Message))
                                {
                                    <span>@(request.Message.Length > 100 ? request.Message.Substring(0, 100) + "..." : request.Message)</span>
                                }
                                else
                                {
                                    <span class="text-muted">@Localizer["TeamAdmin_NoMessage"]</span>
                                }
                            </td>
                            <td>@request.RequestedAt.ToString("MMM d, yyyy HH:mm")</td>
                            <td>
                                <div class="d-flex gap-1">
                                    <form asp-action="ApproveRequest" asp-route-slug="@Model.TeamSlug" asp-route-requestId="@request.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-success" data-confirm="@Localizer["TeamAdmin_ApproveConfirm"].Value">@Localizer["TeamAdmin_Approve"]</button>
                                    </form>
                                    <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#rejectModal-@request.Id">
                                        @Localizer["TeamAdmin_Reject"]
                                    </button>
                                </div>

                                <!-- Reject Modal -->
                                <div class="modal fade" id="rejectModal-@request.Id" tabindex="-1" aria-labelledby="rejectModalLabel-@request.Id" aria-hidden="true">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <form asp-action="RejectRequest" asp-route-slug="@Model.TeamSlug" asp-route-requestId="@request.Id" method="post">
                                                @Html.AntiForgeryToken()
                                                <div class="modal-header">
                                                    <h5 class="modal-title" id="rejectModalLabel-@request.Id">@Localizer["TeamAdmin_RejectRequest"]</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <p>@string.Format(Localizer["TeamAdmin_RejectingFrom"].Value, request.UserDisplayName)</p>
                                                    <div class="mb-3">
                                                        <label for="notes-@request.Id" class="form-label">@Localizer["TeamAdmin_RejectionReason"]</label>
                                                        <textarea name="Notes" id="notes-@request.Id" class="form-control" rows="3" required></textarea>
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Common_Cancel"]</button>
                                                    <button type="submit" class="btn btn-danger">@Localizer["TeamAdmin_RejectRequest"]</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (Model.Members.Any())
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>@Localizer["Teams_Member"]</th>
                        <th>@Localizer["MyTeams_Role"]</th>
                        <th>@Localizer["MyTeams_Joined"]</th>
                        @if (Model.CanManageRoles)
                        {
                            <th>@Localizer["MyTeams_Actions"]</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var member in Model.Members)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <vc:user-avatar profile-picture-url="@member.ProfilePictureUrl"
                                                    display-name="@member.DisplayName"
                                                    size="40"
                                                    css-class="me-2" />
                                    <div>
                                        <a asp-controller="Human" asp-action="View" asp-route-id="@member.UserId" class="text-decoration-none">
                                            <strong>@member.DisplayName</strong>
                                        </a><br>
                                        <small class="text-muted">@member.Email</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @await Html.PartialAsync("_RoleBadge", member.IsLead ? TeamMemberRole.Lead : TeamMemberRole.Member)
                            </td>
                            <td>@member.JoinedAt.ToString("MMM d, yyyy")</td>
                            @if (Model.CanManageRoles)
                            {
                                <td>
                                    <div class="d-flex gap-1" role="group">
                                        @if (member.IsLead)
                                        {
                                            <form asp-action="SetRole" asp-route-slug="@Model.TeamSlug" asp-route-userId="@member.UserId" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="Role" value="@TeamMemberRole.Member" />
                                                <button type="submit" class="btn btn-sm btn-outline-secondary" data-confirm="@Localizer["TeamAdmin_DemoteConfirm"].Value">
                                                    @Localizer["TeamAdmin_DemoteToMember"]
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="SetRole" asp-route-slug="@Model.TeamSlug" asp-route-userId="@member.UserId" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="Role" value="@TeamMemberRole.Lead" />
                                                <button type="submit" class="btn btn-sm btn-outline-primary" data-confirm="@Localizer["TeamAdmin_PromoteConfirm"].Value">
                                                    @Localizer["TeamAdmin_PromoteToLead"]
                                                </button>
                                            </form>
                                        }
                                        <form asp-action="RemoveMember" asp-route-slug="@Model.TeamSlug" asp-route-userId="@member.UserId" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" data-confirm="@Localizer["TeamAdmin_RemoveConfirm"].Value">
                                                @Localizer["TeamAdmin_Remove"]
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">
        @Localizer["TeamAdmin_NoMembers"]
    </div>
}

@if (Model.TotalCount > Model.PageSize)
{
    var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (var i = 1; i <= totalPages && i <= 10; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" asp-action="Members" asp-route-slug="@Model.TeamSlug" asp-route-page="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}

<div class="mt-3">
    <a asp-controller="Team" asp-action="Details" asp-route-slug="@Model.TeamSlug" class="btn btn-outline-secondary">@Localizer["TeamAdmin_BackToTeam"]</a>
    <a asp-action="Resources" asp-route-slug="@Model.TeamSlug" class="btn btn-outline-info">@Localizer["TeamAdmin_ManageResources"]</a>
</div>
