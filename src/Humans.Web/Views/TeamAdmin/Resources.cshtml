@using Humans.Domain.Enums
@model Humans.Web.Models.TeamResourcesViewModel
@{
    ViewData["Title"] = string.Format(Localizer["TeamAdminResources_Title"].Value, Model.TeamName);
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Team" asp-action="Index">@Localizer["Teams_Title"]</a></li>
        <li class="breadcrumb-item"><a asp-controller="Team" asp-action="Details" asp-route-slug="@Model.TeamSlug">@Model.TeamName</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Localizer["TeamAdmin_Resources"]</li>
    </ol>
</nav>

<h1>@Localizer["TeamAdmin_ManageResources"]</h1>
<p class="text-muted">@Localizer["MyTeams_Team"]: @Model.TeamName</p>

<vc:temp-data-alerts />

<div class="card mb-4">
    <div class="card-header">@Localizer["TeamAdmin_ServiceAccountTitle"]</div>
    <div class="card-body">
        <p class="mb-2">@Localizer["TeamAdmin_ShareWithServiceAccount"]</p>
        <div class="input-group mb-3" style="max-width: 600px;">
            <input type="text" class="form-control" value="@Model.ServiceAccountEmail" readonly id="serviceAccountEmail">
            <button class="btn btn-outline-secondary" type="button" id="copyServiceAccountBtn">@Localizer["TeamAdmin_Copy"]</button>
        </div>
        <ul class="mb-0 text-muted small">
            <li><strong>@Localizer["TeamAdmin_DriveFolders"]:</strong> @Localizer["TeamAdmin_DriveFoldersHelp"]</li>
            <li><strong>Drive Files:</strong> Share the file's parent Shared Drive with the service account as Contributor.</li>
            <li><strong>@Localizer["TeamAdmin_GoogleGroups"]:</strong> @Localizer["TeamAdmin_GoogleGroupsHelp"]</li>
        </ul>
    </div>
</div>

@if (Model.Resources.Any())
{
    <div class="card mb-4">
        <div class="card-header">@Localizer["TeamAdmin_LinkedResources"]</div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>@Localizer["AdminTeams_Name"]</th>
                        <th>@Localizer["AdminTeams_Type"]</th>
                        <th>Permission</th>
                        <th>@Localizer["TeamAdmin_LastSynced"]</th>
                        <th>@Localizer["Common_Status"]</th>
                        <th>@Localizer["MyTeams_Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var resource in Model.Resources)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(resource.Url))
                                {
                                    <a href="@resource.Url" target="_blank" rel="noopener noreferrer">@resource.Name</a>
                                }
                                else
                                {
                                    @resource.Name
                                }
                            </td>
                            <td>
                                @if (string.Equals(resource.ResourceType, "Drive Folder", StringComparison.Ordinal))
                                {
                                    <span class="badge bg-info">Drive Folder</span>
                                }
                                else if (string.Equals(resource.ResourceType, "Drive File", StringComparison.Ordinal))
                                {
                                    <span class="badge bg-warning text-dark">Drive File</span>
                                }
                                else if (string.Equals(resource.ResourceType, "Google Group", StringComparison.Ordinal))
                                {
                                    <span class="badge bg-primary">Google Group</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@resource.ResourceType</span>
                                }
                            </td>
                            <td>
                                @if (resource.IsDriveResource)
                                {
                                    <form asp-action="UpdatePermissionLevel" asp-route-slug="@Model.TeamSlug" asp-route-resourceId="@resource.Id" method="post" class="d-inline permission-form">
                                        @Html.AntiForgeryToken()
                                        @{
                                            var currentLevel = resource.DrivePermissionLevel.ToString();
                                        }
                                        <select name="level" class="form-select form-select-sm d-inline-block permission-select" style="width: auto; min-width: 140px;" data-original="@currentLevel">
                                            @foreach (var opt in new[] { ("Viewer", "Viewer"), ("Commenter", "Commenter"), ("Contributor", "Contributor"), ("ContentManager", "Content Manager"), ("Manager", "Manager") })
                                            {
                                                if (opt.Item1 == currentLevel)
                                                {
                                                    <option value="@opt.Item1" selected>@opt.Item2</option>
                                                }
                                                else
                                                {
                                                    <option value="@opt.Item1">@opt.Item2</option>
                                                }
                                            }
                                        </select>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                @if (resource.LastSyncedAt.HasValue)
                                {
                                            @resource.LastSyncedAt.Value.ToDisplayCompactDateTime()
                                }
                                else
                                {
                                    <span class="text-muted">@Localizer["Admin_Never"]</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(resource.ErrorMessage))
                                {
                                    <span class="badge bg-danger" title="@resource.ErrorMessage">Error</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1" role="group">
                                    <form asp-action="UnlinkResource" asp-route-slug="@Model.TeamSlug" asp-route-resourceId="@resource.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" data-confirm="Are you sure you want to deactivate this resource?">Deactivate</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-info mb-4">
        @Localizer["TeamAdmin_NoResources"]
    </div>
}

<div class="card mb-4">
    <div class="card-header">Link Google Drive Resource</div>
    <div class="card-body">
        <form asp-action="LinkDriveResource" asp-route-slug="@Model.TeamSlug" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label for="resourceUrl" class="form-label">Drive URL</label>
                <input type="url" class="form-control" id="resourceUrl" name="ResourceUrl"
                       placeholder="https://drive.google.com/drive/folders/... or https://docs.google.com/spreadsheets/d/..." required>
                <div class="form-text">Paste a Google Drive folder, Sheets, Docs, Slides, or other file URL.</div>
            </div>
            <div class="mb-3">
                <label for="permissionLevel" class="form-label">Permission Level</label>
                <select class="form-select" id="permissionLevel" name="PermissionLevel" style="max-width: 300px;">
                    <option value="Viewer">Viewer (read-only)</option>
                    <option value="Commenter">Commenter</option>
                    <option value="Contributor" selected>Contributor (read/write)</option>
                    <option value="ContentManager">Content Manager</option>
                    <option value="Manager">Manager</option>
                </select>
                <div class="form-text">Permission level granted to team humans for this resource.</div>
            </div>
            <button type="submit" class="btn btn-primary">Link Resource</button>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-controller="Team" asp-action="Details" asp-route-slug="@Model.TeamSlug" class="btn btn-outline-secondary">@Localizer["TeamAdmin_BackToTeam"]</a>
    <a asp-action="Members" asp-route-slug="@Model.TeamSlug" class="btn btn-outline-primary">@Localizer["TeamAdmin_ManageMembers"]</a>
</div>

<script>
    document.getElementById('copyServiceAccountBtn').addEventListener('click', function () {
        navigator.clipboard.writeText(document.getElementById('serviceAccountEmail').value);
    });

    document.querySelectorAll('[data-confirm]').forEach(function (button) {
        button.addEventListener('click', function (e) {
            if (!confirm(this.getAttribute('data-confirm'))) {
                e.preventDefault();
            }
        });
    });

    document.querySelectorAll('.permission-select').forEach(function (select) {
        select.addEventListener('change', function () {
            if (confirm('Are you sure you want to change the permission level?')) {
                this.closest('form').submit();
            } else {
                this.value = this.getAttribute('data-original');
            }
        });
    });
</script>
