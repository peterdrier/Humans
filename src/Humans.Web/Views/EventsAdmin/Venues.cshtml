@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@model Humans.Web.Models.Events.GuideVenueListViewModel
@{
    ViewData["Title"] = "Communal Venues";
}

<page-header title="Communal Venues">
    <a asp-controller="EventsAdmin" asp-action="CreateVenue" class="btn btn-primary">
        <i class="fa-solid fa-plus me-1"></i>Add Venue
    </a>
</page-header>


@if (Model.Venues.Count == 0)
{
    <div class="alert alert-info">
        No venues yet. Add one to get started.
    </div>
}
else
{
    var venueList = Model.Venues;
    Func<GuideVenueRowViewModel, IHtmlContent> venueOrderCell = @<text>
        <div class="btn-group btn-group-sm">
            @{ var venueIdx = venueList.IndexOf(item); }
            @if (venueIdx > 0)
            {
                <form method="post" asp-controller="EventsAdmin" asp-action="MoveVenueUp" asp-route-id="@item.Id" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-secondary btn-sm" title="Move up">
                        <i class="fa-solid fa-arrow-up"></i>
                    </button>
                </form>
            }
            @if (venueIdx < venueList.Count - 1)
            {
                <form method="post" asp-controller="EventsAdmin" asp-action="MoveVenueDown" asp-route-id="@item.Id" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-secondary btn-sm" title="Move down">
                        <i class="fa-solid fa-arrow-down"></i>
                    </button>
                </form>
            }
        </div>
    </text>;
    Func<GuideVenueRowViewModel, IHtmlContent> venueActiveCell = @<text>
        @if (item.IsActive)
        {
            <span class="badge bg-success">Active</span>
        }
        else
        {
            <span class="badge bg-secondary">Inactive</span>
        }
    </text>;
    Func<GuideVenueRowViewModel, IHtmlContent> venueActionsCell = @<text>
        <a asp-controller="EventsAdmin" asp-action="EditVenue" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1">
            <i class="fa-solid fa-pen me-1"></i>Edit
        </a>
        <form method="post" asp-controller="EventsAdmin" asp-action="DeleteVenue" asp-route-id="@item.Id" class="d-inline" data-confirm="Delete this venue?">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-outline-danger">
                <i class="fa-solid fa-trash me-1"></i>Delete
            </button>
        </form>
    </text>;
    var venueTable = TableModel.For(Model.Venues)
        .Template("Order", venueOrderCell, c => c.NoSort())
        .Column("Name", r => r.Name)
        .Column("Location", r => r.LocationDescription)
        .Template("Active", venueActiveCell)
        .Column("Events", r => r.EventCount)
        .Template("Actions", venueActionsCell, c => c.NoSort())
        .RowCss(r => !r.IsActive ? "table-secondary" : null)
        .Build();
    <partial name="_Table" model="venueTable" />
}

<a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary">
    <i class="fa-solid fa-arrow-left me-1"></i>Back to Admin
</a>
