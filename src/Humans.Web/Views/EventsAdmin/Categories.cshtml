@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@model Humans.Web.Models.Events.EventCategoryListViewModel
@{
    ViewData["Title"] = "Event Categories";
}

<page-header title="Event Categories">
    <a asp-controller="EventsAdmin" asp-action="CreateCategory" class="btn btn-primary">
        <i class="fa-solid fa-plus me-1"></i>Add Category
    </a>
</page-header>


@if (Model.Categories.Count == 0)
{
    <div class="alert alert-info">
        No categories yet. Add one to get started.
    </div>
}
else
{
    var catList = Model.Categories;
    Func<EventCategoryRowViewModel, IHtmlContent> catOrderCell = @<text>
        <div class="btn-group btn-group-sm">
            @{ var catIdx = catList.IndexOf(item); }
            @if (catIdx > 0)
            {
                <form method="post" asp-controller="EventsAdmin" asp-action="MoveCategoryUp" asp-route-id="@item.Id" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-secondary btn-sm" title="Move up">
                        <i class="fa-solid fa-arrow-up"></i>
                    </button>
                </form>
            }
            @if (catIdx < catList.Count - 1)
            {
                <form method="post" asp-controller="EventsAdmin" asp-action="MoveCategoryDown" asp-route-id="@item.Id" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-secondary btn-sm" title="Move down">
                        <i class="fa-solid fa-arrow-down"></i>
                    </button>
                </form>
            }
        </div>
    </text>;
    Func<EventCategoryRowViewModel, IHtmlContent> catSlugCell =
        @<text><code>@item.Slug</code></text>;
    Func<EventCategoryRowViewModel, IHtmlContent> catSensitiveCell = @<text>
        @if (item.IsSensitive)
        {
            <span class="badge bg-warning text-dark">Sensitive</span>
        }
    </text>;
    Func<EventCategoryRowViewModel, IHtmlContent> catActiveCell = @<text>
        @if (item.IsActive)
        {
            <span class="badge bg-success">Active</span>
        }
        else
        {
            <span class="badge bg-secondary">Inactive</span>
        }
    </text>;
    Func<EventCategoryRowViewModel, IHtmlContent> catActionsCell = @<text>
        <a asp-controller="EventsAdmin" asp-action="EditCategory" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1">
            <i class="fa-solid fa-pen me-1"></i>Edit
        </a>
        <form method="post" asp-controller="EventsAdmin" asp-action="DeleteCategory" asp-route-id="@item.Id" class="d-inline" data-confirm="Delete this category?">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-outline-danger">
                <i class="fa-solid fa-trash me-1"></i>Delete
            </button>
        </form>
    </text>;
    var catTable = TableModel.For(Model.Categories)
        .Template("Order", catOrderCell, c => c.NoSort())
        .Column("Name", r => r.Name)
        .Template("Slug", catSlugCell)
        .Template("Sensitive", catSensitiveCell)
        .Template("Active", catActiveCell)
        .Column("Events", r => r.EventCount)
        .Template("Actions", catActionsCell, c => c.NoSort())
        .RowCss(r => !r.IsActive ? "table-secondary" : null)
        .Build();
    <partial name="_Table" model="catTable" />
}

<a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary">
    <i class="fa-solid fa-arrow-left me-1"></i>Back to Admin
</a>
