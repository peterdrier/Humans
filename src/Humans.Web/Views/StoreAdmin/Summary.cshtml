@model Humans.Web.Models.Store.StoreSummaryViewModel
@{
    ViewData["Title"] = "Store summary";
    var s = Model.Summary;
}

<div class="page-head">
    <h1 class="title">Store summary</h1>
    <form method="get" class="d-flex gap-2 align-items-center mb-0">
        <label for="year" class="form-label mb-0">Year</label>
        <input type="number" name="year" id="year" value="@s.Year"
               class="form-control form-control-sm" style="width: 6rem;" />
        <button type="submit" class="btn btn-sm btn-secondary">Go</button>
    </form>
</div>


@* =====================  By counterparty  ===================== *@
<section class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h2 class="h5 mb-0">By counterparty</h2>
        <div class="d-flex gap-2 align-items-center">
            <label for="paid-filter" class="form-label mb-0 small">Show</label>
            <select id="paid-filter" class="form-select form-select-sm" style="width: 9rem;">
                <option value="all" selected>All</option>
                <option value="paid">Paid</option>
                <option value="partial">Partial</option>
                <option value="unpaid">Unpaid</option>
            </select>
        </div>
    </div>
    <div class="card-body p-0">
        @if (s.ByCounterparty.Count == 0)
        {
            <p class="text-muted m-3 mb-3">No orders for @s.Year.</p>
        }
        else
        {
            <table class="table table-sm mb-0" id="by-camp-table" data-sortable-table>
                <thead>
                    <tr>
                        <th data-sort-key="type" data-sort-type="text">Type <span class="sort-indicator" aria-hidden="true"></span></th>
                        <th data-sort-key="camp" data-sort-type="text">Counterparty <span class="sort-indicator" aria-hidden="true"></span></th>
                        <th data-sort-key="state" data-sort-type="text">State <span class="sort-indicator" aria-hidden="true"></span></th>
                        <th class="text-end" data-sort-key="due" data-sort-type="number">Total due (€) <span class="sort-indicator" aria-hidden="true"></span></th>
                        <th class="text-end" data-sort-key="paid" data-sort-type="number">Paid (€) <span class="sort-indicator" aria-hidden="true"></span></th>
                        <th class="text-end" data-sort-key="balance" data-sort-type="number">Balance (€) <span class="sort-indicator" aria-hidden="true"></span></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in s.ByCounterparty.OrderBy(r => r.CounterpartyType).ThenBy(r => r.CounterpartyName, StringComparer.Ordinal))
                {
                    string paidClass =
                        row.CounterpartyType == Humans.Domain.Enums.StoreOrderCounterpartyType.Team ? "paid" :
                        row.BalanceEur <= 0m ? "paid" :
                        row.PaymentsTotalEur > 0m ? "partial" : "unpaid";
                    <tr data-paid-status="@paidClass"
                        data-type="@row.CounterpartyType"
                        data-camp="@row.CounterpartyName"
                        data-state="@row.State"
                        data-due="@row.TotalDueEur.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                        data-paid="@row.PaymentsTotalEur.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                        data-balance="@row.BalanceEur.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                        <td>@row.CounterpartyType</td>
                        <td>
                            <a asp-controller="Store" asp-action="Order" asp-route-id="@row.OrderId">
                                @row.CounterpartyName
                            </a>
                        </td>
                        <td>@row.State</td>
                        <td class="text-end">@row.TotalDueEur.ToString("N2")</td>
                        <td class="text-end">@(row.CounterpartyType == Humans.Domain.Enums.StoreOrderCounterpartyType.Team ? "—" : row.PaymentsTotalEur.ToString("N2"))</td>
                        <td class="text-end">@(row.CounterpartyType == Humans.Domain.Enums.StoreOrderCounterpartyType.Team ? "—" : row.BalanceEur.ToString("N2"))</td>
                    </tr>
                }
                </tbody>
                @* Totals cover camps only: teams never pay (paid/balance hardcoded to 0),
                   so including their due would make Total due ≠ Paid + Balance. *@
                @{
                    var camps = s.ByCounterparty
                        .Where(r => r.CounterpartyType != Humans.Domain.Enums.StoreOrderCounterpartyType.Team)
                        .ToList();
                }
                <tfoot class="table-group-divider">
                    <tr class="fw-semibold">
                        <td>Total</td>
                        <td>@camps.Count camps</td>
                        <td></td>
                        <td class="text-end">@camps.Sum(r => r.TotalDueEur).ToString("N2")</td>
                        <td class="text-end">@camps.Sum(r => r.PaymentsTotalEur).ToString("N2")</td>
                        <td class="text-end">@camps.Sum(r => r.BalanceEur).ToString("N2")</td>
                    </tr>
                </tfoot>
            </table>
        }
    </div>
</section>

@* =====================  By item  ===================== *@
<section class="card mb-4">
    <div class="card-header"><h2 class="h5 mb-0">By item</h2></div>
    <div class="card-body p-0">
        @if (s.ByItem.Count == 0)
        {
            <p class="text-muted m-3 mb-3">No lines for @s.Year.</p>
        }
        else
        {
            <table class="table table-sm mb-0">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th class="text-end">Total qty</th>
                        <th class="text-end">Total revenue (€)</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in s.ByItem)
                {
                    <tr>
                        <td>@row.ProductName</td>
                        <td class="text-end">@row.TotalQty</td>
                        <td class="text-end">@row.TotalRevenueEur.ToString("N2")</td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</section>

@* =====================  Cross-tab  ===================== *@
<section class="card mb-4">
    <div class="card-header"><h2 class="h5 mb-0">Counterparties × products (qty)</h2></div>
    <div class="card-body p-0 table-responsive">
        @if (s.CrossTab.Counterparties.Count == 0 || s.CrossTab.Products.Count == 0)
        {
            <p class="text-muted m-3 mb-3">Nothing to plot for @s.Year.</p>
        }
        else
        {
            <table class="table table-sm table-bordered mb-0">
                <thead>
                    <tr>
                        <th>Type</th>
                        <th>Counterparty</th>
                        @foreach (var col in s.CrossTab.Products)
                        {
                            <th class="text-end">@col.ProductName</th>
                        }
                    </tr>
                </thead>
                <tbody>
                @foreach (var cp in s.CrossTab.Counterparties.OrderBy(c => c.CounterpartyType).ThenBy(c => c.CounterpartyName, StringComparer.Ordinal))
                {
                    <tr>
                        <td>@cp.CounterpartyType</td>
                        <td>@cp.CounterpartyName</td>
                        @foreach (var col in s.CrossTab.Products)
                        {
                            var qty = cp.QtyByProduct.TryGetValue(col.ProductId, out var q) ? q : 0;
                            <td class="text-end">@(qty == 0 ? "" : qty.ToString())</td>
                        }
                    </tr>
                }
                </tbody>
                <tfoot>
                    <tr class="fw-semibold">
                        <td colspan="2">Total</td>
                        @foreach (var col in s.CrossTab.Products)
                        {
                            <td class="text-end">@col.TotalQty</td>
                        }
                    </tr>
                </tfoot>
            </table>
        }
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["CspNonce"]">
        (function () {
            const table = document.getElementById('by-camp-table');
            if (!table) return;
            const tbody = table.tBodies[0];

            const select = document.getElementById('paid-filter');
            if (select) {
                select.addEventListener('change', function () {
                    const v = select.value;
                    tbody.querySelectorAll('tr').forEach(tr => {
                        tr.style.display = (v === 'all' || tr.dataset.paidStatus === v) ? '' : 'none';
                    });
                });
            }

        })();
    </script>
}
