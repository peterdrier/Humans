@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@model StoreCatalogAdminViewModel
@{
    ViewData["Title"] = "Store Catalog";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Store Catalog — @Model.Year</h1>
    <a asp-action="Edit" class="btn btn-primary">
        <i class="fa-solid fa-plus me-1"></i>Create product
    </a>
</div>


@if (Model.Products.Count == 0)
{
    <div class="card">
        <div class="card-body text-center py-4 text-muted">
            No products defined for @Model.Year. Create one to get started.
        </div>
    </div>
}
else
{
    Func<Humans.Application.Services.Store.Dtos.ProductDto, IHtmlContent> catalogAdminNameCell = @<text>
        <strong>@item.Name</strong>
        @if (!string.IsNullOrWhiteSpace(item.Description))
        {
            <div class="small text-muted">@Html.SanitizedMarkdown(item.Description)</div>
        }
    </text>;
    Func<Humans.Application.Services.Store.Dtos.ProductDto, IHtmlContent> catalogAdminStatusCell = @<text>
        @if (item.IsActive)
        {
            <span class="badge bg-success">Active</span>
        }
        else
        {
            <span class="badge bg-secondary">Inactive</span>
        }
    </text>;
    Func<Humans.Application.Services.Store.Dtos.ProductDto, IHtmlContent> catalogAdminActionsCell = @<text>
        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">
            <i class="fa-solid fa-pen me-1"></i>Edit
        </a>
        @if (item.IsActive)
        {
            <form asp-action="Deactivate" asp-route-id="@item.Id" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-danger"
                        data-confirm="Deactivate &quot;@item.Name&quot;? It will no longer be orderable but historical lines remain.">
                    <i class="fa-solid fa-eye-slash me-1"></i>Deactivate
                </button>
            </form>
        }
    </text>;
    <div class="card">
        @{
            var catalogAdminTable = TableModel.For(Model.Products)
                .Template("Name", catalogAdminNameCell)
                .Column("Unit price", r => r.UnitPriceEur, c => c.Currency().End())
                .Column("VAT %", r => r.VatRatePercent, c => c.Number().End())
                .Column("Deposit", r => r.DepositAmountEur, c => c.Currency().End())
                .Column("Orderable until", r => r.OrderableUntil.ToDate())
                .Template("Status", catalogAdminStatusCell)
                .Template("Actions", catalogAdminActionsCell, c => c.NoSort().End())
                .RowCss(p => p.IsActive ? null : "text-muted")
                .Build();
        }
        <partial name="_Table" model="catalogAdminTable" />
    </div>
}

@section Scripts {
    <script nonce="@Context.Items["CspNonce"]">
        document.querySelectorAll('[data-confirm]').forEach(function (button) {
            button.addEventListener('click', function (e) {
                if (!confirm(this.getAttribute('data-confirm'))) {
                    e.preventDefault();
                }
            });
        });
    </script>
}
