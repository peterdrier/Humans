@{
    ViewData["Title"] = Localizer["GateLogin_Title"].Value;
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card mt-5">
            <div class="card-body text-center">
                <h2 class="card-title mb-2">
                    <i class="fa-solid fa-qrcode me-2"></i>@Localizer["GateLogin_Title"]
                </h2>
                <p class="text-muted mb-4">@Localizer["GateLogin_Description"]</p>
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

                <form asp-controller="Account" asp-action="GateLogin" method="post"
                      class="d-flex flex-column gap-3 align-items-center">
                    <input type="text" name="username" class="form-control" style="max-width: 280px;"
                           placeholder="@Localizer["GateLogin_Username"]" autocomplete="username"
                           autocapitalize="none" required />
                    <input type="password" name="password" class="form-control" style="max-width: 280px;"
                           placeholder="@Localizer["GateLogin_Password"]" autocomplete="current-password" required />
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="fa-solid fa-right-to-bracket me-1"></i>
                        @Localizer["GateLogin_SignIn"]
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
