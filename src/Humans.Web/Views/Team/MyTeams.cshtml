@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@model Humans.Web.Models.MyTeamsViewModel
@{
    ViewData["Title"] = Localizer["MyTeams_Title"].Value;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">@Localizer["Teams_Title"]</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Localizer["MyTeams_Title"]</li>
    </ol>
</nav>

<h1>@Localizer["MyTeams_Title"]</h1>


@if (Model.Memberships.Any())
{
    <div class="card mb-4">
        <div class="card-header">@Localizer["MyTeams_TeamMemberships"]</div>
        @{
        Func<Humans.Web.Models.MyTeamMembershipViewModel, IHtmlContent> membershipTeamCell = @<text>
            <a asp-action="Details" asp-route-slug="@item.TeamSlug">@item.TeamName</a>
            @if (item.IsSystemTeam)
            {
                <span class="badge bg-secondary ms-1">@Localizer["Teams_System"]</span>
            }
        </text>;
        Func<Humans.Web.Models.MyTeamMembershipViewModel, IHtmlContent> membershipRoleCell = @<text>
            <partial name="_RoleBadge" model="@(item.IsCoordinator ? TeamMemberRole.Coordinator : TeamMemberRole.Member)" />
        </text>;
        Func<Humans.Web.Models.MyTeamMembershipViewModel, IHtmlContent> membershipActionsCell = @<text>
            <a asp-action="Details" asp-route-slug="@item.TeamSlug" class="btn btn-sm btn-outline-primary">@Localizer["MyTeams_View"]</a>
            @if (item.IsCoordinator)
            {
                <a asp-controller="TeamAdmin" asp-action="Members" asp-route-slug="@item.TeamSlug" class="btn btn-sm btn-outline-secondary">
                    @Localizer["Teams_Manage"]
                    @if (item.PendingRequestCount > 0)
                    {
                        <span class="badge bg-warning ms-1">@item.PendingRequestCount</span>
                    }
                </a>
            }
            @if (item.CanLeave)
            {
                <form asp-action="Leave" asp-route-slug="@item.TeamSlug" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger" data-confirm="@string.Format(Localizer["MyTeams_LeaveConfirm"].Value, item.TeamName)">
                        @Localizer["MyTeams_Leave"]
                    </button>
                </form>
            }
        </text>;
            var membershipsTable = TableModel.For(Model.Memberships)
                .Template(Localizer["MyTeams_Team"].Value, membershipTeamCell)
                .Template(Localizer["MyTeams_Role"].Value, membershipRoleCell)
                .Column(Localizer["MyTeams_Joined"].Value, r => r.JoinedAt.ToDate())
                .Template(Localizer["MyTeams_Actions"].Value, membershipActionsCell, c => c.NoSort())
                .Build();
        }
        <partial name="_Table" model="membershipsTable" />
    </div>
}
else
{
    <div class="alert alert-info">
        @Localizer["MyTeams_NoTeams"] <a asp-action="Index">@Localizer["MyTeams_BrowseTeams"]</a>
    </div>
}

@if (Model.PendingRequests.Any())
{
    <div class="card">
        <div class="card-header">@Localizer["MyTeams_PendingRequests"]</div>
        @{
        Func<Humans.Web.Models.TeamJoinRequestSummaryViewModel, IHtmlContent> requestTeamCell =
            @<text><a asp-action="Details" asp-route-slug="@item.TeamSlug">@item.TeamName</a></text>;
        Func<Humans.Web.Models.TeamJoinRequestSummaryViewModel, IHtmlContent> requestStatusCell =
            @<text><span class="badge @item.StatusBadgeClass">@item.Status</span></text>;
        Func<Humans.Web.Models.TeamJoinRequestSummaryViewModel, IHtmlContent> requestWithdrawCell = @<text>
            <form asp-action="WithdrawRequest" asp-route-id="@item.Id" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-danger" data-confirm="@Localizer["MyTeams_WithdrawConfirm"].Value">
                    @Localizer["MyTeams_Withdraw"]
                </button>
            </form>
        </text>;
            var pendingRequestsTable = TableModel.For(Model.PendingRequests)
                .Template(Localizer["MyTeams_Team"].Value, requestTeamCell)
                .Template(Localizer["MyTeams_Status"].Value, requestStatusCell)
                .Column(Localizer["MyTeams_Requested"].Value, r => r.RequestedAt.ToDate())
                .Template(Localizer["MyTeams_Actions"].Value, requestWithdrawCell, c => c.NoSort())
                .Build();
        }
        <partial name="_Table" model="pendingRequestsTable" />
    </div>
}
