@model Humans.Web.Models.TeamSummaryViewModel

<div class="col">
    <div class="card h-100">
        <div class="card-body">
            @if (Model.ParentTeamName != null)
            {
                <h5 class="card-title mb-0">
                    <a asp-action="Details" asp-route-slug="@Model.ParentTeamSlug" class="text-decoration-none">
                        @Model.ParentTeamName
                    </a>
                </h5>
                <div class="ms-3 mt-1">
                    <a asp-action="Details" asp-route-slug="@Model.Slug" class="text-muted text-decoration-none">
                        @Model.Name
                    </a>
                </div>
            }
            else
            {
                <h5 class="card-title mb-0">
                    <a asp-action="Details" asp-route-slug="@Model.Slug" class="text-decoration-none">
                        @Model.Name
                    </a>
                </h5>
            }
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p class="card-text text-muted small mt-2 mb-0">
                    @(Model.Description.Length > 150 ? Model.Description.Substring(0, 150) + "..." : Model.Description)
                </p>
            }
        </div>
        <div class="card-footer bg-transparent d-flex justify-content-between align-items-center">
            <div>
                <a asp-action="Details" asp-route-slug="@Model.Slug" class="btn btn-sm btn-outline-primary">
                    @Localizer["Teams_ViewDetails"]
                </a>
                @if (Model.IsCurrentUserCoordinator)
                {
                    <a asp-controller="TeamAdmin" asp-action="Members" asp-route-slug="@Model.Slug" class="btn btn-sm btn-outline-secondary">
                        @Localizer["Teams_Manage"]
                    </a>
                }
            </div>
            <small class="text-muted">
                @string.Format(Localizer["Teams_MemberCount"].Value, Model.MemberCount)
            </small>
        </div>
    </div>
</div>
