@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@model Humans.Application.DTOs.EmailRenameDetectionResult
@{
    ViewData["Title"] = "Email Rename Detection";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mt-4 mb-3">
        <h1>Email Rename Detection</h1>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Back to Google
        </a>
    </div>


    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            <i class="fa-solid fa-triangle-exclamation me-1"></i>Error: @Model.ErrorMessage
        </div>
    }
    else if (Model.Renames.Count == 0)
    {
        <div class="alert alert-success">
            <i class="fa-solid fa-check-circle me-1"></i>All @Model.TotalUsersChecked @@nobodies.team email(s) match Google Directory. No renames detected.
        </div>
    }
    else
    {
        Func<Humans.Application.DTOs.EmailRenameInfo, IHtmlContent> arrowCell =
            @<text><i class="fa-solid fa-arrow-right text-muted"></i></text>;
        Func<Humans.Application.DTOs.EmailRenameInfo, IHtmlContent> oldEmailCell =
            @<text><code class="text-danger">@item.OldEmail</code></text>;
        Func<Humans.Application.DTOs.EmailRenameInfo, IHtmlContent> newEmailCell =
            @<text><code class="text-success">@item.NewEmail</code></text>;
        Func<Humans.Application.DTOs.EmailRenameInfo, IHtmlContent> affectedCell = @<text>
            @if (item.AffectedResourceCount > 0)
            {
                <span class="badge bg-warning text-dark">@item.AffectedResourceCount</span>
            }
            else
            {
                <span class="text-muted">0</span>
            }
        </text>;
        var renameTable = TableModel.For(Model.Renames)
            .Column("Human", r => r.DisplayName)
            .Template("Old Email", oldEmailCell)
            .Template("", arrowCell, c => c.NoSort())
            .Template("New Email", newEmailCell)
            .Template("Affected Resources", affectedCell)
            .Build();
        <div class="alert alert-warning">
            <i class="fa-solid fa-triangle-exclamation me-1"></i>
            Found <strong>@Model.Renames.Count</strong> renamed email(s) out of <strong>@Model.TotalUsersChecked</strong> @@nobodies.team users checked.
            No admin action available — renames self-heal on the user's next Google sign-in.
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <i class="fa-solid fa-right-left me-1"></i>Detected Renames
            </div>
            <div class="card-body p-0">
                <partial name="_Table" model="renameTable" />
                <div class="card-body small text-muted">
                    <i class="fa-solid fa-circle-info me-1"></i>Read-only diagnostic. Renames self-heal on the user's next Google sign-in via the OAuth callback — no admin action available.
                </div>
            </div>
        </div>

        <div class="text-muted small">
            <i class="fa-solid fa-info-circle me-1"></i>
            After fixing a rename, the next sync cycle will automatically resolve any Missing/Extra drift for that human's resources.
        </div>
    }
</div>
