@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@model Humans.Application.DTOs.SyncReport
@{
    ViewData["Title"] = "System Team Sync Results";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mt-4 mb-3">
        <h1>Sync Results</h1>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Back to Google
        </a>
    </div>

    @if (!Model.HasChanges)
    {
        <div class="alert alert-success">
            <i class="fa-solid fa-check-circle me-1"></i>All @Model.Steps.Count steps completed — no changes needed.
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fa-solid fa-arrows-rotate me-1"></i>Sync completed with @Model.TotalChanges change(s) across @Model.Steps.Count steps.
        </div>
    }

    @foreach (var step in Model.Steps)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>@step.StepName</strong>
                @if (step.HasChanges)
                {
                    <span class="badge bg-warning text-dark">@step.TotalChanges change(s)</span>
                }
                else
                {
                    <span class="badge bg-success">No changes</span>
                }
            </div>
            @if (step.HasChanges)
            {
                Func<Humans.Application.DTOs.SyncChange, IHtmlContent> actionCell = r =>
                    new HtmlString($"<span class=\"badge {(string.Equals(r.Action, "Added", StringComparison.Ordinal) ? "bg-success" : string.Equals(r.Action, "Removed", StringComparison.Ordinal) ? "bg-danger" : string.Equals(r.Action, "Fixed", StringComparison.Ordinal) ? "bg-info" : "bg-secondary")}\">{Html.Encode(r.Action)}</span>");
                Func<Humans.Application.DTOs.SyncChange, IHtmlContent> humanCell =
                    @<text><vc:human user-id="@item.User.UserId" link="Admin" /></text>;
                var stepTable = TableModel.For(step.Changes)
                    .Template("Action", actionCell, c => c.NoSort())
                    .Template("Human", humanCell)
                    .Column("Detail", r => r.Detail)
                    .Build();
                <div class="card-body p-0">
                    <partial name="_Table" model="stepTable" />
                </div>
            }
        </div>
    }
</div>
