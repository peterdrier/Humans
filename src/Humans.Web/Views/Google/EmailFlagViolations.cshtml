@using Humans.Application.Interfaces.Profiles
@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@model IReadOnlyList<UserEmailFlagViolation>
@{
    ViewData["Title"] = "Email flag violations";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mt-4 mb-3">
        <h1>Email flag violations</h1>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Back to Google
        </a>
    </div>


    <p class="text-muted">Users whose email rows violate the exactly-one IsGoogle (when verified rows exist) / exactly-one IsPrimary invariants. Open each user's email grid to remediate.</p>

    @if (Model.Count == 0)
    {
        <div class="alert alert-success">
            <i class="fa-solid fa-check-circle me-1"></i>No invariant violations found. All users have exactly one Google identity row (when they have verified emails) and exactly one primary verified email.
        </div>
    }
    else
    {
        Func<UserEmailFlagViolation, IHtmlContent> userCell =
            @<text><vc:human user-id="@item.UserId" link="Admin" /></text>;
        Func<UserEmailFlagViolation, IHtmlContent> isGoogleCell = @<text>
            @if (item.HasMultipleGoogle)
            {
                <span class="badge bg-danger">@item.IsGoogleCount</span>
            }
            else if (item.HasZeroGoogle)
            {
                <span class="badge bg-warning text-dark">@item.IsGoogleCount</span>
            }
            else
            {
                <span class="text-muted">@item.IsGoogleCount</span>
            }
        </text>;
        Func<UserEmailFlagViolation, IHtmlContent> primaryCell = @<text>
            @if (item.HasPrimaryProblem)
            {
                <span class="badge bg-warning text-dark">@item.VerifiedPrimaryCount</span>
            }
            else
            {
                <span class="text-muted">@item.VerifiedPrimaryCount</span>
            }
        </text>;
        Func<UserEmailFlagViolation, IHtmlContent> issueCell = @<text>
            @if (item.HasMultipleGoogle)
            {
                <div><i class="fa-brands fa-google me-1 text-danger"></i>Multiple Google rows</div>
            }
            @if (item.HasZeroGoogle)
            {
                <div><i class="fa-brands fa-google me-1 text-warning"></i>No Google row among verified emails</div>
            }
            @if (item.HasPrimaryProblem)
            {
                <div>
                    <i class="fa-solid fa-star me-1 text-warning"></i>
                    @if (item.VerifiedPrimaryCount == 0)
                    {
                        <text>No primary among verified rows</text>
                    }
                    else
                    {
                        <text>Multiple primary verified rows</text>
                    }
                </div>
            }
        </text>;
        Func<UserEmailFlagViolation, IHtmlContent> actionCell = @<text>
            <a asp-controller="Profile" asp-action="AdminEmails" asp-route-id="@item.UserId" class="btn btn-outline-primary btn-sm">
                <i class="fa-solid fa-envelope me-1"></i>Open admin emails
            </a>
        </text>;
        var table = TableModel.For(Model)
            .Template("User", userCell)
            .Template("IsGoogle rows", isGoogleCell)
            .Column("Verified rows", r => r.VerifiedCount)
            .Template("Primary verified rows", primaryCell)
            .Template("Issue", issueCell)
            .Template("Action", actionCell, c => c.NoSort().End())
            .Build();
        <div class="card mb-4">
            <div class="card-body p-0">
                <partial name="_Table" model="table" />
            </div>
        </div>
    }
</div>
