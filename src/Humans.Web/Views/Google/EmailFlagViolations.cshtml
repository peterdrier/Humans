@using Humans.Application.Interfaces.Profiles
@model IReadOnlyList<UserEmailFlagViolation>
@{
    ViewData["Title"] = Localizer["GoogleEmailViolations_Title"].Value;
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mt-4 mb-3">
        <h1>@Localizer["GoogleEmailViolations_Title"]</h1>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Back to Google
        </a>
    </div>

    <vc:temp-data-alerts />

    <p class="text-muted">@Localizer["GoogleEmailViolations_Description"]</p>

    @if (Model.Count == 0)
    {
        <div class="alert alert-success">
            <i class="fa-solid fa-check-circle me-1"></i>@Localizer["GoogleEmailViolations_NoneFound"]
        </div>
    }
    else
    {
        <div class="card mb-4">
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>@Localizer["GoogleEmailViolations_ColumnUser"]</th>
                            <th>@Localizer["GoogleEmailViolations_ColumnIsGoogle"]</th>
                            <th>@Localizer["GoogleEmailViolations_ColumnVerified"]</th>
                            <th>@Localizer["GoogleEmailViolations_ColumnPrimary"]</th>
                            <th>@Localizer["GoogleEmailViolations_ColumnIssue"]</th>
                            <th class="text-end">@Localizer["GoogleEmailViolations_ColumnAction"]</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var v in Model)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Profile" asp-action="AdminDetail" asp-route-id="@v.UserId">
                                    @(string.IsNullOrWhiteSpace(v.DisplayName) ? v.UserId.ToString() : v.DisplayName)
                                </a>
                            </td>
                            <td>
                                @if (v.HasMultipleGoogle)
                                {
                                    <span class="badge bg-danger">@v.IsGoogleCount</span>
                                }
                                else
                                {
                                    <span class="text-muted">@v.IsGoogleCount</span>
                                }
                            </td>
                            <td><span class="text-muted">@v.VerifiedCount</span></td>
                            <td>
                                @if (v.HasPrimaryProblem)
                                {
                                    <span class="badge bg-warning text-dark">@v.VerifiedPrimaryCount</span>
                                }
                                else
                                {
                                    <span class="text-muted">@v.VerifiedPrimaryCount</span>
                                }
                            </td>
                            <td>
                                @if (v.HasMultipleGoogle)
                                {
                                    <div><i class="fa-brands fa-google me-1 text-danger"></i>@Localizer["GoogleEmailViolations_IssueMultipleGoogle"]</div>
                                }
                                @if (v.HasPrimaryProblem)
                                {
                                    <div>
                                        <i class="fa-solid fa-star me-1 text-warning"></i>
                                        @if (v.VerifiedPrimaryCount == 0)
                                        {
                                            @Localizer["GoogleEmailViolations_IssueNoPrimary"]
                                        }
                                        else
                                        {
                                            @Localizer["GoogleEmailViolations_IssueMultiplePrimary"]
                                        }
                                    </div>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-controller="Profile" asp-action="AdminEmails" asp-route-id="@v.UserId" class="btn btn-outline-primary btn-sm">
                                    <i class="fa-solid fa-envelope me-1"></i>@Localizer["GoogleEmailViolations_OpenAdminEmails"]
                                </a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
