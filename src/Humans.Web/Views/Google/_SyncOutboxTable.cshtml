@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@model IList<Humans.Application.Interfaces.GoogleIntegration.GoogleSyncOutboxEventSnapshot>
@{
    var googleEmailLookup = (Dictionary<Guid, string>)ViewData["GoogleEmailLookup"]!;
    var teamLookup = (Dictionary<Guid, string>)ViewData["TeamLookup"]!;
    var resourceLookup = (Dictionary<Guid, List<string>>)ViewData["ResourceLookup"]!;
    var showError = (bool)ViewData["ShowError"]!;
}

@if (Model.Count == 0)
{
    <div class="text-muted text-center py-4">No events.</div>
}
else
{
    Func<Humans.Application.Interfaces.GoogleIntegration.GoogleSyncOutboxEventSnapshot, IHtmlContent> eventTypeCell =
        @<text><code>@item.EventType</code></text>;
    Func<Humans.Application.Interfaces.GoogleIntegration.GoogleSyncOutboxEventSnapshot, IHtmlContent> humanCell =
        @<text><vc:human user-id="@item.UserId" link="Admin" /></text>;
    Func<Humans.Application.Interfaces.GoogleIntegration.GoogleSyncOutboxEventSnapshot, IHtmlContent> googleEmailCell =
        @<text><small class="text-muted">@googleEmailLookup.GetValueOrDefault(item.UserId, "unknown")</small></text>;
    Func<Humans.Application.Interfaces.GoogleIntegration.GoogleSyncOutboxEventSnapshot, IHtmlContent> resourceCell = evt =>
    {
        var resources = resourceLookup.GetValueOrDefault(evt.TeamId);
        if (resources is { Count: > 0 })
        {
            var sb = new System.Text.StringBuilder();
            foreach (var resource in resources)
                sb.Append($"<div><small>{Html.Encode(resource)}</small></div>");
            return new HtmlString(sb.ToString());
        }
        return new HtmlString("<small class=\"text-muted\">-</small>");
    };
    Func<Humans.Application.Interfaces.GoogleIntegration.GoogleSyncOutboxEventSnapshot, IHtmlContent> retriesCell = @<text>
        @if (item.RetryCount > 0)
        {
            <span class="badge bg-secondary">@item.RetryCount</span>
        }
    </text>;
    var builder = TableModel.For(Model.ToList())
        .Template("Event Type", eventTypeCell)
        .Template("Human", humanCell)
        .Template("Google Email", googleEmailCell)
        .Column("Team", r => teamLookup.GetValueOrDefault(r.TeamId, r.TeamId.ToString()))
        .Template("Resource", resourceCell)
        .Column("Occurred", r => r.OccurredAt, c => c.DateTime())
        .Template("Retries", retriesCell);
    if (showError)
    {
        Func<Humans.Application.Interfaces.GoogleIntegration.GoogleSyncOutboxEventSnapshot, IHtmlContent> errorCell = @<text>
            @if (!string.IsNullOrEmpty(item.LastError))
            {
                <small class="text-danger" title="@item.LastError">
                    @(item.LastError.Length > 120 ? item.LastError[..120] + "..." : item.LastError)
                </small>
            }
        </text>;
        builder = builder.Template("Last Error", errorCell);
    }
    var table = builder.Build();
    <partial name="_Table" model="table" />
}
