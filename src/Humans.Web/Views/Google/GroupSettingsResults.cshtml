@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@model Humans.Application.DTOs.GroupSettingsDriftResult
@{
    ViewData["Title"] = "Google Group Settings Check";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mt-4 mb-3">
        <h1>Group Settings Check</h1>
        <div class="d-flex gap-2">
            <a asp-action="AllGroups" class="btn btn-outline-primary btn-sm">
                <i class="fa-solid fa-layer-group me-1"></i>All Domain Groups
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="fa-solid fa-arrow-left me-1"></i>Back to Google
            </a>
        </div>
    </div>

    @if (Model.Skipped)
    {
        <div class="alert alert-secondary">
            <i class="fa-solid fa-circle-pause me-1"></i>Check skipped: @Model.SkipReason
        </div>
    }
    else if (Model.DriftCount == 0 && Model.ErrorCount == 0)
    {
        <div class="alert alert-success">
            <i class="fa-solid fa-check-circle me-1"></i>All @Model.TotalGroups group(s) have correct settings.
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fa-solid fa-magnifying-glass me-1"></i>Checked @Model.TotalGroups group(s):
            <strong>@Model.OkCount</strong> OK,
            <strong>@Model.DriftCount</strong> with drift,
            <strong>@Model.ErrorCount</strong> with errors.
        </div>
    }

    @foreach (var report in Model.Reports.OrderByDescending(r => r.HasDrift).ThenByDescending(r => r.HasError))
    {
        var headerClass = report.HasDrift ? "bg-warning text-dark" : report.HasError ? "bg-danger text-white" : "bg-success text-white";
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center @headerClass">
                <div>
                    <strong>@report.GroupName</strong>
                    <small class="ms-2">@report.GroupEmail</small>
                </div>
                <div class="d-flex align-items-center gap-2">
                    @if (report.HasDrift)
                    {
                        <span class="badge bg-dark">@report.Drifts.Count drift(s)</span>
                        <form asp-action="RemediateGroupSettings" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="groupEmail" value="@report.GroupEmail" />
                            <input type="hidden" name="returnUrl" value="@Url.Action("GroupSettingsResults")" />
                            <button type="submit" class="btn btn-sm btn-dark py-0">
                                <i class="fa-solid fa-wand-magic-sparkles me-1"></i>Fix
                            </button>
                        </form>
                    }
                    else if (report.HasError)
                    {
                        <span class="badge bg-dark">Error</span>
                    }
                    else
                    {
                        <span class="badge bg-dark">OK</span>
                    }
                </div>
            </div>

            @if (report.HasError)
            {
                <div class="card-body">
                    <div class="text-danger">
                        <i class="fa-solid fa-triangle-exclamation me-1"></i>@report.ErrorMessage
                    </div>
                </div>
            }

            @if (report.HasDrift)
            {
                Func<Humans.Application.DTOs.GroupSettingDrift, IHtmlContent> driftSettingCell =
                    @<text><code>@item.SettingName</code></text>;
                Func<Humans.Application.DTOs.GroupSettingDrift, IHtmlContent> driftExpectedCell =
                    @<text><span class="badge bg-success">@item.ExpectedValue</span></text>;
                Func<Humans.Application.DTOs.GroupSettingDrift, IHtmlContent> driftActualCell =
                    @<text><span class="badge bg-danger">@item.ActualValue</span></text>;
                var driftTable = TableModel.For(report.Drifts)
                    .Template("Setting", driftSettingCell)
                    .Template("Expected", driftExpectedCell)
                    .Template("Actual", driftActualCell)
                    .Build();
                <div class="card-body p-0">
                    <partial name="_Table" model="driftTable" />
                </div>
            }

            @if (report.Url != null)
            {
                <div class="card-footer text-muted small">
                    <a href="@report.Url" target="_blank" rel="noopener noreferrer">
                        <i class="fa-solid fa-arrow-up-right-from-square me-1"></i>Open in Google Groups
                    </a>
                </div>
            }
        </div>
    }

    @if (Model.ExpectedSettings.Count > 0)
    {
        var settingRows = Model.ExpectedSettings.Select(kv => new { Setting = kv.Key, Value = kv.Value }).ToList();
        var settingsTable = TableModel.For(settingRows)
            .Template("Setting", item => new HtmlString($"<code>{Html.Encode(item.Setting)}</code>"))
            .Template("Expected Value", item => new HtmlString($"<span class=\"badge bg-success\">{Html.Encode(item.Value)}</span>"))
            .Build();
        <div class="card mt-4 mb-4">
            <div class="card-header bg-light">
                <i class="fa-solid fa-list-check me-1"></i><strong>Expected Settings Reference</strong>
            </div>
            <div class="card-body p-0">
                <partial name="_Table" model="settingsTable" />
            </div>
        </div>
    }
</div>
