@model Humans.Web.Models.CampRegisterViewModel
@{
    ViewData["Title"] = $"Register Your {Localizer["Camp_Singular"]} — {ViewData["SeasonYear"]}";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">@Localizer["Camp_Plural"]</a></li>
        <li class="breadcrumb-item active" aria-current="page">Register</li>
    </ol>
</nav>

<h1 class="mb-4">Register Your @Localizer["Camp_Singular"] <small class="text-muted">(@ViewData["SeasonYear"] season)</small></h1>

<vc:temp-data-alerts />

<div asp-validation-summary="All" class="text-danger mb-3"></div>

@* Barrio Information Accordion *@
<div class="card mb-4 border-info">
    <div class="card-header bg-info bg-opacity-10">
        <i class="fa-solid fa-circle-info me-1"></i> What You Need to Know Before Registering Your @Localizer["Camp_Singular"]
    </div>
    <div class="card-body p-0">
        <div class="accordion accordion-flush" id="barrio-info-accordion">
            @* Benefits *@
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button"
                            data-bs-toggle="collapse" data-bs-target="#barrio-benefits">
                        <i class="fa-solid fa-gift me-2 text-success"></i>
                        What Your @Localizer["Camp_Singular"] Gets
                    </button>
                </h2>
                <div id="barrio-benefits" class="accordion-collapse collapse"
                     data-bs-parent="#barrio-info-accordion">
                    <div class="accordion-body">
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2">
                                <i class="fa-solid fa-bolt text-warning me-2"></i>
                                <strong>Power access</strong> — connection to the electrical grid based on your selected tier
                            </li>
                            <li class="mb-2">
                                <i class="fa-solid fa-droplet text-primary me-2"></i>
                                <strong>Water supply</strong> — access to the shared water infrastructure on site
                            </li>
                            <li class="mb-2">
                                <i class="fa-solid fa-map-pin text-danger me-2"></i>
                                <strong>Placement on the city map</strong> — your @Localizer["Camp_Singular"] will be placed in a zone matching your sound and space preferences
                            </li>
                            <li class="mb-2">
                                <i class="fa-solid fa-bullhorn text-info me-2"></i>
                                <strong>Listing and publicity</strong> — your @Localizer["Camp_Singular"] appears in the official directory and event guide, visible to all attendees
                            </li>
                            <li class="mb-2">
                                <i class="fa-solid fa-handshake-angle text-success me-2"></i>
                                <strong>@Localizer["Camp_Singular"] support resources</strong> — access to shared infrastructure, community channels, and coordination support from the city planning team
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            @* Obligations *@
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button"
                            data-bs-toggle="collapse" data-bs-target="#barrio-obligations">
                        <i class="fa-solid fa-clipboard-check me-2 text-warning"></i>
                        Your Obligations as a @Localizer["Camp_Singular"]
                    </button>
                </h2>
                <div id="barrio-obligations" class="accordion-collapse collapse"
                     data-bs-parent="#barrio-info-accordion">
                    <div class="accordion-body">
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2">
                                <i class="fa-solid fa-user-check text-primary me-2"></i>
                                <strong>Designate a contact person</strong> — at least one human must be reachable for coordination before and during the event
                            </li>
                            <li class="mb-2">
                                <i class="fa-solid fa-calendar-check text-success me-2"></i>
                                <strong>Meet registration deadlines</strong> — complete your registration and provide all required information by the deadline set for the current season
                            </li>
                            <li class="mb-2">
                                <i class="fa-solid fa-people-carry-box text-warning me-2"></i>
                                <strong>Participate in community shifts</strong> — contribute to shared duties such as gate shifts, setup, and teardown
                            </li>
                            <li class="mb-2">
                                <i class="fa-solid fa-broom text-info me-2"></i>
                                <strong>Leave No Trace</strong> — clean up your area completely at the end of the event, leaving the land as you found it
                            </li>
                            <li class="mb-2">
                                <i class="fa-solid fa-handshake text-danger me-2"></i>
                                <strong>Follow community guidelines</strong> — respect noise zones, fire safety rules, and the principles of the event
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            @* Resources *@
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button"
                            data-bs-toggle="collapse" data-bs-target="#barrio-resources">
                        <i class="fa-solid fa-toolbox me-2 text-primary"></i>
                        Useful Resources and Tips
                    </button>
                </h2>
                <div id="barrio-resources" class="accordion-collapse collapse"
                     data-bs-parent="#barrio-info-accordion">
                    <div class="accordion-body">
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2">
                                <i class="fa-solid fa-box text-warning me-2"></i>
                                <strong>Containers</strong> — shipping containers can be arranged for storage and structure; note your needs in the Placement section below
                            </li>
                            <li class="mb-2">
                                <i class="fa-solid fa-tags text-success me-2"></i>
                                <strong>Official pricing</strong> — pricing for power, water, and container rental will be shared with registered @Localizer["Camp_Plural"] before the season begins
                            </li>
                            <li class="mb-2">
                                <i class="fa-solid fa-truck text-info me-2"></i>
                                <strong>Recommended vendors</strong> — a list of recommended local suppliers for shade structures, generators, and other equipment will be shared after registration
                            </li>
                            <li class="mb-2">
                                <i class="fa-solid fa-lightbulb text-primary me-2"></i>
                                <strong>Best practices</strong> — first-time @Localizer["Camp_Singular"] leads are encouraged to connect with experienced leads through the community channels for advice on layout, logistics, and community building
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<form asp-action="Register" method="post">
    @Html.AntiForgeryToken()

    @* Camp Info *@
    <div class="card mb-4">
        <div class="card-header"><i class="fa-solid fa-campground me-1"></i> @Localizer["Camp_InfoTitle"]</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label">@Localizer["Camp_NameLabel"]</label>
                    <input asp-for="Name" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label asp-for="ContactEmail" class="form-label">Contact Email</label>
                    <input asp-for="ContactEmail" class="form-control" type="email" required />
                </div>
                <div class="col-md-6">
                    <label asp-for="ContactPhone" class="form-label">Contact Phone</label>
                    <input asp-for="ContactPhone" class="form-control" type="tel" pattern="\+[\d\s\-()]{6,20}" placeholder="+34 612 345 678" />
                </div>
                <div class="col-12">
                    <label class="form-label">@Localizer["Camp_Edit_Links"]</label>
                    <div id="links-container">
                        @if (Model.Links.Count > 0)
                        {
                            for (var i = 0; i < Model.Links.Count; i++)
                            {
                                <div class="input-group mb-2 link-entry">
                                    <input type="url" name="Links" class="form-control" value="@Model.Links[i]" placeholder="https://" />
                                    <button type="button" class="btn btn-outline-danger remove-link">
                                        <i class="fa-solid fa-times"></i>
                                    </button>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="input-group mb-2 link-entry">
                                <input type="url" name="Links" class="form-control" placeholder="https://" />
                                <button type="button" class="btn btn-outline-danger remove-link">
                                    <i class="fa-solid fa-times"></i>
                                </button>
                            </div>
                        }
                    </div>
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="add-link">
                        <i class="fa-solid fa-plus me-1"></i> @Localizer["Camp_Edit_AddLink"]
                    </button>
                </div>
                <div class="col-md-3">
                    <label asp-for="TimesAtNowhere" class="form-label">Times Participating</label>
                    <input asp-for="TimesAtNowhere" class="form-control" type="number" min="0" />
                </div>
                <div class="col-md-3">
                    <div class="form-check mt-4">
                        <input asp-for="IsSwissCamp" class="form-check-input" />
                        <label asp-for="IsSwissCamp" class="form-check-label">@Localizer["Camp_SwissCampLabel"]</label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* About Your Camp *@
    <div class="card mb-4">
        <div class="card-header"><i class="fa-solid fa-pen-fancy me-1"></i> About Your @Localizer["Camp_Singular"]</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="BlurbShort" class="form-label">Short Description</label>
                    <textarea asp-for="BlurbShort" class="form-control" rows="2" maxlength="300"
                              placeholder="One or two sentences about your camp (max 300 chars)" required></textarea>
                </div>
                <div class="col-12">
                    <label asp-for="BlurbLong" class="form-label">Full Description</label>
                    <textarea asp-for="BlurbLong" class="form-control" rows="6"
                              placeholder="Tell the world about your camp. Markdown is supported." required></textarea>
                    <div class="form-text">
                        <a href="#" data-bs-toggle="modal" data-bs-target="#markdownHelpModal">
                            <i class="fa-solid fa-circle-info me-1"></i>Markdown formatting is supported
                        </a>
                    </div>
                </div>
                <div class="col-md-6">
                    <label asp-for="Languages" class="form-label">Languages Spoken</label>
                    <input asp-for="Languages" class="form-control" placeholder="e.g. English, Spanish, German" required />
                </div>
            </div>
        </div>
    </div>

    @* Community *@
    <div class="card mb-4">
        <div class="card-header"><i class="fa-solid fa-users me-1"></i> Community</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="AcceptingMembers" class="form-label">Accepting New Members?</label>
                    <select asp-for="AcceptingMembers" class="form-select"
                            asp-items="@(new SelectList(Enum.GetValues<YesNoMaybe>()))"></select>
                </div>
                <div class="col-md-4">
                    <label asp-for="KidsWelcome" class="form-label">Kids Welcome?</label>
                    <select asp-for="KidsWelcome" class="form-select"
                            asp-items="@(new SelectList(Enum.GetValues<YesNoMaybe>()))"></select>
                </div>
                <div class="col-md-4">
                    <label asp-for="KidsVisiting" class="form-label">Kids Visiting Policy</label>
                    <select asp-for="KidsVisiting" class="form-select"
                            asp-items="@(new SelectList(Enum.GetValues<KidsVisitingPolicy>()))"></select>
                </div>
                <div class="col-12">
                    <label asp-for="KidsAreaDescription" class="form-label">Kids Area Description</label>
                    <textarea asp-for="KidsAreaDescription" class="form-control" rows="2"
                              placeholder="Describe your kids area if applicable"></textarea>
                    <div class="form-text">
                        <a href="#" data-bs-toggle="modal" data-bs-target="#markdownHelpModal">
                            <i class="fa-solid fa-circle-info me-1"></i>Markdown formatting is supported
                        </a>
                    </div>
                </div>
                <div class="col-md-4">
                    <label asp-for="AdultPlayspace" class="form-label">Adult Playspace</label>
                    <select asp-for="AdultPlayspace" class="form-select"
                            asp-items="@(new SelectList(Enum.GetValues<AdultPlayspacePolicy>()))"></select>
                </div>
                <div class="col-md-4">
                    <label asp-for="MemberCount" class="form-label">Expected Members</label>
                    <input asp-for="MemberCount" class="form-control" type="number" min="1" />
                </div>
            </div>
        </div>
    </div>

    @* Culture & Events *@
    <div class="card mb-4">
        <div class="card-header"><i class="fa-solid fa-masks-theater me-1"></i> Culture & Events</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="HasPerformanceSpace" class="form-label">Performance Space</label>
                    <select asp-for="HasPerformanceSpace" class="form-select"
                            asp-items="@(new SelectList(Enum.GetValues<PerformanceSpaceStatus>()))"></select>
                </div>
                <div class="col-md-8">
                    <label asp-for="PerformanceTypes" class="form-label">Performance Types</label>
                    <input asp-for="PerformanceTypes" class="form-control" placeholder="e.g. Music, Theater, Workshops" />
                </div>
                <div class="col-12">
                    <label class="form-label">Vibes</label>
                    <div class="d-flex flex-wrap gap-3">
                        @foreach (var vibe in Enum.GetValues<CampVibe>())
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox"
                                       name="Vibes" value="@vibe"
                                       id="vibe-@vibe"
                                       checked="@(Model.Vibes.Contains(vibe) ? "checked" : null)" />
                                <label class="form-check-label" for="vibe-@vibe">@vibe</label>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Placement *@
    <div class="card mb-4">
        <div class="card-header"><i class="fa-solid fa-map-location-dot me-1"></i> Placement</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="SoundZone" class="form-label">Sound Zone Preference</label>
                    <select asp-for="SoundZone" class="form-select"
                            asp-items="@(new SelectList(Enum.GetValues<SoundZone>()))">
                        <option value="">No Preference</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="SpaceRequirement" class="form-label">Space Requirement</label>
                    <select asp-for="SpaceRequirement" class="form-select"
                            asp-items="@(new SelectList(Enum.GetValues<SpaceSize>()))">
                        <option value="">Not Sure</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="ElectricalGrid" class="form-label">Electrical Grid</label>
                    <select asp-for="ElectricalGrid" class="form-select"
                            asp-items="@(new SelectList(Enum.GetValues<ElectricalGrid>()))">
                        <option value="">Unknown</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="ContainerCount" class="form-label">Number of Containers</label>
                    <input asp-for="ContainerCount" class="form-control" type="number" min="0" />
                </div>
                <div class="col-md-8">
                    <label asp-for="ContainerNotes" class="form-label">Container Notes</label>
                    <input asp-for="ContainerNotes" class="form-control" placeholder="Size, type, special requirements" />
                </div>
            </div>
        </div>
    </div>

    @* History *@
    <div class="card mb-4">
        <div class="card-header"><i class="fa-solid fa-clock-rotate-left me-1"></i> History</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="HistoricalNames" class="form-label">Previous Names</label>
                    <input asp-for="HistoricalNames" class="form-control"
                           placeholder="Comma-separated list of previous camp names" />
                    <div class="form-text">If your camp has had different names in past years, list them here.</div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between">
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary">
            <i class="fa-solid fa-paper-plane me-1"></i> Register @Localizer["Camp_Singular"]
        </button>
    </div>
</form>

<partial name="_MarkdownHelp" />

@section Scripts {
    <partial name="_LinksEditorScripts" />
}
