@model Humans.Web.Models.ExpensesIndexViewModel
@{
    ViewData["Title"] = "My Expense Reports";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">My Expense Reports</h1>
    @if (Model.HasActiveYear)
    {
        <a asp-action="New" class="btn btn-primary">
            <i class="fa-solid fa-plus me-1"></i>New Report
        </a>
    }
</div>


@if (Model.Iou is { } iou)
{
    <div class="card mb-4 border-info">
        <div class="card-header bg-info-subtle"><strong><i class="fa-solid fa-building-columns me-1"></i>What the collective owes you</strong></div>
        <div class="card-body">
            <div class="row text-center">
                <div class="col-md-4">
                    <div class="text-muted small">Owed to you (Holded balance)</div>
                    <div class="fs-4 fw-semibold">&euro;@iou.OwedToMember.ToString("N2")</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">Paid to date</div>
                    <div class="fs-4">&euro;@iou.TotalPaid.ToString("N2")</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">Last payment</div>
                    <div class="fs-4">@(iou.LastPaymentDate is { } d ? d.ToInvariantDate() : "—")</div>
                </div>
            </div>
            @if (iou.OtherAmount > 0)
            {
                <p class="text-muted small mb-0 mt-3">
                    <i class="fa-solid fa-circle-info me-1"></i>
                    Your Holded balance includes &euro;@iou.OtherAmount.ToString("N2") unrelated to these reports
                    (items fronted on the collective's behalf, adjustments, etc.), so the rows below won't necessarily sum to it.
                </p>
            }
        </div>
        @if (Model.Ledger.Count > 0)
        {
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Item</th>
                            <th class="text-end">Amount</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Ledger)
                        {
                            <tr class="@(row.IsPayment ? "table-success" : "")">
                                <td>@row.Date.ToInvariantDate()</td>
                                <td>
                                    @if (row.IsPayment)
                                    {
                                        <i class="fa-solid fa-money-bill-wave text-success me-1"></i>
                                    }
                                    @row.Label
                                    @if (row.Status is { } st)
                                    {
                                        <span class="badge bg-secondary ms-1">@st</span>
                                    }
                                </td>
                                <td class="text-end">@(row.IsPayment ? "−" : "")&euro;@row.Amount.ToString("N2")</td>
                                <td class="text-end">
                                    @if (row.ReportId is { } rid)
                                    {
                                        <a asp-action="Detail" asp-route-id="@rid" class="btn btn-sm btn-outline-secondary">View</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@if (!Model.HasActiveYear)
{
    <div class="alert alert-info">
        There is no active budget year at the moment. Expense reports cannot be filed until a budget year is activated.
    </div>
}
else if (!Model.HasIban)
{
    <div class="alert alert-warning">
        <i class="fa-solid fa-circle-exclamation me-1"></i>
        You have not yet set your payment IBAN. You will be prompted to set it when you submit a report.
    </div>
}

@if (Model.Reports.Count == 0)
{
    <div class="card">
        <div class="card-body text-center text-muted py-5">
            <i class="fa-solid fa-receipt fa-2x mb-3 d-block"></i>
            <p class="mb-0">No expense reports yet.</p>
            @if (Model.HasActiveYear)
            {
                <a asp-action="New" class="btn btn-outline-primary mt-3">File your first report</a>
            }
        </div>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Created</th>
                    <th>Category</th>
                    <th>Status</th>
                    <th class="text-end">Total</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Reports.OrderByDescending(x => x.CreatedAt))
                {
                    var badgeClass = r.Status switch
                    {
                        ExpenseReportStatus.Draft => "bg-secondary",
                        ExpenseReportStatus.Submitted => "bg-primary",
                        ExpenseReportStatus.CoordinatorEndorsed => "bg-info text-dark",
                        ExpenseReportStatus.Approved => "bg-success",
                        ExpenseReportStatus.SepaSent => "bg-warning text-dark",
                        ExpenseReportStatus.Paid => "bg-success",
                        _ => "bg-secondary"
                    };
                    <tr>
                        <td>@r.CreatedAt.ToDate()</td>
                        <td><small class="text-muted">@(Model.CategoryNames.TryGetValue(r.BudgetCategoryId, out var cat) ? cat : r.BudgetCategoryId.ToString())</small></td>
                        <td><span class="badge @badgeClass">@r.Status</span></td>
                        <td class="text-end">&euro;@r.Total.ToString("N2")</td>
                        <td class="text-end">
                            <a asp-action="Detail" asp-route-id="@r.Id" class="btn btn-sm btn-outline-secondary">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
