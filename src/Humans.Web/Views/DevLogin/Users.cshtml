@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@using System.Text.Encodings.Web
@model List<(Guid Id, string DisplayName, string Email)>
@{
    ViewData["Title"] = "Dev Login — Choose User";
    var returnUrl = ViewData["ReturnUrl"] as string;
    var rows = Model.Select(u => new { u.Id, u.DisplayName, u.Email }).ToList();
    var table = TableModel.For(rows)
        .Column("Name", r => r.DisplayName)
        .Column("Email", r => r.Email)
        .Template("", r =>
        {
            var url = Url.Action("SignInAsUser", "DevLogin", new { id = r.Id, returnUrl });
            return new HtmlString($"""<a href="{HtmlEncoder.Default.Encode(url ?? string.Empty)}" class="btn btn-sm btn-outline-primary">Sign in</a>""");
        }, c => c.NoSort().End())
        .Build();
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card mt-5 border-warning">
            <div class="card-header bg-warning text-dark">
                <strong>Dev Login — Sign in as any user</strong>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">Select a user to sign in as. This is only available in dev/preview environments.</p>
                <partial name="_Table" model="table" />
            </div>
        </div>

    </div>
</div>
