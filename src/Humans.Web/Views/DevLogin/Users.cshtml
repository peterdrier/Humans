@model List<(Guid Id, string DisplayName, string Email)>
@{
    ViewData["Title"] = "Dev Login — Choose User";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card mt-5 border-warning">
            <div class="card-header bg-warning text-dark">
                <strong>Dev Login — Sign in as any user</strong>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">Select a user to sign in as. This is only available in dev/preview environments.</p>
                <div class="table-responsive">
                    <table class="table table-hover table-sm">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td>@user.DisplayName</td>
                                    <td class="text-muted">@user.Email</td>
                                    <td>
                                        <a asp-controller="DevLogin" asp-action="SignInAsUser" asp-route-id="@user.Id"
                                           class="btn btn-sm btn-outline-primary">Sign in</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @if (User.Identity?.IsAuthenticated == true)
        {
        <div class="card mt-4 border-info">
            <div class="card-header bg-info text-white">
                <strong>Dev Tools — Seed Data</strong>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">Populate dev/preview environments with realistic demo data.</p>
                <div class="d-flex gap-2">
                    <form asp-controller="DevSeed" asp-action="SeedBudget" method="post">
                        <button type="submit" class="btn btn-outline-info">
                            <i class="fa-solid fa-coins me-1"></i> Seed Budget Data
                        </button>
                    </form>
                    <form asp-controller="DevSeed" asp-action="SeedTickets" method="post">
                        <button type="submit" class="btn btn-outline-info">
                            <i class="fa-solid fa-ticket me-1"></i> Seed Ticket Data
                        </button>
                    </form>
                </div>
            </div>
        </div>
        }
    </div>
</div>
