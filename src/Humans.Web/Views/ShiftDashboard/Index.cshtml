@model Humans.Web.Models.ShiftDashboardViewModel
@using Humans.Application.Interfaces
@using Humans.Domain.Enums
@using Humans.Web.Controllers

@{
    ViewData["Title"] = "Shift Dashboard";
    var antiForgeryWriter = new System.IO.StringWriter();
    Html.AntiForgeryToken().WriteTo(antiForgeryWriter, System.Text.Encodings.Web.HtmlEncoder.Default);
    var antiForgeryHtml = antiForgeryWriter.ToString();
    var searchUrl = Url.Action(nameof(ShiftDashboardController.SearchVolunteers), "ShiftDashboard");
    var voluntellUrl = Url.Action(nameof(ShiftDashboardController.Voluntell), "ShiftDashboard");
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Shift Dashboard</h2>
        <span class="badge bg-secondary fs-6">@Model.Shifts.Count shifts</span>
    </div>

    <vc:temp-data-alerts />

    @* Filter bar *@
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Date</label>
                    <input type="date" name="date" value="@Model.SelectedDate" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Department</label>
                    <select name="departmentId" class="form-select">
                        <option value="">All departments</option>
                        @foreach (var dept in Model.Departments)
                        {
                            <option value="@dept.TeamId" selected="@(Model.SelectedDepartmentId == dept.TeamId)">@dept.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-auto">
                    <button type="submit" class="btn btn-primary">Filter</button>
                    <a asp-action="Index" class="btn btn-outline-secondary ms-1">Clear</a>
                </div>
            </form>
        </div>
    </div>

    @* Staffing chart *@
    @await Html.PartialAsync("_StaffingChart", (Model.StaffingData, "dashboardStaffingChart"))

    @* Urgency table *@
    @if (Model.Shifts.Count == 0)
    {
        <div class="alert alert-info">No shifts match the current filters.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Shift</th>
                        <th>Department</th>
                        <th>Date / Time</th>
                        <th>Slots</th>
                        <th>Priority</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Shifts)
                    {
                        var shift = item.Shift;
                        var shiftDate = Model.EventSettings.GateOpeningDate.PlusDays(shift.DayOffset);
                        var shiftDateLabel = shiftDate.DayOfWeek.ToString()[..3] + " " + shiftDate.ToString("MMM d", null);
                        var period = shift.GetShiftPeriod(Model.EventSettings);
                        var periodBadge = period switch
                        {
                            ShiftPeriod.Build => "bg-info",
                            ShiftPeriod.Event => "bg-success",
                            ShiftPeriod.Strike => "bg-secondary",
                            _ => "bg-secondary"
                        };
                        var periodLabel = period switch
                        {
                            ShiftPeriod.Build => "Set-up",
                            ShiftPeriod.Event => "Event",
                            ShiftPeriod.Strike => "Strike",
                            _ => ""
                        };
                        var priorityBadge = shift.Rota.Priority switch
                        {
                            ShiftPriority.Essential => "bg-danger",
                            ShiftPriority.Important => "bg-warning text-dark",
                            _ => "bg-secondary"
                        };
                        var priorityLabel = shift.Rota.Priority.ToString();
                        var understaffed = item.ConfirmedCount < shift.MinVolunteers;
                        var collapseId = "voluntell-" + shift.Id.ToString("N");

                        <tr>
                            <td>
                                @shift.Rota.Name
                                @if (shift.AdminOnly) { <span class="badge bg-dark ms-1">Admin</span> }
                            </td>
                            <td>@item.DepartmentName</td>
                            <td>
                                <span class="badge @periodBadge me-1">@periodLabel</span>
                                @shiftDateLabel
                                <small class="text-muted ms-1">@shift.StartTime</small>
                            </td>
                            <td>
                                <span class="@(understaffed ? "text-danger fw-bold" : "")">@item.ConfirmedCount</span>
                                <small class="text-muted">/ @shift.MinVolunteers–@shift.MaxVolunteers</small>
                            </td>
                            <td><span class="badge @priorityBadge">@priorityLabel</span></td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary"
                                        type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#@collapseId"
                                        data-shift-id="@shift.Id">
                                    Voluntell
                                </button>
                            </td>
                        </tr>
                        <tr class="collapse" id="@collapseId">
                            <td colspan="6">
                                <div class="p-3 bg-light rounded border">
                                    <label class="form-label fw-semibold">Search volunteers for: @shift.Rota.Name</label>
                                    <input type="text"
                                           class="form-control mb-2 volunteer-search-input"
                                           placeholder="Type a name (min 2 chars)..."
                                           data-shift-id="@shift.Id"
                                           autocomplete="off" />
                                    <div class="volunteer-results" data-shift-id="@shift.Id"></div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
<script>
(function () {
    var searchUrl = '@Html.Raw(searchUrl)';
    var voluntellUrl = '@Html.Raw(voluntellUrl)';
    var tokenHtml = '@Html.Raw(antiForgeryHtml?.Replace("'", "\\'"))';

    function escapeHtml(str) {
        if (!str) return '';
        return str
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function renderBadges(items, cssClass) {
        if (!items || items.length === 0) return '';
        return items.map(function (i) {
            return '<span class="badge ' + cssClass + ' me-1">' + escapeHtml(i) + '</span>';
        }).join('');
    }

    function renderResults(results, shiftId, container) {
        if (!results || results.length === 0) {
            container.innerHTML = '<p class="text-muted small mb-0">No volunteers found.</p>';
            return;
        }

        var html = '<ul class="list-group list-group-flush">';
        results.forEach(function (r) {
            var overlapWarning = r.hasOverlap
                ? '<span class="badge bg-warning text-dark ms-2">Schedule conflict</span>'
                : '';
            var skillBadges = renderBadges(r.skills, 'bg-info text-dark');
            var quirkBadges = renderBadges(r.quirks, 'bg-secondary');
            var langBadges = renderBadges(r.languages, 'bg-primary');
            var diet = r.dietaryPreference
                ? '<small class="text-muted ms-2">' + escapeHtml(r.dietaryPreference) + '</small>'
                : '';

            html += '<li class="list-group-item d-flex justify-content-between align-items-start flex-wrap gap-2">';
            html += '<div>';
            html += '<strong>' + escapeHtml(r.displayName) + '</strong>';
            html += overlapWarning;
            html += ' <small class="text-muted">(' + r.bookedShiftCount + ' shifts)</small>';
            html += diet;
            html += '<div class="mt-1">' + skillBadges + quirkBadges + langBadges + '</div>';
            html += '</div>';
            html += '<form method="post" action="' + escapeHtml(voluntellUrl) + '">';
            html += tokenHtml;
            html += '<input type="hidden" name="shiftId" value="' + escapeHtml(shiftId) + '" />';
            html += '<input type="hidden" name="userId" value="' + escapeHtml(r.userId) + '" />';
            html += '<button type="submit" class="btn btn-sm btn-success"' + (r.hasOverlap ? ' title="Warning: schedule conflict"' : '') + '>Assign</button>';
            html += '</form>';
            html += '</li>';
        });
        html += '</ul>';
        container.innerHTML = html;
    }

    function debounce(fn, delay) {
        var timer;
        return function () {
            var args = arguments;
            clearTimeout(timer);
            timer = setTimeout(function () { fn.apply(null, args); }, delay);
        };
    }

    document.addEventListener('input', debounce(function (e) {
        var input = e.target;
        if (!input.classList.contains('volunteer-search-input')) return;

        var shiftId = input.dataset.shiftId;
        var query = input.value.trim();
        var resultsDiv = document.querySelector('.volunteer-results[data-shift-id="' + shiftId + '"]');
        if (!resultsDiv) return;

        if (query.length < 2) {
            resultsDiv.innerHTML = '';
            return;
        }

        var url = searchUrl + '?shiftId=' + encodeURIComponent(shiftId) + '&query=' + encodeURIComponent(query);
        fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(function (resp) { return resp.json(); })
            .then(function (data) { renderResults(data, shiftId, resultsDiv); })
            .catch(function () { resultsDiv.innerHTML = '<p class="text-danger small mb-0">Search failed.</p>'; });
    }, 300));
}());
</script>
}
