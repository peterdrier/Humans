@model Humans.Web.Models.TicketTransferRequestPageViewModel
@{
    ViewData["Title"] = "Transfer ticket";
}

<h1>Transfer ticket</h1>

<vc:temp-data-alerts />

<form asp-action="Lookup" method="post" class="mb-3">
    @Html.AntiForgeryToken()
    <input type="hidden" name="attendeeId" value="@Model.AttendeeId" />
    <label for="query">Recipient (full email address, or burner name)</label>
    <div class="input-group">
        <input id="query" name="query" value="@Model.Query" class="form-control" required />
        <button class="btn btn-primary" type="submit">Look up</button>
    </div>
</form>

@if (Model.LookupError is not null)
{
    <div class="alert alert-warning">@Model.LookupError</div>
}

@if (Model.Recipients.Count > 1)
{
    <p class="text-muted">Multiple matches — pick the one you mean.</p>
    <div class="list-group mb-3">
        @foreach (var r in Model.Recipients)
        {
            <form asp-action="Lookup" method="post" class="list-group-item list-group-item-action p-0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="attendeeId" value="@Model.AttendeeId" />
                <input type="hidden" name="query" value="@Model.Query" />
                <input type="hidden" name="selectedUserId" value="@r.UserId" />
                <button type="submit" class="btn btn-link text-decoration-none text-reset w-100 d-flex align-items-center p-3" style="text-align:left">
                    @if (r.HasCustomProfilePicture && r.ProfilePictureUrl is not null)
                    {
                        <img src="@r.ProfilePictureUrl" alt="" class="rounded-circle me-3" style="width:48px;height:48px" />
                    }
                    else
                    {
                        <div class="me-3 text-muted" style="width:48px;height:48px;display:flex;align-items:center;justify-content:center;background:#eee;border-radius:50%">
                            <strong>@(r.DisplayName.FirstOrDefault())</strong>
                        </div>
                    }
                    <div>
                        <div><strong>@r.DisplayName</strong></div>
                        @if (r.BurnerName is not null) { <div class="text-muted small">@r.BurnerName</div> }
                    </div>
                </button>
            </form>
        }
    </div>
}
else if (Model.Recipients.Count == 1)
{
    var recipient = Model.Recipients[0];
    <div class="card mb-3">
        <div class="card-body d-flex align-items-center">
            @if (recipient.HasCustomProfilePicture && recipient.ProfilePictureUrl is not null)
            {
                <img src="@recipient.ProfilePictureUrl" alt="" class="rounded-circle me-3" style="width:64px;height:64px" />
            }
            else
            {
                <div class="me-3 text-muted" style="width:64px;height:64px;display:flex;align-items:center;justify-content:center;background:#eee;border-radius:50%">
                    <strong>@(recipient.DisplayName.FirstOrDefault())</strong>
                </div>
            }
            <div>
                <div><strong>@recipient.DisplayName</strong></div>
                @if (recipient.BurnerName is not null) { <div class="text-muted">@recipient.BurnerName</div> }
                @if (recipient.PreferredEmail is not null) { <div class="text-muted">@recipient.PreferredEmail</div> }
            </div>
        </div>
    </div>

    <form asp-action="Submit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="AttendeeId" value="@Model.AttendeeId" />
        <input type="hidden" name="RecipientUserId" value="@recipient.UserId" />
        <div class="mb-3">
            <label for="Reason">Reason for transfer (visible to admin)</label>
            <textarea id="Reason" name="Reason" rows="3" class="form-control" required maxlength="1000"></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Request transfer</button>
        <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">Cancel</a>
    </form>
}
