@using Humans.Web.Models.Tables
@model Humans.Web.Models.Events.EventsDashboardViewModel
@{
    ViewData["Title"] = "Event Guide Dashboard";
}

<h2 class="mb-4">Event Guide Dashboard</h2>

<div class="row mb-4">
    <div class="col-md-2">
        <div class="card text-center">
            <div class="card-body py-2">
                <div class="fs-4 fw-bold">@Model.TotalCount</div>
                <small class="text-muted">Total</small>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-center">
            <div class="card-body py-2">
                <div class="fs-4 fw-bold text-warning">@Model.PendingCount</div>
                <small class="text-muted">Pending</small>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-center">
            <div class="card-body py-2">
                <div class="fs-4 fw-bold text-success">@Model.ApprovedCount</div>
                <small class="text-muted">Approved</small>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-center">
            <div class="card-body py-2">
                <div class="fs-4 fw-bold text-danger">@Model.RejectedCount</div>
                <small class="text-muted">Rejected</small>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-center">
            <div class="card-body py-2">
                <div class="fs-4 fw-bold text-info">@Model.ResubmitRequestedCount</div>
                <small class="text-muted">Resubmit</small>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-center">
            <div class="card-body py-2">
                <div class="fs-4 fw-bold text-secondary">@Model.WithdrawnCount</div>
                <small class="text-muted">Withdrawn</small>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="fa-solid fa-gavel me-1"></i>Moderation Queue
            </div>
            <div class="card-body text-center">
                <a asp-controller="EventsModeration" asp-action="Index" class="btn btn-warning btn-lg">
                    Moderate Events
                    @if (Model.PendingCount > 0)
                    {
                        <span class="badge bg-dark ms-1">@Model.PendingCount</span>
                    }
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="fa-solid fa-file-export me-1"></i>Exports
            </div>
            <div class="card-body d-flex gap-2 justify-content-center">
                <a asp-controller="EventsExport" asp-action="PrintGuide" class="btn btn-outline-danger" target="_blank">
                    <i class="fa-solid fa-print me-1"></i>Print Guide
                </a>
                <a asp-controller="EventsExport" asp-action="DownloadCsv" class="btn btn-outline-success">
                    <i class="fa-solid fa-download me-1"></i>Download CSV
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card mb-4">
            <div class="card-header">
                <i class="fa-solid fa-calendar-days me-1"></i>Coverage by Day
            </div>
            @if (Model.CoverageByDay.Count > 0)
            {
                var dayTable = TableModel.For(Model.CoverageByDay)
                    .Column("Day", r => r.DayLabel)
                    .Column("Approved", r => r.ApprovedCount, c => c.End())
                    .Build();
                <partial name="_Table" model="dayTable" />
            }
            else
            {
                <div class="card-body text-muted">No event settings configured.</div>
            }
        </div>
    </div>

    <div class="col-md-4">
        <div class="card mb-4">
            <div class="card-header">
                <i class="fa-solid fa-tags me-1"></i>Coverage by Category
            </div>
            @{
                var categoryTable = TableModel.For(Model.CoverageByCategory)
                    .Column("Category", r => r.CategoryName)
                    .Column("Sub", r => r.SubmittedCount, c => c.End())
                    .Column("App", r => r.ApprovedCount, c => c.End())
                    .Column("Pen", r => r.PendingCount, c => c.End())
                    .Column("Rej", r => r.RejectedCount, c => c.End())
                    .Build();
            }
            <partial name="_Table" model="categoryTable" />
        </div>
    </div>

    <div class="col-md-4">
        <div class="card mb-4">
            <div class="card-header">
                <i class="fa-solid fa-campground me-1"></i>Top Submitting Camps
            </div>
            @if (Model.TopCamps.Count > 0)
            {
                var campsTable = TableModel.For(Model.TopCamps)
                    .Column("Camp", r => r.CampName)
                    .Column("Sub", r => r.SubmittedCount, c => c.End())
                    .Column("App", r => r.ApprovedCount, c => c.End())
                    .Column("Pen", r => r.PendingCount, c => c.End())
                    .Build();
                <partial name="_Table" model="campsTable" />
            }
            else
            {
                <div class="card-body text-muted">No camp events submitted yet.</div>
            }
        </div>
    </div>
</div>
