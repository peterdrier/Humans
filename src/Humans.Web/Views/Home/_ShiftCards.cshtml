@model Humans.Web.Models.ShiftCardsViewModel

@if (Model.UrgentShifts.Count > 0)
{
    <div class="card border-0 shadow-sm mt-3">
        <div class="card-body">
            <h6 class="mb-3"><i class="fa-solid fa-fire text-danger me-1"></i>@Localizer["GetInvolved_UrgentShifts"]</h6>
            <ul class="list-unstyled mb-0">
                @foreach (var item in Model.UrgentShifts)
                {
                    <li class="d-flex justify-content-between align-items-center py-1">
                        <span>
                            <strong>@(item?.RotaName ?? item?.Shift?.Rota?.Name ?? Localizer["Common_Unknown"].Value)</strong>
                            <small class="text-muted ms-1">@(item?.DepartmentName ?? "")</small>
                        </span>
                        <span class="badge bg-danger">@(item?.RemainingSlots ?? 0) @((item?.RemainingSlots ?? 0) == 1 ? Localizer["Dashboard_SlotsSingular"].Value : Localizer["Dashboard_SlotsPlural"].Value)</span>
                    </li>
                }
            </ul>
            <a asp-controller="Shifts" asp-action="Index" class="btn btn-sm btn-outline-success mt-2">@Localizer["GetInvolved_BrowseAllShifts"]</a>
        </div>
    </div>
}
