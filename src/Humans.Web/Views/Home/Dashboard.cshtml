@using Humans.Domain.Enums
@model Humans.Web.Models.DashboardViewModel
@{
    ViewData["Title"] = Localizer["Dashboard_Title"].Value;
}


@* ─── Header ─── *@
<div class="row justify-content-center mb-4">
    <div class="col-lg-8">
        <div class="d-flex align-items-center">
            <vc:human user-id="@Model.UserId"
                      layout="Avatar"
                      size="64"
                      css-class="me-3" />
            <div>
                <h1 class="mb-1">
                    @Html.Raw(string.Format(Localizer["Dashboard_Welcome"].Value, Html.Encode(Model.DisplayName)))
                    @if (Model.MembershipTier != MembershipTier.Volunteer)
                    {
                        <span class="badge bg-primary ms-2 align-middle dashboard-membership-badge">@Model.MembershipTier</span>
                    }
                </h1>
                <p class="text-muted mb-0">@Localizer["Dashboard_Subtitle"]</p>
            </div>
        </div>
    </div>
</div>

@* ─── Rejection alert ─── *@
@if (Model.IsRejected)
{
    <div class="row justify-content-center mb-4">
        <div class="col-lg-8">
            <div class="alert alert-danger mb-0" role="alert">
                <h5 class="alert-heading">@Localizer["Dashboard_RejectedTitle"]</h5>
                <p class="mb-0">@Localizer["Dashboard_RejectedMessage"]</p>
                @if (!string.IsNullOrEmpty(Model.RejectionReason))
                {
                    <hr />
                    <p class="mb-0"><strong>@Localizer["Dashboard_RejectionReason"]:</strong> @Model.RejectionReason</p>
                }
            </div>
        </div>
    </div>
}

@* ─── Things to do (auto-hides when all complete; profile-completion nudge lives inside as a graded item) ─── *@
<div class="row justify-content-center mb-4">
    <div class="col-lg-8">
        <vc:things-to-do user-id="@Model.UserId"
                         is-volunteer-member="@Model.IsVolunteerMember"
                         has-shift-signups="@Model.HasShiftSignups"
                         profile-completion-percent="@Model.ProfileCompletionPercent" />
    </div>
</div>

@* ─── Pending consents alert ─── *@
@if (Model.PendingConsents > 0)
{
    <div class="row justify-content-center mb-4">
        <div class="col-lg-8">
            <div class="alert alert-warning d-flex align-items-center mb-0" role="alert">
                <i class="fa-solid fa-file-signature me-2"></i>
                <div>
                    <a asp-controller="Consent" asp-action="Index" class="alert-link">
                        @Model.PendingConsents @(Model.PendingConsents == 1 ? Localizer["Dashboard_AgreementSingular"].Value : Localizer["Dashboard_AgreementPlural"].Value)
                    </a>
                </div>
            </div>
        </div>
    </div>
}

@* ─── Term expiry warnings (Colaborador/Asociado) ─── *@
@if (Model.IsVolunteerMember && Model.MembershipTier != MembershipTier.Volunteer)
{
    <div class="row justify-content-center mb-4">
        <div class="col-lg-8">
            @if (Model.TermExpired)
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-body d-flex align-items-center py-3">
                        <div class="dashboard-action-icon dashboard-action-icon-sm dashboard-action-icon-danger me-3">
                            <i class="fa-solid fa-clock"></i>
                        </div>
                        <div class="flex-grow-1">
                            <strong>@Localizer["Dashboard_TermExpired"]</strong>
                            <br /><small class="text-muted">@Localizer["Dashboard_MembershipTier"]: @Model.MembershipTier</small>
                        </div>
                        <a asp-controller="GovernanceApplications" asp-action="Create" class="btn btn-sm btn-primary ms-3">@Localizer["Dashboard_RenewNow"]</a>
                    </div>
                </div>
            }
            else if (Model.TermExpiresSoon)
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-body d-flex align-items-center py-3">
                        <div class="dashboard-action-icon dashboard-action-icon-sm dashboard-action-icon-warning me-3">
                            <i class="fa-solid fa-clock"></i>
                        </div>
                        <div class="flex-grow-1">
                            @Html.Raw(string.Format(Localizer["Dashboard_TermExpiresSoon"].Value, Model.TermExpiresAt?.ToDate()))
                            <br /><small class="text-muted">@Localizer["Dashboard_MembershipTier"]: @Model.MembershipTier</small>
                        </div>
                        <a asp-controller="GovernanceApplications" asp-action="Create" class="btn btn-sm btn-warning ms-3">@Localizer["Dashboard_RenewNow"]</a>
                    </div>
                </div>
            }
            else if (Model.HasPendingApplication)
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-body d-flex align-items-center py-3">
                        <div class="dashboard-action-icon dashboard-action-icon-sm dashboard-action-icon-info me-3">
                            <i class="fa-solid fa-hourglass-half"></i>
                        </div>
                        <div>
                            <strong>@Localizer["Dashboard_TierApplicationPending"]</strong>
                            <br /><small class="text-muted">@Localizer["Dashboard_MembershipTier"]: @Model.MembershipTier</small>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-body d-flex align-items-center py-3">
                        <div class="dashboard-action-icon dashboard-action-icon-sm dashboard-action-icon-success me-3">
                            <i class="fa-solid fa-circle-check"></i>
                        </div>
                        <div>
                            <strong>@Localizer["Dashboard_TierActive"]</strong>
                            <span class="badge bg-primary ms-2">@Model.MembershipTier</span>
                            @if (Model.TermExpiresAt.HasValue)
                            {
                                <br /><small class="text-muted">@Html.Raw(string.Format(Localizer["Dashboard_TermExpires"].Value, Model.TermExpiresAt.Value.ToDate()))</small>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@* ─── Ticket Status ─── *@
<div class="row justify-content-center mb-5">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                @if (!Model.TicketsConfigured)
                {
                    <div class="d-flex align-items-center">
                        <div class="dashboard-action-icon dashboard-action-icon-sm dashboard-action-icon-warning me-3">
                            <i class="fa-solid fa-ticket"></i>
                        </div>
                        <div>
                            <strong>@Localizer["Dashboard_TicketNotConfigured"]</strong>
                        </div>
                    </div>
                }
                else if (Model.HasTicket)
                {
                    <div class="d-flex align-items-center">
                        <div class="dashboard-action-icon dashboard-action-icon-sm dashboard-action-icon-success me-3">
                            <i class="fa-solid fa-ticket"></i>
                        </div>
                        <div>
                            <h5 class="mb-0">@Localizer["Dashboard_TicketConfirmed"]</h5>
                            @if (Model.UserTicketCount > 1)
                            {
                                <small class="text-muted">@string.Format(Localizer["Dashboard_TicketCount"].Value, Model.UserTicketCount)</small>
                            }
                        </div>
                    </div>
                    <vc:my-ticket-stubs user-id="@Model.UserId" />
                    <div class="mt-3">
                        <a class="btn btn-sm btn-outline-secondary"
                           asp-controller="TicketTransfer" asp-action="Index">Transfers…</a>
                    </div>
                }
                else if (Model.ParticipationStatus == ParticipationStatus.NotAttending)
                {
                    <div class="d-flex align-items-center mb-3">
                        <div class="dashboard-action-icon dashboard-action-icon-sm dashboard-action-icon-neutral me-3">
                            <i class="fa-solid fa-ticket"></i>
                        </div>
                        <div>
                            <h5 class="mb-0">@Localizer["Dashboard_NotAttending"]</h5>
                            <small class="text-muted">@Localizer["Dashboard_NotAttendingHint"]</small>
                        </div>
                    </div>
                    <form asp-action="UndoNotAttending" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-primary btn-sm">
                            <i class="fa-solid fa-rotate-left me-1"></i> @Localizer["Dashboard_UndoNotAttending"]
                        </button>
                    </form>
                }
                else
                {
                    <div class="d-flex align-items-center mb-3">
                        <div class="dashboard-action-icon dashboard-action-icon-sm dashboard-action-icon-info me-3">
                            <i class="fa-solid fa-ticket"></i>
                        </div>
                        <div>
                            <h5 class="mb-0">@Localizer["Dashboard_TicketMissing"]</h5>
                            <small class="text-muted">@Localizer["Dashboard_TicketMissingHint"]</small>
                        </div>
                    </div>
                    <div class="d-flex flex-wrap gap-2 align-items-center">
                        <a href="@Model.TicketPurchaseUrl" target="_blank" rel="noopener" class="btn btn-primary">
                            <i class="fa-solid fa-external-link-alt me-1"></i> @Localizer["Dashboard_BuyTicket"]
                        </a>
                        <a asp-controller="Profile" asp-action="Emails" class="btn btn-outline-secondary btn-sm">@Localizer["Dashboard_DifferentEmail"]</a>
                    </div>
                    @if (Model.EventYear.HasValue)
                    {
                        <hr />
                        <form asp-action="DeclareNotAttending" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-secondary btn-sm">
                                <i class="fa-solid fa-xmark me-1"></i> @Localizer["Dashboard_DeclareNotAttending"]
                            </button>
                        </form>
                    }
                }
            </div>
        </div>
    </div>
</div>

@{
    var shiftCards = ViewData["ShiftCards"] as ShiftCardsViewModel;
    var hasUpcomingShifts = shiftCards?.NextShifts.Count > 0 || shiftCards?.PendingCount > 0;
}

@* ─── Your shifts (if signed up) ─── *@
@if (hasUpcomingShifts)
{
    <div class="row justify-content-center mb-5">
        <div class="col-lg-8">
            <vc:shift-signups user-id="@Model.UserId" view-mode="@ShiftSignupsViewMode.Self" />

            @if (shiftCards?.UrgentShifts.Count > 0)
            {
                @await Html.PartialAsync("_ShiftCards", shiftCards)
            }
        </div>
    </div>
}
else if (Model.IsShiftBrowsingOpen && Model.IsVolunteerMember)
{
    @* ─── Guided shift discovery — no shifts yet ─── *@
    <div class="row justify-content-center mb-5">
        <div class="col-lg-8">
            <div class="card border-0 shadow dashboard-callout">
                <div class="card-body text-center py-5 px-4">
                    <h2 class="display-6 fw-bold mb-3 dashboard-callout-title">
                        <i class="fa-solid fa-hand-holding-heart me-2"></i>@Localizer["GetInvolved_Title"]
                    </h2>
                    <p class="mb-2 dashboard-callout-copy">
                        @Localizer["GetInvolved_Intro"]
                    </p>

                    <div class="row g-3 my-4 justify-content-center">
                        <div class="col-sm-4">
                            <div class="rounded p-3 h-100 dashboard-callout-phase">
                                <h6 class="dashboard-callout-accent">@Localizer["GetInvolved_Phase_Setup"]</h6>
                                <small class="dashboard-callout-muted">@Localizer["GetInvolved_Phase_Setup_Desc"]</small>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="rounded p-3 h-100 dashboard-callout-phase">
                                <h6 class="dashboard-callout-accent">@Localizer["GetInvolved_Phase_Event"]</h6>
                                <small class="dashboard-callout-muted">@Localizer["GetInvolved_Phase_Event_Desc"]</small>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="rounded p-3 h-100 dashboard-callout-phase">
                                <h6 class="dashboard-callout-accent">@Localizer["GetInvolved_Phase_Strike"]</h6>
                                <small class="dashboard-callout-muted">@Localizer["GetInvolved_Phase_Strike_Desc"]</small>
                            </div>
                        </div>
                    </div>

                    @if (shiftCards?.UrgentShifts.Count > 0)
                    {
                        <div class="text-start mb-3 dashboard-callout-copy">
                            <h6 class="dashboard-callout-accent"><i class="fa-solid fa-fire me-1"></i>@Localizer["GetInvolved_UrgentShifts"]</h6>
                            <ul class="list-unstyled mb-0">
                                @foreach (var item in shiftCards.UrgentShifts)
                                {
                                    <li class="d-flex justify-content-between align-items-center py-1">
                                        <span>
                                            <strong>@(item?.RotaName ?? item?.Shift?.Rota?.Name ?? Localizer["Common_Unknown"].Value)</strong>
                                            <small class="ms-1 dashboard-callout-muted">@(item?.DepartmentName ?? "")</small>
                                        </span>
                                        <span class="badge bg-danger">@(item?.RemainingSlots ?? 0) @((item?.RemainingSlots ?? 0) == 1 ? Localizer["Dashboard_SlotsSingular"].Value : Localizer["Dashboard_SlotsPlural"].Value)</span>
                                    </li>
                                }
                            </ul>
                        </div>
                    }

                    <div class="d-flex justify-content-center gap-2">
                        <a asp-controller="Shifts" asp-action="Index" class="btn btn-lg px-4 dashboard-callout-primary">
                            <i class="fa-solid fa-calendar-alt me-1"></i>@Localizer["GetInvolved_BrowseAllShifts"]
                        </a>
                        <a asp-controller="Shifts" asp-action="Mine" class="btn btn-lg btn-outline-light px-4">
                            <i class="fa-solid fa-clipboard-list me-1"></i>@Localizer["GetInvolved_MyShifts"]
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@* ─── Get involved ─── *@
@if (Model.IsVolunteerMember)
{
    <div class="row justify-content-center mb-5">
        <div class="col-lg-8">
            <h5 class="text-muted mb-1">@Localizer["Dashboard_GetInvolved"]</h5>
            <p class="text-muted small mb-3 guest-section-sub">@Localizer["Dashboard_GetInvolvedSubtitle"]</p>
            <div class="row g-3">
                @await Html.PartialAsync("_DashboardActionCard", new DashboardActionCardViewModel
                {
                    Controller = "Shifts",
                    Action = "Index",
                    Title = Localizer["Nav_Shifts"].Value,
                    Description = Localizer["Dashboard_ShiftsDescription"].Value,
                    IconCssClass = "fa-solid fa-calendar-alt fa-lg",
                    ColumnClass = "col-sm-4"
                })
                @await Html.PartialAsync("_DashboardActionCard", new DashboardActionCardViewModel
                {
                    Controller = "Team",
                    Action = "Index",
                    Title = Localizer["Nav_Teams"].Value,
                    Description = Localizer["Dashboard_TeamsDescription"].Value,
                    IconCssClass = "fa-solid fa-people-group fa-lg",
                    ColumnClass = "col-sm-4"
                })
                @await Html.PartialAsync("_DashboardActionCard", new DashboardActionCardViewModel
                {
                    Controller = "Camp",
                    Action = "Index",
                    Title = Localizer["Camp_Plural"].Value,
                    Description = Localizer["Dashboard_CampsDescription"].Value,
                    IconCssClass = "fa-solid fa-campground fa-lg",
                    ColumnClass = "col-sm-4"
                })
            </div>
        </div>
    </div>
}

@* ─── Your stuff ─── *@
<div class="row justify-content-center mb-4">
    <div class="col-lg-8">
        <h5 class="text-muted mb-1">@Localizer["Dashboard_YourStuff"]</h5>
        <p class="text-muted small mb-3 guest-section-sub">@Localizer["Dashboard_YourStuffSubtitle"]</p>
        <div class="row g-3">
            @await Html.PartialAsync("_DashboardActionCard", new DashboardActionCardViewModel
            {
                Controller = "Profile",
                Action = "Edit",
                Title = Localizer["Dashboard_ProfileCard"].Value,
                Description = Localizer["Dashboard_ProfileCardDescription"].Value,
                IconCssClass = "fa-solid fa-user-pen",
                Compact = true
            })
            @await Html.PartialAsync("_DashboardActionCard", new DashboardActionCardViewModel
            {
                Controller = "Consent",
                Action = "Index",
                Title = Localizer["Dashboard_ConsentsCard"].Value,
                Description = Localizer["Dashboard_ConsentsCardDescription"].Value,
                IconCssClass = "fa-solid fa-file-signature",
                IconVariant = "info",
                Compact = true
            })
            @await Html.PartialAsync("_DashboardActionCard", new DashboardActionCardViewModel
            {
                Controller = "Profile",
                Action = "Privacy",
                Title = Localizer["Dashboard_PrivacyCard"].Value,
                Description = Localizer["Dashboard_PrivacyCardDescription"].Value,
                IconCssClass = "fa-solid fa-shield-halved",
                IconVariant = "info",
                Compact = true
            })
            @if (Model.IsVolunteerMember)
            {
                @await Html.PartialAsync("_DashboardActionCard", new DashboardActionCardViewModel
                {
                    Controller = "GovernanceApplications",
                    Action = "Index",
                    Title = Localizer["Nav_Governance"].Value,
                    Description = Localizer["Dashboard_GovernanceCardDescription"].Value,
                    IconCssClass = "fa-solid fa-landmark",
                    Compact = true
                })
            }
        </div>
    </div>
</div>

@* ─── Google Resources (volunteer only) ─── *@
@if (Model.IsVolunteerMember)
{
    <div class="row justify-content-center mb-4">
        <div class="col-lg-8">
            @await Component.InvokeAsync("MyGoogleResources")
        </div>
    </div>
}
