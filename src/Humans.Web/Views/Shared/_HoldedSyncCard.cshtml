@model Humans.Application.DTOs.Finance.HoldedSyncDashboardDto

<div class="card mb-3">
    <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="card-title mb-1">Holded sync</h5>
            <div class="text-muted small">
                Status: <strong>@Model.SyncStatus</strong>
                @if (Model.LastSyncAt is { } t)
                {
                    <text> &middot; Last sync @t.ToString("yyyy-MM-dd HH:mm 'UTC'", System.Globalization.CultureInfo.InvariantCulture)</text>
                }
                &middot; @Model.LastSyncedDocCount docs last cycle
                @if (Model.LastError is not null)
                {
                    <text> &middot; </text>
                    <span class="text-danger" title="@Model.LastError">Error</span>
                }
            </div>
        </div>
        <div class="d-flex align-items-center gap-2">
            <a asp-controller="Finance" asp-action="HoldedUnmatched" class="btn btn-outline-secondary btn-sm">
                Unmatched: <span class="badge bg-warning text-dark">@Model.UnmatchedCount</span>
            </a>
            <a asp-controller="Finance" asp-action="HoldedTags" class="btn btn-link btn-sm">Tag reference</a>
            <form asp-controller="Finance" asp-action="HoldedSyncRun" method="post" class="m-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-primary btn-sm">Sync now</button>
            </form>
        </div>
    </div>
</div>
