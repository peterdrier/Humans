@{
    var roleId = (Guid)ViewData["RoleId"]!;
    var slotIndex = (int)ViewData["SlotIndex"]!;
    var roleName = (string)ViewData["RoleName"]!;
    var slug = (string)ViewData["Slug"]!;
    var modalId = $"autoPromoteModal-{roleId}-{slotIndex}";
}

<div class="modal fade" id="@modalId" tabindex="-1" aria-labelledby="@(modalId)-label" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Camp" asp-action="AssignRole" asp-route-slug="@slug" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="campRoleDefinitionId" value="@roleId" />
                <input type="hidden" name="slotIndex" value="@slotIndex" />
                <input type="hidden" name="autoPromote" value="true" />

                <div class="modal-header">
                    <h5 class="modal-title" id="@(modalId)-label">
                        Add someone &amp; assign as @roleName
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted">
                        Use this when the human you want as <strong>@roleName</strong> is not yet a member of this barrio.
                        They will be added as an active member and assigned to the role in one step.
                    </p>
                    <div class="mb-3">
                        <label class="form-label">Human</label>
                        <input type="text" name="assigneeUserId" class="form-control" required
                               placeholder="User GUID — picker comes later" />
                        <div class="form-text">A proper humans-picker will replace this input in a later issue.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-solid fa-user-plus me-1"></i>Add &amp; assign
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
