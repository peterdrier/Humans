@{
    string? profilePictureUrl = ViewBag.ProfilePictureUrl as string;
    string initial = ViewBag.Initial as string ?? "?";
    int size = (int?)ViewBag.Size ?? 40;
    string? cssClass = ViewBag.CssClass as string;
    string bgColor = ViewBag.BgColor as string ?? "bg-secondary";
    double fontRem = (double?)ViewBag.FontRem ?? 0.8;
}
@if (!string.IsNullOrEmpty(profilePictureUrl))
{
    <img src="@profilePictureUrl" alt="" class="rounded-circle @cssClass" style="width: @(size)px; height: @(size)px; object-fit: cover;" />
}
else
{
    <div class="@bgColor rounded-circle d-flex align-items-center justify-content-center text-white @cssClass" style="width: @(size)px; height: @(size)px; font-size: @(fontRem)rem;">
        @initial
    </div>
}
