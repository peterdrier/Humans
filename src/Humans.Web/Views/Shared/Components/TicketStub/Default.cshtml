@model Humans.Application.DTOs.TicketStubInfo
@using Humans.Domain.Enums
@{
    var isVoid = Model.Status == TicketAttendeeStatus.Void;
    var pending = Model.HasPendingTransfer;
    // Emit the shared stub CSS once per request (the component renders many times).
    var emitCss = !Context.Items.ContainsKey("ticket-stub-css");
    if (emitCss) { Context.Items["ticket-stub-css"] = true; }
    // TODO(open item): source the event label from the active event instead of a constant.
    const string eventLabel = "Elsewhere 2026 · Admit One";
}
@if (emitCss)
{
    <style>
        .ticket-stub { display:flex; max-width:440px; border-radius:12px; overflow:hidden;
            background:#fff; border:1px solid #e3ddd0; box-shadow:0 3px 10px rgba(0,0,0,.12); position:relative; }
        .ticket-stub-main { flex:1; padding:13px 16px; background:linear-gradient(135deg,#faf7f0,#f3ecdd); min-width:0; }
        .ticket-stub-event { font-size:10px; letter-spacing:.16em; text-transform:uppercase; color:#9a8f78; font-weight:700; }
        .ticket-stub-name { font-size:19px; font-weight:800; color:#2e2a22; margin:2px 0; overflow-wrap:anywhere; }
        .ticket-stub-email { font-size:12.5px; color:#6b6453; overflow-wrap:anywhere; }
        .ticket-stub-side { width:74px; background:#efe7d6; display:flex; flex-direction:column; align-items:center;
            justify-content:center; gap:5px; border-left:2px dashed #c9bfa7; position:relative; flex-shrink:0; }
        .ticket-stub-serial { writing-mode:vertical-rl; font-family:ui-monospace,monospace; font-size:10px; color:#8a7f68; letter-spacing:.1em; }
        .ticket-stub-ico { font-size:18px; }
        .ticket-stub.pending .ticket-stub-main { filter:saturate(.6); }
        .ticket-stub.voided { opacity:.55; }
        .ticket-stub.voided .ticket-stub-name { text-decoration:line-through; }
        .ticket-stub-stamp { position:absolute; top:50%; left:38%; transform:translate(-50%,-50%) rotate(-14deg);
            border:3px solid #b5532e; color:#b5532e; font-weight:900; font-size:14px; letter-spacing:.08em;
            padding:3px 10px; border-radius:6px; text-transform:uppercase; opacity:.82; background:rgba(255,255,255,.35);
            pointer-events:none; white-space:nowrap; }
    </style>
}
<div class="ticket-stub@(pending ? " pending" : "")@(isVoid ? " voided" : "")">
    <div class="ticket-stub-main">
        <div class="ticket-stub-event">@eventLabel</div>
        <div class="ticket-stub-name">@Model.AttendeeName</div>
        @if (!string.IsNullOrEmpty(Model.AttendeeEmail))
        {
            <div class="ticket-stub-email">@Model.AttendeeEmail</div>
        }
    </div>
    <div class="ticket-stub-side">
        <span class="ticket-stub-ico">🎟️</span>
        @if (!string.IsNullOrEmpty(Model.VendorTicketId))
        {
            <span class="ticket-stub-serial">@Model.VendorTicketId</span>
        }
    </div>
    @if (pending)
    {
        <div class="ticket-stub-stamp">Transfer pending</div>
    }
</div>
