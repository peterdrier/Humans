@model Humans.Web.Models.Events.EventsCardViewModel

@functions {
    static string FormatDuration(int minutes)
    {
        var hours = minutes / 60;
        var mins = minutes % 60;
        if (hours == 0) return $"{mins}m";
        return mins == 0 ? $"{hours}h" : $"{hours}h {mins}m";
    }
}

<div class="card mb-4">
    <div class="card-header">
        <i class="fa-solid fa-calendar-days me-1"></i> Events
    </div>
    <div class="list-group list-group-flush">
        @foreach (var row in Model.Rows)
        {
            <div class="list-group-item">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <strong>@row.Title</strong>
                        <span class="badge bg-secondary ms-1">@row.CategoryName</span>
                        @if (row.IsRecurring)
                        {
                            <span class="badge bg-light text-dark ms-1" title="Recurring event">
                                <i class="fa-solid fa-repeat"></i>
                            </span>
                        }
                    </div>
                    <form method="post" asp-controller="Events" asp-action="ToggleCardFavourite"
                          asp-route-eventId="@row.EventId" asp-route-returnUrl="@Model.ReturnUrl" class="d-inline ms-2">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm @(row.IsFavourited ? "btn-danger" : "btn-outline-danger")"
                                title="@(row.IsFavourited ? "Remove from favourites" : "Add to favourites")">
                            <i class="fa-solid fa-heart"></i>
                        </button>
                    </form>
                </div>
                <div class="mt-1 small text-muted">
                    <i class="fa-solid fa-clock me-1"></i>@row.StartAt.ToWeekdayDayMonth() &middot;
                    @row.StartAt.ToTime() — @row.StartAt.AddMinutes(row.DurationMinutes).ToTime()
                    (@FormatDuration(row.DurationMinutes))
                    @if (row.VenueName != null)
                    {
                        <text> &middot; <i class="fa-solid fa-location-dot me-1"></i>@row.VenueName</text>
                    }
                    @if (!string.IsNullOrEmpty(row.LocationNote))
                    {
                        <text> &middot; @row.LocationNote</text>
                    }
                    @if (!string.IsNullOrEmpty(row.Host))
                    {
                        <text> &middot; <i class="fa-solid fa-user me-1"></i>@row.Host</text>
                    }
                </div>
                @if (!string.IsNullOrEmpty(row.Description))
                {
                    <p class="mt-2 mb-0 small">@row.Description</p>
                }
            </div>
        }
    </div>
</div>
