@model Humans.Web.Models.AdminDashboardViewModel

<div class="card">
    <div class="card-head">
        <h3>Staffing by department</h3>
        <small>
            @if (Model.ShiftTotalOf.HasValue)
            {
                <text>event-wide · @Model.ShiftFilledOf / @Model.ShiftTotalOf shifts</text>
            }
        </small>
    </div>
    <div class="staffing">
        @if (Model.StaffingByDepartment.Count == 0)
        {
            <p class="text-muted px-3">
                Live staffing tile coming — see
                <a asp-controller="Shifts" asp-action="Index">Shifts</a>.
            </p>
        }
        else
        {
            foreach (var dept in Model.StaffingByDepartment)
            {
                var pct = (int)(dept.Ratio * 100);
                <div class="dept-row">
                    <span class="name">@dept.Name</span>
                    <div class="track @dept.TrackClass"><div style="width:@(pct)%"></div></div>
                    <span class="num">@pct%</span>
                </div>
            }
        }
    </div>
</div>
