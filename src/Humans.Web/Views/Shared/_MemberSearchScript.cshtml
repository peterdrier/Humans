@{
    var searchInputSelector = (string?)ViewData["SearchInputSelector"] ?? "#memberSearch";
    var resultsSelector = (string?)ViewData["ResultsSelector"] ?? "#searchResults";
    var searchUrl = (string?)ViewData["SearchUrl"] ?? string.Empty;
    var addUrl = (string?)ViewData["AddUrl"] ?? string.Empty;
    var noResultsText = ((string?)ViewData["NoResultsText"] ?? "No results found.")
        .Replace("'", "\\'", StringComparison.Ordinal);
    var addText = ((string?)ViewData["AddText"] ?? "Add")
        .Replace("'", "\\'", StringComparison.Ordinal);
}
(function () {
    var searchInput = document.querySelector('@searchInputSelector');
    var resultsDiv = document.querySelector('@resultsSelector');
    if (!searchInput || !resultsDiv) {
        return;
    }

    var debounceTimer = null;
    var searchUrl = '@Html.Raw(searchUrl)';
    var addUrl = '@Html.Raw(addUrl)';
    var noResultsText = '@noResultsText';
    var addText = '@addText';
    var antiForgeryToken = getRequestVerificationToken();

    searchInput.addEventListener('input', function () {
        clearTimeout(debounceTimer);
        var query = searchInput.value.trim();
        if (query.length < 2) {
            resultsDiv.style.display = 'none';
            resultsDiv.innerHTML = '';
            return;
        }

        debounceTimer = setTimeout(function () {
            fetch(searchUrl + '?q=' + encodeURIComponent(query))
                .then(function (res) { return res.json(); })
                .then(function (data) {
                    resultsDiv.innerHTML = '';
                    if (data.length === 0) {
                        resultsDiv.innerHTML = '<div class="list-group-item text-muted">' + escapeHtml(noResultsText) + '</div>';
                    } else {
                        data.forEach(function (user) {
                            var item = document.createElement('div');
                            item.className = 'list-group-item d-flex justify-content-between align-items-center';
                            item.innerHTML = '<div><strong>' + escapeHtml(user.displayName) + '</strong> <small class="text-muted">' + escapeHtml(user.email) + '</small></div>'
                                + '<form method="post" action="' + addUrl + '" class="d-inline">'
                                + '<input type="hidden" name="__RequestVerificationToken" value="' + antiForgeryToken + '" />'
                                + '<input type="hidden" name="UserId" value="' + user.userId + '" />'
                                + '<button type="submit" class="btn btn-sm btn-success">' + escapeHtml(addText) + '</button>'
                                + '</form>';
                            resultsDiv.appendChild(item);
                        });
                    }
                    resultsDiv.style.display = 'block';
                })
                .catch(function () {
                    resultsDiv.style.display = 'none';
                });
        }, 300);
    });

    document.addEventListener('click', function (e) {
        if (!resultsDiv.contains(e.target) && e.target !== searchInput) {
            resultsDiv.style.display = 'none';
        }
    });
}());
