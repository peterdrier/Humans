@model Humans.Web.Models.AuditLogListViewModel

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Audit Log</h1>
    <form asp-action="CheckDriveActivity" method="post" class="d-inline" id="checkForm">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-warning" id="checkBtn">
            Check Drive Activity Now
        </button>
    </form>
</div>

<vc:temp-data-alerts />

@if (Model.AnomalyCount > 0)
{
    <div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
        <strong class="me-2">@Model.AnomalyCount anomalous permission change(s) detected.</strong>
        <a asp-action="AuditLog" asp-route-filter="AnomalousPermissionDetected" class="alert-link">View all</a>
    </div>
}

<div class="mb-3">
    <div class="btn-group" role="group">
        <a asp-action="AuditLog" class="btn btn-sm @(string.IsNullOrEmpty(Model.ActionFilter) ? "btn-primary" : "btn-outline-primary")">
            All
        </a>
        <a asp-action="AuditLog" asp-route-filter="AnomalousPermissionDetected"
           class="btn btn-sm @Model.ActionFilter.ToAuditFilterButtonClass(nameof(AuditAction.AnomalousPermissionDetected), "btn-warning", "btn-outline-warning")">
            Anomalous Permissions
            @if (Model.AnomalyCount > 0)
            {
                <span class="badge bg-danger ms-1">@Model.AnomalyCount</span>
            }
        </a>
        <a asp-action="AuditLog" asp-route-filter="GoogleResourceAccessGranted"
           class="btn btn-sm @Model.ActionFilter.ToAuditFilterButtonClass(nameof(AuditAction.GoogleResourceAccessGranted), "btn-primary", "btn-outline-primary")">
            Access Granted
        </a>
        <a asp-action="AuditLog" asp-route-filter="GoogleResourceAccessRevoked"
           class="btn btn-sm @Model.ActionFilter.ToAuditFilterButtonClass(nameof(AuditAction.GoogleResourceAccessRevoked), "btn-primary", "btn-outline-primary")">
            Access Revoked
        </a>
        <a asp-action="AuditLog" asp-route-filter="MemberSuspended"
           class="btn btn-sm @Model.ActionFilter.ToAuditFilterButtonClass(nameof(AuditAction.MemberSuspended), "btn-primary", "btn-outline-primary")">
            Suspensions
        </a>
        <a asp-action="AuditLog" asp-route-filter="RoleAssigned"
           class="btn btn-sm @Model.ActionFilter.ToAuditFilterButtonClass(nameof(AuditAction.RoleAssigned), "btn-primary", "btn-outline-primary")">
            Roles
        </a>
    </div>
</div>

@if (Model.Entries.Count == 0)
{
    <div class="alert alert-info">
        No audit log entries found.
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Action</th>
                        <th>Description</th>
                        <th>Actor</th>
                        <th>When</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in Model.Entries)
                    {
                        var rowClass = entry.Action.ToAuditEntryRowClass();
                        <tr class="@rowClass">
                            <td>
                                <span class="badge @entry.Action.ToAuditBadgeClass()">@entry.Action.ToAuditBadgeLabel()</span>
                            </td>
                            <td>@entry.Description</td>
                            <td>
                                @if (entry.IsSystemAction)
                                {
                                    <span class="badge bg-info">System</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Admin</span>
                                }
                                <span class="ms-1">@entry.ActorName</span>
                            </td>
                            <td class="text-nowrap">@entry.OccurredAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (var i = 1; i <= Model.TotalPages && i <= 10; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a asp-action="AuditLog" asp-route-filter="@Model.ActionFilter" asp-route-page="@i" class="page-link">@i</a>
                </li>
            }
            @if (Model.TotalPages > 10)
            {
                <li class="page-item disabled"><span class="page-link">...</span></li>
            }
        </ul>
    </nav>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">Back to Dashboard</a>
</div>
