@using Humans.Domain.Constants
@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@model Humans.Web.Models.AdminRoleAssignmentListViewModel

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>@Localizer["AdminRoles_Title"]</h1>
    <span class="text-muted">@string.Format(Localizer["Admin_TotalCount"].Value, Model.TotalCount)</span>
</div>

<div class="card mb-4">
    <div class="card-body d-flex justify-content-between align-items-center">
        <div class="btn-group" role="group">
            <a asp-action="Roles" asp-route-showInactive="@Model.ShowInactive"
               class="btn @(string.IsNullOrEmpty(Model.RoleFilter) ? "btn-primary" : "btn-outline-primary")">
                @Localizer["AdminRoles_All"]
            </a>
            @foreach (var role in RoleNames.All)
            {
                var label = role != RoleNames.Admin && role.EndsWith(RoleNames.Admin, StringComparison.Ordinal)
                    ? role[..^RoleNames.Admin.Length]
                    : role;
                <a asp-action="Roles" asp-route-role="@role" asp-route-showInactive="@Model.ShowInactive"
                   class="btn @(Model.RoleFilter == role ? "btn-primary" : "btn-outline-primary")">
                    @label
                </a>
            }
        </div>
        <div>
            @if (Model.ShowInactive)
            {
                <a asp-action="Roles" asp-route-role="@Model.RoleFilter" asp-route-showInactive="false" class="btn btn-outline-secondary btn-sm">
                    @Localizer["AdminRoles_HideInactive"]
                </a>
            }
            else
            {
                <a asp-action="Roles" asp-route-role="@Model.RoleFilter" asp-route-showInactive="true" class="btn btn-outline-secondary btn-sm">
                    @Localizer["AdminRoles_ShowInactive"]
                </a>
            }
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        @{
            Func<Humans.Web.Models.AdminRoleAssignmentViewModel, IHtmlContent> userCell =
                @<text>
                    <vc:human user-id="@item.UserId" link="Admin" />
                    <br />
                    <small class="text-muted">@item.UserEmail</small>
                </text>;
            Func<Humans.Web.Models.AdminRoleAssignmentViewModel, IHtmlContent> roleCell =
                @<text><strong>@item.RoleName</strong></text>;
            Func<Humans.Web.Models.AdminRoleAssignmentViewModel, IHtmlContent> validToCell =
                @<text>
                    @if (item.ValidTo.HasValue)
                    {
                        @item.ValidTo.Value.ToDate()
                    }
                    else
                    {
                        <span class="text-muted">-</span>
                    }
                </text>;
            Func<Humans.Web.Models.AdminRoleAssignmentViewModel, IHtmlContent> statusCell =
                @<text>
                    @if (item.IsActive)
                    {
                        <span class="badge bg-success">@Localizer["AdminHuman_Active"]</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@Localizer["AdminHuman_Ended"]</span>
                    }
                </text>;
            Func<Humans.Web.Models.AdminRoleAssignmentViewModel, IHtmlContent> actionCell =
                @<text>
                    @if (item.IsActive)
                    {
                        <form asp-controller="UsersAdmin" asp-action="EndRole" asp-route-id="@item.UserId" asp-route-roleId="@item.Id" method="post" class="d-inline"
                              data-confirm="@Localizer["AdminHuman_EndRoleConfirm"].Value">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">@Localizer["AdminHuman_End"]</button>
                        </form>
                    }
                </text>;
            var rolesTable = TableModel.For(Model.RoleAssignments)
                .Template(Localizer["AdminRoles_User"].Value, userCell)
                .Template(Localizer["MyTeams_Role"].Value, roleCell)
                .Column(Localizer["AdminRoles_ValidFrom"].Value, ra => ra.ValidFrom.ToDate())
                .Template(Localizer["AdminRoles_ValidTo"].Value, validToCell)
                .Template(Localizer["Common_Status"].Value, statusCell, c => c.NoSort())
                .Template("", actionCell, c => c.NoSort().End())
                .RowCss(ra => ra.IsActive ? null : "table-secondary")
                .Empty(Localizer["AdminHuman_NoRoleAssignments"].Value)
                .ServerMode(null, false, new PagerViewModel(Model.TotalPages, Model.PageNumber, "Roles") { NavCssClass = "mt-4" })
                .Build();
        }
        <partial name="_Table" model="rolesTable" />
    </div>
</div>
