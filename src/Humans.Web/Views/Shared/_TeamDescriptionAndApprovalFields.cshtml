@model Humans.Web.Models.TeamFormViewModelBase
@{
    var isReadOnly = (bool?)ViewData["IsReadOnly"] ?? false;
    var showRequiresApprovalHelp = (bool?)ViewData["ShowRequiresApprovalHelp"] ?? true;
}

<div class="mb-3">
    <label asp-for="Description" class="form-label">@Localizer["AdminTeams_DescriptionOptional"]</label>
    <textarea asp-for="Description" class="form-control" rows="4" disabled="@isReadOnly"></textarea>
    <span asp-validation-for="Description" class="text-danger"></span>
</div>

<div class="mb-3 form-check">
    <input asp-for="RequiresApproval" type="checkbox" class="form-check-input" disabled="@isReadOnly" />
    <label asp-for="RequiresApproval" class="form-check-label">@Localizer["AdminTeams_RequireApproval"]</label>
    @if (showRequiresApprovalHelp)
    {
        <div class="form-text">@Localizer["AdminTeams_RequireApprovalHelp"]</div>
    }
</div>
