@using Humans.Web.Controllers
@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@model Humans.Web.Controllers.AgentConversationsViewModel
@{
    ViewData["Title"] = Model.IsAdminView ? "Agent Conversations" : Localizer["Agent_HistoryTitle"].Value;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">@ViewData["Title"]</h2>
    @if (Model.IsAdminView)
    {
        <a asp-controller="AdminAgent" asp-action="Settings" class="btn btn-outline-secondary btn-sm">Settings</a>
    }
</div>

@if (Model.IsAdminView)
{
    <form method="get" class="row g-2 mb-3">
        <div class="col-auto">
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" name="refusalsOnly" value="true" @(Context.Request.Query["refusalsOnly"] == "true" ? "checked" : null) id="refusalsOnly" />
                <label class="form-check-label" for="refusalsOnly">Refusals only</label>
            </div>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-outline-primary btn-sm">Filter</button>
        </div>
    </form>
}

@if (!Model.Rows.Any())
{
    <p class="text-muted">@Localizer["Agent_HistoryEmpty"]</p>
}
else
{
    Func<AgentConversationRow, IHtmlContent> humanCell =
        @<text><vc:human user-id="@item.Conversation.UserId" link="Admin" /></text>;
    Func<AgentConversationRow, IHtmlContent> startedCell =
        @<text><span class="text-nowrap">@item.Conversation.StartedAt.ToInvariantTimestamp()</span></text>;
    Func<AgentConversationRow, IHtmlContent> lastMessageCell =
        @<text><span class="text-nowrap">@item.Conversation.LastMessageAt.ToInvariantTimestamp()</span></text>;
    // Non-admin viewers go to the user-facing transcript (issue #632) which
    // reuses the live-chat bubble style and surfaces the live user-context tail.
    // Admins keep the existing token/tool-call diagnostic view.
    Func<AgentConversationRow, IHtmlContent> viewCell = Model.IsAdminView
        ? @<text><a asp-action="ConversationDetail" asp-route-id="@item.Conversation.Id">View</a></text>
        : @<text><a asp-action="Conversation" asp-route-id="@item.Conversation.Id">View</a></text>;
    var b = TableModel.For(Model.Rows);
    if (Model.IsAdminView)
    {
        b = b.Template("Human", humanCell);
    }
    b = b.Template(Localizer["Agent_HistoryStarted"].Value, startedCell);
    if (Model.IsAdminView)
    {
        b = b.Column("Locale", r => r.Conversation.Locale);
    }
    var table = b.Column(Localizer["Agent_HistoryMessages"].Value, r => r.Conversation.MessageCount, c => c.End())
        .Template(Localizer["Agent_HistoryLastMessage"].Value, lastMessageCell)
        .Template("", viewCell, c => c.NoSort())
        .Build();
    <partial name="_Table" model="table" />
}
