@using Humans.Web.Models.Tables
@using Microsoft.AspNetCore.Html
@using Humans.Application.Interfaces.Budget
@model Humans.Web.Models.CoordinatorBudgetViewModel
@{
    ViewData["Title"] = $"Budget - {Model.Year.Name}";
    var groups = Model.Year.Groups
        .Where(g => !g.IsTicketingGroup || Model.IsFinanceAdmin)
        .OrderBy(g => g.SortOrder)
        .ToList();
    var totalAllocated = groups.SelectMany(g => g.Categories).Sum(c => c.AllocatedAmount);
    var totalLineItems = groups.SelectMany(g => g.Categories).SelectMany(c => c.LineItems).Where(li => !li.IsCashflowOnly).Sum(li => li.Amount);
    var unallocated = totalAllocated - totalLineItems;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Summary">Budget</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Year.Name</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center gap-3">
        <h1 class="mb-0">@Model.Year.Name</h1>
        <span class="badge bg-success fs-6">@Model.Year.Status</span>
    </div>
    @if (Model.IsFinanceAdmin)
    {
        <a asp-controller="Finance" asp-action="Index" class="btn btn-outline-primary">
            <i class="fa-solid fa-gear me-1"></i>Finance Admin <i class="fa-solid fa-lock auth-lock-icon"></i>
        </a>
    }
</div>


<div class="row mb-4">
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted">Total Allocated</h6>
                <h3 class="card-title mb-0">&euro;@totalAllocated.ToString("N2")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted">Detailed in Line Items</h6>
                <h3 class="card-title mb-0">&euro;@totalLineItems.ToString("N2")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted">Unallocated</h6>
                <h3 class="card-title mb-0 @(unallocated < 0 ? "text-danger" : "")">
                    &euro;@unallocated.ToString("N2")
                </h3>
            </div>
        </div>
    </div>
</div>

@if (!groups.Any())
{
    <div class="card">
        <div class="card-body text-center py-4">
            <p class="text-muted mb-0">No budget groups available yet.</p>
        </div>
    </div>
}

@foreach (var group in groups)
{
    var groupAllocated = group.Categories.Sum(c => c.AllocatedAmount);
    var collapseId = $"group-{group.Id.ToString("N")}";

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center" role="button" data-bs-toggle="collapse" data-bs-target="#@collapseId">
            <div>
                <strong>@group.Name</strong>
                <span class="text-muted ms-2">(@group.Categories.Count categories)</span>
                @if (group.IsDepartmentGroup)
                {
                    <span class="badge bg-info ms-1">Departments</span>
                }
                @if (group.IsRestricted)
                {
                    <span class="badge bg-secondary ms-1"><i class="fa-solid fa-lock me-1"></i>Restricted</span>
                }
            </div>
            <span class="text-muted">&euro;@groupAllocated.ToString("N2")</span>
        </div>
        <div id="@collapseId" class="collapse show">
            <div class="card-body p-0">
                @if (group.Categories.Any())
                {
                    Func<BudgetCategoryDetail, IHtmlContent> categoryNameCell = @<text>
                        @item.Name
                        @if (item.TeamId.HasValue && Model.EditableTeamIds.Contains(item.TeamId.Value))
                        {
                            <span class="badge bg-success ms-1">Your dept</span>
                        }
                    </text>;
                    Func<BudgetCategoryDetail, IHtmlContent> unallocatedCell = @<text>
                        @{ var cellUnallocated = item.AllocatedAmount - item.LineItems.Where(li => !li.IsCashflowOnly).Sum(li => li.Amount); }
                        <span class="@(cellUnallocated < 0 ? "text-danger" : "")">
                            &euro;@cellUnallocated.ToString("N2", System.Globalization.CultureInfo.CurrentCulture)
                        </span>
                    </text>;
                    Func<BudgetCategoryDetail, IHtmlContent> expenditureTypeCell = @<text>
                        <span class="badge bg-@(item.ExpenditureType == ExpenditureType.CapEx ? "primary" : "secondary")">
                            @item.ExpenditureType
                        </span>
                    </text>;
                    Func<BudgetCategoryDetail, IHtmlContent> actionsCell = @<text>
                        @if (group.IsRestricted && !Model.IsFinanceAdmin)
                        {
                            <span class="badge bg-secondary"><i class="fa-solid fa-lock me-1"></i>Restricted</span>
                        }
                        else
                        {
                            var isEditable = Model.IsFinanceAdmin || (item.TeamId.HasValue && Model.EditableTeamIds.Contains(item.TeamId.Value));
                            <a asp-action="CategoryDetail" asp-route-id="@item.Id"
                               class="btn btn-outline-@(isEditable ? "primary" : "secondary") btn-sm">
                                @(isEditable ? "Manage" : "View") <i class="fa-solid fa-arrow-right ms-1"></i>
                            </a>
                        }
                    </text>;
                    var groupTable = TableModel.For(group.Categories.OrderBy(c => c.SortOrder).ToList())
                        .Template("Category", categoryNameCell)
                        .Column("Allocated (€)", c => c.AllocatedAmount, c => c.Currency().End())
                        .Column("Line Items (€)", c => c.LineItems.Where(li => !li.IsCashflowOnly).Sum(li => li.Amount), c => c.Currency().End())
                        .Template("Unallocated", unallocatedCell, c => c.End())
                        .Template("Type", expenditureTypeCell)
                        .Template("", actionsCell, c => c.NoSort().End())
                        .Build();
                    <partial name="_Table" model="groupTable" />
                }
                else
                {
                    <div class="card-body text-center text-muted py-3">
                        No categories in this group.
                    </div>
                }
            </div>
        </div>
    </div>
}
